+			while (true) {
+				thread_lock(&thread->xnu_thread);
+				bool still_waiting = (thread->xnu_thread.state & TH_WAIT) != 0;
+				thread_unlock(&thread->xnu_thread);
+				if (!still_waiting) {
+					break;
+				}
+				dtape_hooks->thread_suspend(thread->context, NULL, thread, NULL);
+			}
+		}
