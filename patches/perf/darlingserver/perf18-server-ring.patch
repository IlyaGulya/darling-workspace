+              f"file: 0x{s['old_fileoff']:x} -> plane+0x{s['new_plane_off']:x} (size 0x{s['filesize']:x})")
+print(f"\nplane sizes: TEXT=0x{planes['__TEXT']:x}  DATA=0x{planes['__DATA']:x}  LINKEDIT=0x{planes['__LINKEDIT']:x}")
