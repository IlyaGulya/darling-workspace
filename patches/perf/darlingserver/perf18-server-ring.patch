+                elif dTgt==dText:
+                    if ptgt!=exp: rip_bad+=1; fails+=1
+                    else: rip_st_ok+=1
+                else:
+                    if ptgt!=exp: rip_bad+=1; fails+=1; print("FAIL %s helper@%#x rip not rewritten (%#x!=%#x)"%(gp,pos,ptgt,exp))
+                    else: rip_rw_ok+=1
