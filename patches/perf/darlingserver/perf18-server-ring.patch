 	std::unique_lock lock(_rwlock);
 
@@ -1693,43 +1745,15 @@ void DarlingServer::Thread::pushCallReply(std::shared_ptr<Call> expectedCall, Me
 
 		_interrupts.top().savedReply = std::move(reply);
