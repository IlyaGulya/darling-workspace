 			}
 		} else {
 			return false; // in flight but no reply yet
 		}
 	}
 
+	if (resumeRealFiber) {
+		// resume the parked deallocate fiber with the synthesized munmap reply (the UDS path's wakeup).
+		dtape_semaphore_up(_s2cReplySempahore);
