+void DarlingServer::Server::_setAllRingStates(uint32_t state) {
+	std::unique_lock lock(_ringThreadsLock);
+	for (auto& weak : _ringThreads) {
+		if (auto t = weak.lock()) {
+			if (auto r = t->ring()) {
+				r->setServerState(state);
+			}
+		}
+	}
+};
