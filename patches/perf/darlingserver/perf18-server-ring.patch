+	if ! "$CXX" -std=c++17 -DDSERVER_RING_TRANSPORT -DRED_BREAK_VERDICT_S2C -I"$GEN_RPC" -I"$INC" -I"$ININC" -o "$TMP/hm_red2" "$HMSRC" "$HMIMPL" 2>/dev/null; then
