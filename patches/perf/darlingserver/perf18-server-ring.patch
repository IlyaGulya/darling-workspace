+		echo "attach-census GREEN arm failed to COMPILE"; exit 2
+	fi
+	if ! "$TMP/ac_green"; then
+		echo "attach-census GREEN arm FAILED -- pre/post split or eligible accounting wrong"; exit 1
+	fi
+	echo
+	echo "== attach-census RED arm 1 (-DRED_BREAK_DISARMED_NOOP: disarmed recording must change counts, MUST fail) =="
+	if ! "$CXX" -std=c++17 -DDSERVER_RING_TRANSPORT -DRED_BREAK_DISARMED_NOOP -I"$GEN_RPC" -I"$INC" -I"$ININC" -o "$TMP/ac_red1" "$ACSRC" "$ACIMPL" 2>/dev/null; then
+		echo "attach-census RED arm 1 failed to COMPILE -- gate broken"; exit 2
+	fi
+	if "$TMP/ac_red1" >/dev/null 2>&1; then
+		echo "attach-census RED arm 1 PASSED but must FAIL -- default-OFF no-op invariant not exercised"; exit 1
+	fi
+	echo "  attach-census RED arm 1 correctly failed."
+	echo
+	echo "== attach-census RED arm 2 (-DRED_BREAK_ELIGIBLE_SPLIT: ineligible call counted as eligible, MUST fail) =="
+	if ! "$CXX" -std=c++17 -DDSERVER_RING_TRANSPORT -DRED_BREAK_ELIGIBLE_SPLIT -I"$GEN_RPC" -I"$INC" -I"$ININC" -o "$TMP/ac_red2" "$ACSRC" "$ACIMPL" 2>/dev/null; then
+		echo "attach-census RED arm 2 failed to COMPILE -- gate broken"; exit 2
+	fi
+	if "$TMP/ac_red2" >/dev/null 2>&1; then
+		echo "attach-census RED arm 2 PASSED but must FAIL -- eligible-pool accounting not exercised"; exit 1
+	fi
+	echo "  attach-census RED arm 2 correctly failed."
+	echo
+	echo "attach-census gate: RED->GREEN OK"
+	echo
+fi
+
 echo "all perf#18 ring gates: OK"

From 3811b71157130794e958cd0af313834fad39ea86 Mon Sep 17 00:00:00 2001
From: Ilya Gulya <ilya@gulya.me>
Date: Tue, 30 Jun 2026 14:30:28 +0000
Subject: [PATCH] perf#18 D16 (dar-dar6x4-perf-5dq / dar-1il.11): per-thread
 ring lanes gate + A/B

The server side of D16 needs NO change (it was already per-thread: _ringThreads /
_drainRings / per-thread RingAttach + wake-fd Monitor). This commit carries the
deterministic multi-lane gate, the live A/B runner, and the deliverable.

tests/ring_multilane_gate_test.c -- the dar-my8 exhaustive-interleaving lesson applied
to the per-thread lane table's active-bit/generation bookkeeping. A single-stepped
driver enumerates EVERY ordering of {acquire-lane, reader-observes, release, reclaim}
and asserts: a reader never acts on a half-initialized lane (acquire publishes active
LAST) and never false-matches a stale epoch (every reclaim bumps the generation;
release clears active first). GREEN = zero violations. RED arms
-DRACE_PUBLISH_ACTIVE_BEFORE_INIT and -DRACE_REUSE_WITHOUT_GEN_BUMP both fail. Wired
into run-ring-shm-validate.sh (RED->GREEN).

tests/run-per-thread-lanes-d16.sh -- live A/B runner. Deploys a matched census server
+ chosen dylib (baseline single-owner vs D16 per-thread) + optionally the matched dyld
(DEPLOY_DYLD=1; drives attach_rejects to 0 so the post-attach pool is the clean
signal), warm-boots with the attach-census + heatmap armed, runs the same warm
workload, dumps the snapshot.

Result (matched dyld+dylib+server, same workload): post_attach_eligible_UDS
1533 -> 231 (-85%); per-op heatmap ring-share ~100% on the eligible ops
(mach_reply_port/self-traps/uidgid/get_tracer/set_thread_handles now 100% ring; only
the first-eligible-call-before-lane-attach -- started_suspended, vchroot_path --
keeps a residual UDS share). Fork-storm 3/3; ring_fast_fail/s2c_full/fast_suspend/
clients_blocked all 0. Doc + both snapshots included. Guest impl + full design in the
xnu commit; ABI stays v5 (a lane is the same ring ABI attached N times).
