+	if ! "$CXX" -std=c++17 -DDSERVER_RING_TRANSPORT -DRED_BREAK_PERCALL_LEAK -I"$GEN_RPC" -I"$INC" -I"$ININC" -o "$TMP/hm_red3" "$HMSRC" "$HMIMPL" 2>/dev/null; then
