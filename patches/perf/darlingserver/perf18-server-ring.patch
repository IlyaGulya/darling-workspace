+		if ! "$CC" -std=c11 -DFASTPATH_NO_HATCH -I"$GEN_RPC" -I"$INC" -o "$TMP/fp_red" "$FPSRC" 2>/dev/null; then
+			echo "fast-path RED arm failed to COMPILE -- gate broken"; exit 2
