index 2b91e85c72dba7e9d4b427045205055782a93190..cafb7f420d5bf7aae477998c40b92b7f4557903a 100644
--- a/tools/closure-cache/closure-cache-builder.c
+++ b/tools/closure-cache/closure-cache-builder.c
@@ -225,6 +225,28 @@ int main(int argc,char**argv){
             /* copy the segment file bytes into its region blob */
             memcpy(out + rfile + roff, im->map + im->sliceOff + sg->fileoff, sg->filesize);
         }
+        /* --- REWRITE the LC_SEGMENT_64 vmaddrs INSIDE the packed mach-o header ---
+         * dyld reads seg vmaddrs from the header (not our dcc_seg table): getSlide()=loadedAddr-hdrTEXT.vmaddr
+         * and segRuntime=hdrSeg.vmaddr+getSlide. The header lives in the TEXT segment bytes we just copied
+         * into the RX region at im->rx_off. Patch each LC_SEGMENT_64.vmaddr to the rewritten region-relative
+         * value so a single uniform slide reproduces every segment address. Code/text bytes are untouched;
+         * only the load-command vmaddr fields change (header is in TEXT but these are metadata, not code). */
+        {
+            struct mh64* mh=(struct mh64*)(out + rx_file + im->rx_off);
+            if(mh->magic!=MH_MAGIC_64){fprintf(stderr,"ABORT: packed header not MH_MAGIC_64 for %s\n",im->path);return 1;}
+            struct lc* hc=(struct lc*)((char*)mh+sizeof *mh);
+            for(uint32_t ci=0;ci<mh->ncmds;ci++){
+                if(hc->cmd==LC_SEGMENT_64){
+                    struct seg64* hsg=(struct seg64*)hc;
+                    int matched=0;
+                    for(int s=0;s<im->nsegs;s++){
+                        if(!strncmp(di->segs[s].name,hsg->segname,16)){ hsg->vmaddr=di->segs[s].vmaddr; matched=1; break; }
+                    }
+                    if(!matched){fprintf(stderr,"ABORT: header seg %.16s has no table entry in %s\n",hsg->segname,im->path);return 1;}
+                }
+                hc=(struct lc*)((char*)hc+hc->cmdsize);
+            }
+        }
         /* --- single-slide invariant (build-time assert) ---
          * dyld reads the REWRITTEN LC_SEGMENT vmaddrs (ds->vmaddr) and computes
          *   getSlide = loadedAddr(TEXT) - rewrittenTEXT.vmaddr ; segAddr = seg.vmaddr + slide.

From fdae3db9011543c73ee3f4e2a2fdf614f74ddc93 Mon Sep 17 00:00:00 2001
From: Ilya Gulya <ilya@gulya.me>
Date: Wed, 1 Jul 2026 09:03:02 +0000
Subject: [PATCH] perf#24c2b: DCC2 fixup-table builder + standalone applier
 validator (no live dyld)

Proves the builder can emit a cache-native precomputed fixup table and a
standalone applier applies it to the packed regions matching normal-dyld
expectations, WITHOUT invoking dyld. No dyld code, nothing deployed.

DCC2 format (magic DCC2, v2) = DCC1 region-packed cache + a fixup table with
cache-relative locations/targets (region id + offset) so one uniform slide
relocates everything: REBASE (*loc += slide), BIND_INTERNAL
(region[tgt].vm_base + tgt_off + slide + addend), BIND_EXTERN (runtime dyld
resolver + addend, for flat/unresolvable symbols).

Builder (dcc2-builder.c): walks opcode rebase/bind (closure is 100%
LC_DYLD_INFO_ONLY, zero chained), resolves binds to cache offsets at build via
export trie. Key fix: self (ord=0) binds follow LC_REEXPORT_DYLIB deps, since
libSystem.B re-exports its 33 sub-dylibs' whole export sets implicitly (so
_malloc/_free/... self-binds resolve into the subs). Counts match the
perf#24c2a audit exactly: full closure 23407 rebases + 1395 binds (1236
two-level + 154 self + 5 flat-resolved + 0 extern, 0 unresolved); 2-dylib smoke
{libsystem_blocks,libunwind} 50 rebases + 5 binds (1 in-set + 4 genuinely
external flat: dyld_stub_binder/__NSConcreteMallocBlock/___stack_chk_guard/
___stderrp).

Applier/validator (dcc2-applier.c): maps 3 regions on one slide (RW MAP_PRIVATE
COW), applies the whole table to the private copy. All 7 acceptance checks pass
on both caches (parse; counts; apply 24802 fixups; every location in RW; every
internal target in a region + every extern in the strtab; table fully covers
DCC images so the normal fixup engine is not needed; deterministic md5-stable +
atomic) plus a COW proof and byte-identity vs source (120 segs; only header
LC_SEGMENT_64.vmaddr changed). All 4 RED arms are detected: location from old
image offset, target using original inter-segment delta, bind target outside
closure without resolver, stale header vmaddr.

New invariant (carried into c2c/c2d): DCC images must never enter the normal
Mach-O fixup path (applyFixupsToImage -> WrappedMachO::forEachFixup); if one
does it is a hard fail (that path is known-wrong for region-packed layout).

prod dserver 835946f9 + mldr f0cd2a82 + dyld 10af572e untouched. LOCAL only.
