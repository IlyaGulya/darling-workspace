From dc8c4a8082487d9f4d9d6fe36dcd8287c40276bb Mon Sep 17 00:00:00 2001
From: Ilya Gulya <ilya@gulya.me>
Date: Thu, 2 Jul 2026 01:43:14 +0000
Subject: [PATCH] perf#24c2d-crashcap: guest SIGSEGV capture patch for
 sigexc_handler
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

Temporary diagnostic (apply at xnu@a0328833 to libsystem_kernel sigexc.c) that,
on a fatal fault, dumps guest RIP / fault addr / all GP registers / (stack) /
instruction bytes via __simple_kprintf before forwarding. Used to capture the
full-closure DCC2 crash:

  sig=11 RIP=0x747865745F5F faultaddr=cr2=RIP err=0x14 trapno=0xE

err=0x14 (user + instruction-fetch) + trapno=0xE (#PF) + RIP==faultaddr proves
the guest CALLED a function pointer whose value is the ASCII "__text" — a
func-ptr slot holding section_64.sectname bytes, in libSystem.B's first
initializer (rdi arg0 = libc++ __TEXT+0x1028). Not a static DCC2 fixup
(wildchk2 clean); a runtime-loaded/computed bad func ptr. See task #96 +
memory dar-perf24c2d-full-closure-ab.
---
 tools/closure-cache/crashcap-sigexc.patch | 47 +++++++++++++++++++++++
 1 file changed, 47 insertions(+)
 create mode 100644 tools/closure-cache/crashcap-sigexc.patch

diff --git a/tools/closure-cache/crashcap-sigexc.patch b/tools/closure-cache/crashcap-sigexc.patch
new file mode 100644
index 0000000000000000000000000000000000000000..dd24f6028ad366161d368f57698af2e0445fecd8
--- /dev/null
+++ b/tools/closure-cache/crashcap-sigexc.patch
@@ -0,0 +1,47 @@
+diff --git a/darling/src/libsystem_kernel/emulation/src/linux_premigration/signal/sigexc.c b/darling/src/libsystem_kernel/emulation/src/linux_premigration/signal/sigexc.c
+index 67de2d0..bc79379 100644
+--- a/darling/src/libsystem_kernel/emulation/src/linux_premigration/signal/sigexc.c
++++ b/darling/src/libsystem_kernel/emulation/src/linux_premigration/signal/sigexc.c
+@@ -314,6 +314,42 @@ void sigexc_handler(int linux_signum, struct linux_siginfo* info, struct linux_u
+ 	kern_printf("sigexc: have RIP 0x%llx\n", ctxt->uc_mcontext.gregs.rip);
+ #endif
+ 
++#if defined(__x86_64__)
++	// perf#24c2d-crashcap TEMP DIAGNOSTIC: on a fatal fault (SEGV/BUS/ILL/FPE/TRAP), dump the guest
++	// faulting PC, fault address, all GP registers, instruction bytes around RIP, and the stack top —
++	// BEFORE forwarding to dserver. Uses __simple_kprintf (unconditional -> dserver log). Read-only.
++	if ( linux_signum == 11 /*SEGV*/ || linux_signum == 7 /*BUS*/ || linux_signum == 4 /*ILL*/
++	  || linux_signum == 8 /*FPE*/  || linux_signum == 5 /*TRAP*/ ) {
++		const struct linux_gregset* g = &ctxt->uc_mcontext.gregs;
++		__simple_kprintf("CRASHCAP: sig=%d RIP=0x%llx faultaddr=0x%llx cr2=0x%llx err=0x%llx trapno=0x%llx\n",
++			linux_signum, (unsigned long long)g->rip, (unsigned long long)(info ? (unsigned long)info->si_addr : 0),
++			(unsigned long long)g->cr2, (unsigned long long)g->err, (unsigned long long)g->trapno);
++		__simple_kprintf("CRASHCAP: rax=0x%llx rbx=0x%llx rcx=0x%llx rdx=0x%llx rsi=0x%llx rdi=0x%llx\n",
++			(unsigned long long)g->rax, (unsigned long long)g->rbx, (unsigned long long)g->rcx,
++			(unsigned long long)g->rdx, (unsigned long long)g->rsi, (unsigned long long)g->rdi);
++		__simple_kprintf("CRASHCAP: rbp=0x%llx rsp=0x%llx r8=0x%llx r9=0x%llx r10=0x%llx r11=0x%llx\n",
++			(unsigned long long)g->rbp, (unsigned long long)g->rsp, (unsigned long long)g->r8,
++			(unsigned long long)g->r9, (unsigned long long)g->r10, (unsigned long long)g->r11);
++		__simple_kprintf("CRASHCAP: r12=0x%llx r13=0x%llx r14=0x%llx r15=0x%llx\n",
++			(unsigned long long)g->r12, (unsigned long long)g->r13, (unsigned long long)g->r14, (unsigned long long)g->r15);
++		// stack top FIRST (RSP valid in a fault; *RSP is the RETURN ADDRESS => the caller that jumped here).
++		const unsigned long long* sp = (const unsigned long long*)(unsigned long)g->rsp;
++		for (int si = 0; si < 24; si += 4) {
++			__simple_kprintf("CRASHCAP: stack[+0x%x] 0x%llx 0x%llx 0x%llx 0x%llx\n",
++				si*8, sp[si], sp[si+1], sp[si+2], sp[si+3]);
++		}
++		// insn bytes LAST, only if RIP looks like mapped code (an instruction-fetch fault means RIP is
++		// unmapped — reading it faults again and would lose the stack dump above).
++		if ( (unsigned long long)g->rip > 0x1000000ULL && ((unsigned long long)g->rip >> 47) == 0 ) {
++			const unsigned char* ip = (const unsigned char*)(unsigned long)g->rip;
++			__simple_kprintf("CRASHCAP: insn@RIP %02x %02x %02x %02x %02x %02x %02x %02x\n",
++				ip[0],ip[1],ip[2],ip[3],ip[4],ip[5],ip[6],ip[7]);
++		} else {
++			__simple_kprintf("CRASHCAP: RIP not mapped-code => jumped to a bad function pointer\n");
++		}
++	}
++#endif
++
+ 	thread_t thread = mach_thread_self();
+ 
+ #if defined(__x86_64__)

From 4a85367bc36eb1698db546818fb805c4c1a6894a Mon Sep 17 00:00:00 2001
From: Ilya Gulya <ilya@gulya.me>
Date: Thu, 2 Jul 2026 02:04:32 +0000
Subject: [PATCH] perf#24c2d-callsite: root cause of "__text" SIGSEGV = DCC2
 region-packing breaks RIP-relative TEXT->DATA refs
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

The full-closure DCC2 crash (instruction-fetch fault to RIP=0x747865745f5f = the
ASCII "__text") is NOT a bad pointer-slot fixup. It is a fundamental model flaw:

x86-64 __stubs are `jmp *disp32(%rip)` with the disp32 baked at link time for the
ORIGINAL per-image TEXT->DATA spacing. DCC2 rewrites segment/section addrs to
region-relative absolutes, moving __TEXT (RX region) and __DATA (RW region, holding
__la_symbol_ptr/__got) far apart, but the fixup table only rewrites pointer SLOTS,
never instruction immediates. Every stub therefore jumps through the wrong address
(the next packed image's Mach-O header); when a stub target lands on <image>+0x68
(first section_64.sectname = "__text") the jump fetches 0x747865745f5f => the crash.

This breaks every RIP-relative reference from __TEXT code into __DATA. The
perf#24c-gate single-slide model is insufficient for x86-64. Fix (next stage):
preserve each image's original TEXT<->DATA delta inside the cache (Apple shared-cache
approach) — option A in the doc.

Adds offline analysis tools (dcc2-extractrx, dcc2-dumpq, dcc2-fxdump, dcc2-stubscan)
and tests/PERF24C2D-CALLSITE-RIPREL-ROOT-CAUSE.md with full reproduction. No production
code changed; prod baselines untouched.
