+  2. LC_DYLD_INFO_ONLY {rebase,bind,weak_bind,lazy_bind,export}_off  += (link_new - link_old)
+  3. LC_SYMTAB {symoff,stroff}  += (link_new - link_old)
+  4. LC_DYSYMTAB {indirectsymoff,...}  += (link_new - link_old)
