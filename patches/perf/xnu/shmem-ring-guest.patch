+int __dserver_ring_mach_port_deallocate(uint32_t target, uint32_t name, int* out_code) {
+	// dserver_call_mach_port_deallocate_t { uint32_t target; uint32_t name; }
+	struct {
+		uint32_t target;
+		uint32_t name;
+	} body = { target, name };
