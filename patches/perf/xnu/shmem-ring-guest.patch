From 1f4aaffd98b6f0ec476f51c98d02d2d2c1f7f10c Mon Sep 17 00:00:00 2001
From: Ilya Gulya <ilya@gulya.me>
Date: Mon, 29 Jun 2026 08:24:10 +0000
Subject: [PATCH] perf#18 P6 (dar-aw2): gated rdtsc phase-prof for the hot ring
 RPC (guest side)

Diagnostic only: behind DARLING_RING_PHASE_PROF (default OFF, byte-identical off, on top
of DARLING_RING_TRANSPORT). rdtsc accountant in gr_port_trap accumulates the guest-visible
phases -- submit (publish + conditional doorbell), roundtrip (server work + cross-proc
wakeup), observe (validate + copy port out) -- and dumps mean cycles/phase to stderr every
GR_PHASE_DUMP_AT samples (reuses the perf#9 in-guest rdtsc pattern; clock_gettime wedges the
guest this early so rdtsc only).

MEASURED (hot mach_reply_port, TSC 1.9962GHz): submit ~510ns, roundtrip ~4196ns (of which
server Mach work ~3236ns, pure wakeup ~960ns), observe ~17ns => guest total ~4.7us. The
transport (submit+observe ~527ns) is negligible; the floor is server-side. See the
darlingserver-side commit for the full 6-phase table + the opcode-fast-path conclusion.
---
 .../resources/dserver-ring.c                  | 47 +++++++++++++++++++
 1 file changed, 47 insertions(+)

diff --git a/darling/src/libsystem_kernel/emulation/src/linux_premigration/resources/dserver-ring.c b/darling/src/libsystem_kernel/emulation/src/linux_premigration/resources/dserver-ring.c
index e25b2169179b8575722d3bf3a9adb90033125bba..9e661b3fc94c93ec180569e74215fd2e2b2938c9 100644
--- a/darling/src/libsystem_kernel/emulation/src/linux_premigration/resources/dserver-ring.c
+++ b/darling/src/libsystem_kernel/emulation/src/linux_premigration/resources/dserver-ring.c
@@ -67,6 +67,35 @@ static dserver_ring_shm_t* gr_cb(void)  { return (dserver_ring_shm_t*)g_ring_map
 static dserver_ring_t* gr_c2s(void)     { return (dserver_ring_t*)((char*)g_ring_map + gr_cb()->c2s_ring_off); }
 static dserver_ring_t* gr_s2c(void)     { return (dserver_ring_t*)((char*)g_ring_map + gr_cb()->s2c_ring_off); }
 
+#ifdef DARLING_RING_PHASE_PROF
+// perf #18 P6 (dar-aw2): guest-side rdtsc phase accountant. Pure diagnostic (default OFF, whole
+// block compiles out). Accumulates TSC cycles for the guest-visible phases of the hot round-trip:
+//   submit    = publish request + conditional doorbell (gr_wake_server)
+//   roundtrip = time from after-submit until the reply is observed (server-side + wakeup latency)
+//   observe   = validate + copy the port out of the reply slot
+// and dumps mean cycles/phase to stderr once GR_PHASE_DUMP_AT samples accrue. Reuses the perf#9
+// in-guest accountant pattern (rdtsc, NOT clock_gettime which wedges the guest this early).
+#include <darling/emulation/common/simple.h>
+#define GR_PHASE_DUMP_AT 5000
+static unsigned long gr_ph_submit = 0, gr_ph_round = 0, gr_ph_observe = 0, gr_ph_total = 0;
+static unsigned long gr_ph_n = 0;
+static inline unsigned long gr_rdtsc(void) {
+#if defined(__x86_64__) || defined(__i386__)
+	unsigned hi, lo;
+	__asm__ __volatile__("rdtsc" : "=a"(lo), "=d"(hi));
+	return ((unsigned long)hi << 32) | lo;
+#else
+	return 0;
+#endif
+}
+static void gr_phase_maybe_dump(void) {
+	if (gr_ph_n < GR_PHASE_DUMP_AT) return;
+	__simple_fprintf(2, "[gr-phase] n=%lu mean cycles: submit=%lu roundtrip=%lu observe=%lu total=%lu\n",
+		gr_ph_n, gr_ph_submit / gr_ph_n, gr_ph_round / gr_ph_n, gr_ph_observe / gr_ph_n, gr_ph_total / gr_ph_n);
+	gr_ph_submit = gr_ph_round = gr_ph_observe = gr_ph_total = 0; gr_ph_n = 0;
+}
+#endif
+
 static inline void gr_relax(void) {
 #if defined(__x86_64__) || defined(__i386__)
 	__builtin_ia32_pause();
@@ -232,6 +261,9 @@ static int gr_port_trap(uint32_t callnum, uint32_t* out_port) {
 		return -1; // no ring for this thread -> UDS fallback
 	}
 
+#ifdef DARLING_RING_PHASE_PROF
+	unsigned long _t0 = gr_rdtsc();
+#endif
 	dserver_ring_t* c2s = gr_c2s();
 	dserver_ring_slot_t* req = dserver_ring_producer_begin(c2s, GR_SLOT_SIZE, GR_SLOT_COUNT);
 	if (!req) {
@@ -248,11 +280,17 @@ static int gr_port_trap(uint32_t callnum, uint32_t* out_port) {
 
 	gr_wake_server();
 
+#ifdef DARLING_RING_PHASE_PROF
+	unsigned long _t1 = gr_rdtsc(); // submit done
+#endif
 	dserver_ring_slot_t* rep = gr_wait_reply();
 	if (!rep) {
 		return -1; // gave up waiting -> UDS fallback (the reply may still land; P3 single
 		           // owner means the next attach re-syncs; acceptable for the first op)
 	}
+#ifdef DARLING_RING_PHASE_PROF
+	unsigned long _t2 = gr_rdtsc(); // reply observed (roundtrip done)
+#endif
 
 	// Validate the reply belongs to our request before trusting it.
 	int rc = -1;
@@ -268,6 +306,15 @@ static int gr_port_trap(uint32_t callnum, uint32_t* out_port) {
 		}
 	}
 	dserver_ring_consumer_advance(gr_s2c());
+#ifdef DARLING_RING_PHASE_PROF
+	unsigned long _t3 = gr_rdtsc(); // observe (validate + copy out) done
+	gr_ph_submit  += (_t1 - _t0);
+	gr_ph_round   += (_t2 - _t1);
+	gr_ph_observe += (_t3 - _t2);
+	gr_ph_total   += (_t3 - _t0);
+	++gr_ph_n;
+	gr_phase_maybe_dump();
+#endif
 	return rc;
 }
 

From bf14ce898766b91a470b4569c316078698500ae0 Mon Sep 17 00:00:00 2001
From: Ilya Gulya <ilya@gulya.me>
Date: Mon, 29 Jun 2026 11:51:29 +0000
Subject: [PATCH] perf#18 P5 (dar-1il): guest ring path for mach_port_mod_refs

Add the GUEST half of the mach_port_mod_refs ring migration (server half is in
the darlingserver repo on perf/shmem-ring-abi-validator).

- gr_body_trap(): generic guest fast path for a small-inline-body op with a
  HEADER-ONLY reply (the result is the reply hdr's kern_return_t code, no
  port/body). Unlike gr_port_trap (empty request, port reply), it publishes the
  request body inline in the slot and reads only the code from the reply. The
  result code and the "fall back to UDS" signal are SEPARATE (a kern_return_t
  can be any value, so it must never be conflated with gr_port_trap's -1
  sentinel): returns 0 + writes *out_code on a valid ring round-trip, -1 on any
  transport miss.
- __dserver_ring_mach_port_mod_refs(): packs the 4-arg body
  {target,name,right,delta} (byte-identical to dserver_call_mach_port_mod_refs_t,
  which the server rebuilds as {callhdr,body} and dispatches via callFromMessage
  exactly as for UDS) and calls gr_body_trap.
- _kernelrpc_mach_port_mod_refs_trap_impl(): try the ring first, UDS-fall-back on
  miss. Folded away (the helper is a static-inline returning -1) unless built
  with -DDARLING_RING_TRANSPORT, so the non-ring dylib is byte-identical.

Validated end-to-end with the server half: byte-identical kern_return_t across
all 14 mach_port_mod_refs edges ring-vs-UDS, ~4.9x faster (UDS p50 ~12.9us ->
ring p50 ~2.6us).
---
 .../resources/dserver-ring.h                  |  7 ++
 .../resources/dserver-ring.c                  | 91 +++++++++++++++++++
 .../src/xnu_syscall/mach/impl/mach_traps.c    | 12 ++-
 3 files changed, 109 insertions(+), 1 deletion(-)

diff --git a/darling/src/libsystem_kernel/emulation/include/linux_premigration/resources/dserver-ring.h b/darling/src/libsystem_kernel/emulation/include/linux_premigration/resources/dserver-ring.h
index 8486cb99338d67f7023df51c244abb26613248a6..b111f9b6806db6c8335e7c4974a50c91520db1bb 100644
--- a/darling/src/libsystem_kernel/emulation/include/linux_premigration/resources/dserver-ring.h
+++ b/darling/src/libsystem_kernel/emulation/include/linux_premigration/resources/dserver-ring.h
@@ -33,6 +33,12 @@ bool __dserver_ring_try_attach(void);
 int __dserver_ring_task_self_trap(uint32_t* out_port);
 int __dserver_ring_mach_reply_port(uint32_t* out_port);
 
+// perf #18 P5: small-inline-body op with a header-only reply. On a valid ring round-trip writes
+// *out_code (the kern_return_t -- use it verbatim, it may be an error like KERN_INVALID_NAME) and
+// returns 0; returns negative on any transport miss -> caller MUST fall back to the UDS wrapper.
