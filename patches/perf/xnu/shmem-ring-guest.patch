diff --git a/darling/src/libsystem_kernel/emulation/CMakeLists.txt b/darling/src/libsystem_kernel/emulation/CMakeLists.txt
index aeec3cd26c581e944aed75c31bf36ba86e05087a..a693177a7b7e719fbaf4997febda51650ab6c6bf 100644
--- a/darling/src/libsystem_kernel/emulation/CMakeLists.txt
+++ b/darling/src/libsystem_kernel/emulation/CMakeLists.txt
@@ -83,6 +83,7 @@ set(linux_premigration_sources
 	src/linux_premigration/misc/ioctl.c
 	src/linux_premigration/resources/dserver-rpc-defs.c
 	src/linux_premigration/resources/rpc-sleep-account.c
+	src/linux_premigration/resources/dserver-ring.c
 	src/linux_premigration/signal/sig_restorer.S
 	src/linux_premigration/signal/sigexc.c
 	src/linux_premigration/elfcalls_wrapper.c
@@ -389,6 +390,20 @@ if (DARLING_RPC_SLEEP_ACCOUNT)
 	target_compile_definitions(emulation_dyld PRIVATE DARLING_RPC_SLEEP_ACCOUNT)
 endif()
 
+# perf #18 (dar-dar6x4-perf-5dq.30): guest-side shared-memory ring transport. OFF by default
+# -> dserver-ring.c compiles to an empty TU and the call-site fast paths (the inline stubs in
+# dserver-ring.h) fold away, so the emulation builds byte-identical to baseline. When ON, the
+# guest builds a memfd ring, negotiates it via ring_attach, and routes eligible calls (P3:
+# task_self_trap) over the ring with a futex wake instead of the UDS round-trip. Compiled into
+# BOTH the dylib (emulation) and dyld (emulation_dyld) since the trap path lives in both
+# (see the perf#7-generalize / gate-hotpath-kprintf lessons about dual-target deploy). The
+# matching server side is darlingserver's -DDSERVER_RING_TRANSPORT; both default OFF.
+option(DARLING_RING_TRANSPORT "Enable guest-side shared-memory ring RPC transport (perf #18)" OFF)
+if (DARLING_RING_TRANSPORT)
+	target_compile_definitions(emulation PRIVATE DARLING_RING_TRANSPORT)
+	target_compile_definitions(emulation_dyld PRIVATE DARLING_RING_TRANSPORT)
+endif()
+
 # perf #7-generalize (dar-dar6x4-perf-5dq.14): guest-side adaptive recv-spin budget.
 # The dylib RPC receive hook (dserver-rpc-defs.h) does a bounded LINUX_MSG_DONTWAIT
 # spin before the blocking recvmsg, so a fast RPC reply is grabbed before the guest
diff --git a/darling/src/libsystem_kernel/emulation/include/linux_premigration/resources/dserver-ring.h b/darling/src/libsystem_kernel/emulation/include/linux_premigration/resources/dserver-ring.h
new file mode 100644
index 0000000000000000000000000000000000000000..7e9b9b38d4a80231e7bb38e80a1671cc0ca1515b
--- /dev/null
+++ b/darling/src/libsystem_kernel/emulation/include/linux_premigration/resources/dserver-ring.h
@@ -0,0 +1,44 @@
+// perf #18 (dar-dar6x4-perf-5dq.30) P3: GUEST-side shared-memory ring transport.
+//
+// The guest builds a memfd holding a dserver_ring_shm control block + two SPSC rings, hands
+// it to the server via the ring_attach RPC (which returns a wake eventfd), then for eligible
+// calls publishes a request onto the c2s ring + writes the wake eventfd and waits for the
+// reply on the s2c ring instead of paying a full UDS sendmsg/recvmsg round-trip.
+//
+// Entire interface is a no-op unless the dylib is built with -DDARLING_RING_TRANSPORT. When
+// off, __dserver_ring_enabled() is a compile-time 0 and every call-site fast-path folds away,
+// so the build is byte-identical to a non-ring dylib. See dserver-ring.c for the design.
+
+#ifndef _DARLING_DSERVER_RING_H_
+#define _DARLING_DSERVER_RING_H_
+
+#include <stdint.h>
+#include <stdbool.h>
+
+#ifdef DARLING_RING_TRANSPORT
+
+// One-shot lazy attach for the CURRENT thread/process: build the memfd, fill the control
+// block, call ring_attach, map the wake eventfd. Idempotent + cheap after the first call.
+// Returns true if a ring is available for this thread to use, false if it must use UDS.
+bool __dserver_ring_try_attach(void);
+
+// Fast path for task_self_trap over the ring. On success writes *out_port + returns 0 (the
+// same contract as dserver_rpc_task_self_trap). Returns a negative value if the ring is
+// unavailable / the op isn't ring-eligible / anything went wrong -> caller MUST fall back to
+// the UDS wrapper. Never blocks unboundedly: it bounded-spins then FUTEX_WAITs for the reply.
+int __dserver_ring_task_self_trap(uint32_t* out_port);
+
+// Reset ring state in the forked child (the parent's ring + wake fd are not valid post-fork;
+// the child re-attaches lazily). Called from the fork path alongside the socket refresh.
+void __dserver_ring_postfork_reset(void);
+
+#else // !DARLING_RING_TRANSPORT
+
+// Folded-away stubs so call sites compile to nothing extra when the feature is off.
+static inline bool __dserver_ring_try_attach(void) { return false; }
+static inline int __dserver_ring_task_self_trap(uint32_t* out_port) { (void)out_port; return -1; }
+static inline void __dserver_ring_postfork_reset(void) {}
+
+#endif // DARLING_RING_TRANSPORT
+
+#endif // _DARLING_DSERVER_RING_H_
diff --git a/darling/src/libsystem_kernel/emulation/src/linux_premigration/resources/dserver-ring.c b/darling/src/libsystem_kernel/emulation/src/linux_premigration/resources/dserver-ring.c
new file mode 100644
index 0000000000000000000000000000000000000000..07bd7d047fca71643f4cbe95db53cee46389c4c8
--- /dev/null
+++ b/darling/src/libsystem_kernel/emulation/src/linux_premigration/resources/dserver-ring.c
@@ -0,0 +1,239 @@
+// perf #18 (dar-dar6x4-perf-5dq.30) P3: GUEST-side shared-memory ring transport.
+//
+// Builds the guest's ring memfd, negotiates it via the ring_attach RPC, and provides a
+// fast path for eligible calls (P3: task_self_trap) that publishes a request onto the c2s
+// ring + wakes the server (via the wake eventfd the server handed back) and waits for the
+// reply on the s2c ring -- skipping the UDS sendmsg/recvmsg round-trip that the profile
+// showed is ~90% empty cross-process wakeup latency.
+//
+// LIBC-FREE: raw LINUX_SYSCALL only, exactly like the rest of the emulation layer. Entire
+// file compiles to nothing unless DARLING_RING_TRANSPORT is defined.
+//
+// P3 SCOPE (deliberately minimal, single-trust-boundary-exercise):
+//   * ONE ring per process, owned by the thread that first attaches it. Other threads see a
+//     foreign owner and fall back to UDS (full per-thread rings are P4). This sidesteps
+//     guest TLS (which is fragile this early in the emulation layer) while staying correct:
+//     a non-owner never touches the ring.
+//   * Only task_self_trap rides the ring. The server's C2S service loop allowlists the same.
+//   * Adaptive wait: bounded spin (reusing the DARLING_GUEST_RECVSPIN budget) then a
+//     cross-process FUTEX_WAIT on s2c_futex. Server wakes via FUTEX_WAKE (non-private).
+
+#ifdef DARLING_RING_TRANSPORT
+
+// Make the ring ABI (structs + SPSC helpers) visible; the server-only attach-check is gated
+// out (we never validate our own ring -- the SERVER is the trust boundary).
+#define DSERVER_RING_TRANSPORT 1
+#define DSERVER_RING_NO_ATTACH_CHECK 1
+
+#include <darling/emulation/common/base.h>
+#include <darling/emulation/common/simple.h>
+#include <darling/emulation/linux_premigration/linux-syscalls/linux.h>
+#include <darling/emulation/linux_premigration/resources/dserver-ring.h>
+
+#include <darlingserver/rpc.h>
+#include <darlingserver/rpc-supplement.h>
+
+#include <stdint.h>
+#include <stdbool.h>
+
+extern void* memcpy(void* dest, const void* src, __SIZE_TYPE__ n);
+
+// The generated ring_attach wrapper.
+extern int dserver_rpc_ring_attach(int ring_fd, uint64_t mapping_size, uint32_t* out_reject_reason, int* out_wake_fd);
+
+// --- ring geometry (must satisfy dserver_ring_shm_validate on the server) -----------------
+#define GR_SLOT_SIZE   128u   // >= sizeof(slot)+reply; in [64,4096]
+#define GR_SLOT_COUNT  8u     // power of two in [2,1024]
+
+#ifndef DARLING_GUEST_RECVSPIN
+#define DARLING_GUEST_RECVSPIN 512
+#endif
+
+// futex op constants (avoid pulling a libc header; cross-PROCESS so NO private flag).
+#define GR_FUTEX_WAIT 0
+#define GR_FUTEX_WAKE 1
+
+// --- process-wide ring state (owned by the first attaching thread) ------------------------
+static int      g_ring_state = 0;        // 0=untried, 1=attached, -1=failed (UDS forever)
+static void*    g_ring_map = 0;
+static uint64_t g_ring_size = 0;
+static int      g_wake_fd = -1;
+static int      g_owner_tid = 0;         // gettid of the thread that owns the ring
+static uint32_t g_seq = 1;               // monotonic request seq (single-owner -> no race)
+
+static dserver_ring_shm_t* gr_cb(void)  { return (dserver_ring_shm_t*)g_ring_map; }
+static dserver_ring_t* gr_c2s(void)     { return (dserver_ring_t*)((char*)g_ring_map + gr_cb()->c2s_ring_off); }
+static dserver_ring_t* gr_s2c(void)     { return (dserver_ring_t*)((char*)g_ring_map + gr_cb()->s2c_ring_off); }
+
+static inline void gr_relax(void) {
+#if defined(__x86_64__) || defined(__i386__)
+	__builtin_ia32_pause();
+#elif defined(__aarch64__)
+	__asm__ __volatile__("yield");
+#else
+	LINUX_SYSCALL0(__NR_sched_yield);
+#endif
+}
+
+void __dserver_ring_postfork_reset(void) {
+	// the parent's mapping + wake fd do not carry meaningful ownership into the child; drop
+	// everything and let the child re-attach lazily on its next eligible call.
+	if (g_ring_map && g_ring_size) {
+		LINUX_SYSCALL(__NR_munmap, g_ring_map, g_ring_size);
+	}
+	if (g_wake_fd >= 0) {
+		LINUX_SYSCALL1(__NR_close, g_wake_fd);
+	}
+	g_ring_state = 0;
+	g_ring_map = 0;
+	g_ring_size = 0;
+	g_wake_fd = -1;
+	g_owner_tid = 0;
+	g_seq = 1;
+}
+
+bool __dserver_ring_try_attach(void) {
+	if (g_ring_state == 1) {
+		return (int)LINUX_SYSCALL(__NR_gettid) == g_owner_tid;
+	}
+	if (g_ring_state == -1) {
+		return false;
+	}
+
+	// Lay out: [control block][c2s ring][s2c ring], each ring 64-aligned.
+	uint64_t hdr = sizeof(dserver_ring_shm_t);
+	uint64_t ring_span = sizeof(dserver_ring_t) + (uint64_t)GR_SLOT_COUNT * GR_SLOT_SIZE;
+	uint64_t c2s_off = (hdr + 63u) & ~63ull;
+	uint64_t s2c_off = (c2s_off + ring_span + 63u) & ~63ull;
+	uint64_t total   = (s2c_off + ring_span + 63u) & ~63ull;
+
+	// memfd_create("dring", MFD_CLOEXEC=0x1)
+	long memfd = LINUX_SYSCALL(__NR_memfd_create, "dring", 0x1u);
+	if (memfd < 0) { g_ring_state = -1; return false; }
+	if (LINUX_SYSCALL(__NR_ftruncate, memfd, total) < 0) {
+		LINUX_SYSCALL1(__NR_close, memfd);
+		g_ring_state = -1; return false;
+	}
+
+	// map RW shared
+#ifdef __NR_mmap2
+	void* map = (void*)LINUX_SYSCALL(__NR_mmap2, 0, total, 0x1 | 0x2 /*PROT_READ|WRITE*/, 0x1 /*MAP_SHARED*/, memfd, 0);
+#else
+	void* map = (void*)LINUX_SYSCALL(__NR_mmap, 0, total, 0x1 | 0x2, 0x1, memfd, 0);
+#endif
+	if ((unsigned long)map > (unsigned long)-4096) {
+		LINUX_SYSCALL1(__NR_close, memfd);
+		g_ring_state = -1; return false;
+	}
+
+	// A freshly ftruncate'd memfd is zero-filled by the kernel, so the rings/control block
+	// start zeroed (head==tail==0 == empty, futex words 0); we only fill the cb fields.
+	dserver_ring_shm_t* cb = (dserver_ring_shm_t*)map;
+	cb->magic = DSERVER_RING_MAGIC;
+	cb->abi_version = DSERVER_RING_ABI_VERSION;
+	cb->slot_size = (uint16_t)GR_SLOT_SIZE;
+	cb->slot_count = GR_SLOT_COUNT;
+	cb->arena_off = 0;
+	cb->arena_size = 0;
+	cb->c2s_ring_off = (uint32_t)c2s_off;
+	cb->s2c_ring_off = (uint32_t)s2c_off;
+	cb->total_size = (uint32_t)total;
+	cb->guest_tid = (int32_t)LINUX_SYSCALL(__NR_gettid); // server cross-checks vs SCM nsid
+
+	// negotiate over UDS: hand the memfd to the server. It validates + maps + returns the
+	// wake eventfd (or a non-zero reject reason).
+	uint32_t reject = 0;
+	int wake_fd = -1;
+	int rc = dserver_rpc_ring_attach((int)memfd, total, &reject, &wake_fd);
+
+	// we no longer need the memfd ourselves (our mapping holds a reference).
+	LINUX_SYSCALL1(__NR_close, memfd);
+
+	if (rc != 0 || reject != dserver_ring_ok || wake_fd < 0) {
+		LINUX_SYSCALL(__NR_munmap, map, total);
+		if (wake_fd >= 0) LINUX_SYSCALL1(__NR_close, wake_fd);
+		g_ring_state = -1;
+		return false;
+	}
+
+	g_ring_map = map;
+	g_ring_size = total;
+	g_wake_fd = wake_fd;
+	g_owner_tid = (int)LINUX_SYSCALL(__NR_gettid);
+	g_ring_state = 1;
+	return true;
+}
+
+// Wake the server: write the eventfd (the only thing its epoll loop can wait on).
+static void gr_wake_server(void) {
+	uint64_t one = 1;
+	LINUX_SYSCALL(__NR_write, g_wake_fd, &one, sizeof(one));
+}
+
+// Wait for a reply on s2c: bounded spin, then cross-process FUTEX_WAIT on s2c_futex.
+// Returns a pointer to the published reply slot (NULL on give-up so the caller UDS-falls-back).
+static dserver_ring_slot_t* gr_wait_reply(void) {
+	dserver_ring_t* s2c = gr_s2c();
+	for (int i = 0; i < (DARLING_GUEST_RECVSPIN); ++i) {
+		dserver_ring_slot_t* rep = dserver_ring_consumer_begin(s2c, GR_SLOT_SIZE, GR_SLOT_COUNT);
+		if (rep) return rep;
+		gr_relax();
+	}
+	// Slow path: sleep on the futex until the server bumps it. Re-check after each wake.
+	uint32_t* word = &gr_cb()->s2c_futex;
+	for (int guard = 0; guard < 100000; ++guard) {
+		uint32_t observed = __atomic_load_n(word, __ATOMIC_ACQUIRE);
+		dserver_ring_slot_t* rep = dserver_ring_consumer_begin(s2c, GR_SLOT_SIZE, GR_SLOT_COUNT);
+		if (rep) return rep;
+		// FUTEX_WAIT(word, observed): sleeps only if *word still == observed (no lost wake).
+		long r = LINUX_SYSCALL(__NR_futex, word, GR_FUTEX_WAIT, observed, 0, 0, 0);
+		(void)r; // EAGAIN (value changed) / EINTR -> just re-loop and re-check the ring
+	}
+	return 0;
+}
+
+int __dserver_ring_task_self_trap(uint32_t* out_port) {
+	if (!__dserver_ring_try_attach()) {
+		return -1; // no ring for this thread -> UDS fallback
+	}
+
+	dserver_ring_t* c2s = gr_c2s();
+	dserver_ring_slot_t* req = dserver_ring_producer_begin(c2s, GR_SLOT_SIZE, GR_SLOT_COUNT);
+	if (!req) {
+		return -1; // ring full -> UDS fallback
+	}
+	uint32_t seq = g_seq++;
+	req->callnum = (uint32_t)dserver_callnum_task_self_trap;
+	req->seq = seq;
+	req->length = 0;
+	req->arena_off = 0;
+	req->arena_len = 0;
+	req->flags = 0;
+	dserver_ring_producer_publish(c2s);
+
+	gr_wake_server();
+
+	dserver_ring_slot_t* rep = gr_wait_reply();
+	if (!rep) {
+		return -1; // gave up waiting -> UDS fallback (the reply may still land; P3 single
+		           // owner means the next attach re-syncs; acceptable for the first op)
+	}
+
+	// Validate the reply belongs to our request before trusting it.
+	int rc = -1;
+	if (rep->seq == seq && rep->callnum == (uint32_t)dserver_callnum_task_self_trap) {
+		uint32_t inlineCap = GR_SLOT_SIZE - (uint32_t)sizeof(dserver_ring_slot_t);
+		if (rep->length >= sizeof(dserver_ring_reply_hdr_t) + sizeof(uint32_t) && rep->length <= inlineCap) {
+			char* payload = (char*)rep + sizeof(dserver_ring_slot_t);
+			dserver_ring_reply_hdr_t* rh = (dserver_ring_reply_hdr_t*)payload;
+			uint32_t port;
+			memcpy(&port, payload + sizeof(dserver_ring_reply_hdr_t), sizeof(port));
+			if (out_port) *out_port = port;
+			rc = rh->code;
+		}
+	}
+	dserver_ring_consumer_advance(gr_s2c());
+	return rc;
+}
+
+#endif // DARLING_RING_TRANSPORT
diff --git a/darling/src/libsystem_kernel/emulation/src/xnu_syscall/bsd/impl/process/fork.c b/darling/src/libsystem_kernel/emulation/src/xnu_syscall/bsd/impl/process/fork.c
index 5ab5d291bc4f8a5f09aae216c1abc9d9ddec185e..a12eb5a223df3df3cf31490c89dfdf5e4a8cdbb7 100644
--- a/darling/src/libsystem_kernel/emulation/src/xnu_syscall/bsd/impl/process/fork.c
+++ b/darling/src/libsystem_kernel/emulation/src/xnu_syscall/bsd/impl/process/fork.c
@@ -13,6 +13,7 @@
 #include <darling/emulation/other/mach/lkm.h>
 #include <darling/emulation/xnu_syscall/bsd/impl/unistd/close.h>
 #include <darling/emulation/common/guarded/table.h>
+#include <darling/emulation/linux_premigration/resources/dserver-ring.h>
 
 #include <darlingserver/rpc.h>
 
@@ -43,6 +44,9 @@ long sys_fork(void)
 
 		// create a new dserver RPC socket
 		__dserver_per_thread_socket_refresh();
+		// perf #18 P3: the parent's ring mapping + wake fd are meaningless in the child; drop
+		// them so the child re-attaches lazily. No-op unless -DDARLING_RING_TRANSPORT.
+		__dserver_ring_postfork_reset();
 		int newReadFd = __dserver_process_lifetime_pipe_refresh();
 
 		// guard it
diff --git a/darling/src/libsystem_kernel/emulation/src/xnu_syscall/mach/impl/mach_traps.c b/darling/src/libsystem_kernel/emulation/src/xnu_syscall/mach/impl/mach_traps.c
index ba01503995e02e6545525c462c7b3f47629a9e6b..d60c2735aa6cee6079025f23297bbc35515ac38f 100644
--- a/darling/src/libsystem_kernel/emulation/src/xnu_syscall/mach/impl/mach_traps.c
+++ b/darling/src/libsystem_kernel/emulation/src/xnu_syscall/mach/impl/mach_traps.c
@@ -16,6 +16,7 @@
 #include <darlingserver/rpc.h>
 
 #include <darling/emulation/xnu_syscall/mach/impl/cached_self_ports.h>
+#include <darling/emulation/linux_premigration/resources/dserver-ring.h>
 
 #define UNIMPLEMENTED_TRAP() { char msg[] = "Called unimplemented Mach trap: "; write(2, msg, sizeof(msg)-1); write(2, __FUNCTION__, sizeof(__FUNCTION__)-1); write(2, "\n", 1); }
 
@@ -722,6 +723,11 @@ kern_return_t syscall_thread_switch_impl(
 static cached_port_name_t __task_self_trap_rpc(void)
 {
 	unsigned int port_name;
+	// perf #18 P3: try the shared-memory ring first; on any failure fall back to the UDS
+	// wrapper. Folded away (always returns -1) unless built with -DDARLING_RING_TRANSPORT.
+	if (__dserver_ring_task_self_trap(&port_name) == 0) {
+		return port_name;
+	}
 	if (dserver_rpc_task_self_trap(&port_name) != 0) {
 		port_name = MACH_PORT_NULL;
 	}

From f93f3d364ecca27bae3929bad4e9c0dfdeebd30a Mon Sep 17 00:00:00 2001
From: Ilya Gulya <ilya@gulya.me>
Date: Mon, 29 Jun 2026 06:43:22 +0000
Subject: [PATCH] perf#18 P3: ride mach_reply_port over the guest ring
 (uncached hot op)

mach_reply_port is the uncached, high-frequency op (every Mach RPC round-trip mints
a reply port) -- unlike the cached task_self_trap, it actually exercises the ring's
latency win. It has the same wire shape (no request body, single-uint32 port reply),
so the existing ring trap body is generalized into gr_port_trap(callnum, out_port)
and both task_self_trap and mach_reply_port become thin wrappers over it.

