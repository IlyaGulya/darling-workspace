 =?UTF-8?q?e=20DCC=5FFIX=5FBIND=5FEXTERN=5FLAZY=20(resolve-or-sentinel)?=
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

Companion to the builder's lazy-tolerant extern fix. A lazy bind whose symbol
is genuinely absent (Darling stub gap) must not abort the process: normal dyld
resolves lazy binds only on first call, so an unused missing symbol never
faults. New fixup kind DCC2_FIX_BIND_EXTERN_LAZY (3): applyAllFixupsOnce /
applyFixups try resolveExtern and, if not found, write a sentinel (0) instead
of hard-failing (as plain DCC2_FIX_BIND_EXTERN still does). Kept in sync with
tools/closure-cache/dcc2-format.h.
---
 dyld3/DCC2Reader.cpp | 18 ++++++++++++++++++
 dyld3/DCC2Reader.h   |  1 +
 2 files changed, 19 insertions(+)

diff --git a/dyld3/DCC2Reader.cpp b/dyld3/DCC2Reader.cpp
index b1c5854e60b712dbc8e4523cb59f7baf106069d1..69a93f2c7c4c689251c77878fce7688123e9dc46 100644
--- a/dyld3/DCC2Reader.cpp
+++ b/dyld3/DCC2Reader.cpp
@@ -194,6 +194,17 @@ bool DCC2Reader::applyAllFixupsOnce(LogFunc logFixups,
                 *loc = v + (uintptr_t)f->addend;
                 break;
             }
+            case DCC2_FIX_BIND_EXTERN_LAZY: {
+                // A lazy bind whose symbol may be genuinely absent (Darling stub gap). Try to resolve; if
+                // not found, write a sentinel (0) instead of hard-failing — preserving lazy "resolve/trap
+                // on first call" semantics for a symbol that is not called on the paths we exercise.
+                const char* sym = _externStr + f->extern_sym;
+                bool found = false;
+                uintptr_t v = resolveExtern ? resolveExtern(sym, found) : 0;
+                *loc = found ? (v + (uintptr_t)f->addend) : (uintptr_t)0;
+                if ( !found && _log ) _log("dyld[DCC2]: lazy extern '%s' unresolved => sentinel 0 (never-called ok)\n", sym);
+                break;
+            }
             default:
                 if(_log)_log("dyld[DCC2]: unknown fixup kind %d (hard fail)\n", f->kind); return false;
         }
@@ -247,6 +258,13 @@ bool DCC2Reader::applyFixups(uint32_t imageIndex, LogFunc logFixups,
                 *loc = v + (uintptr_t)f->addend;
                 break;
             }
+            case DCC2_FIX_BIND_EXTERN_LAZY: {
+                const char* sym = _externStr + f->extern_sym;
+                bool found = false;
+                uintptr_t v = resolveExtern ? resolveExtern(sym, found) : 0;
+                *loc = found ? (v + (uintptr_t)f->addend) : (uintptr_t)0;
+                break;
+            }
             default:
                 if(_log)_log("dyld[DCC2]: unknown fixup kind %d\n", f->kind); return false;
         }
