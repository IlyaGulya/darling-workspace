From 5aa9aa5a7bbc83914b5398cedcf800e2b3560301 Mon Sep 17 00:00:00 2001
From: Ilya Gulya <ilya.gulya@indriver.com>
Date: Sat, 11 Jul 2026 05:52:36 +0000
Subject: [PATCH] mldr: write rootless guest trace to tmp

---
 src/startup/mldr/stack.c | 5 ++++-
 1 file changed, 4 insertions(+), 1 deletion(-)

diff --git a/src/startup/mldr/stack.c b/src/startup/mldr/stack.c
index 903c6101b9b34b6523425da84f0ec13f4786952c..a6ada873303ec5d52aed54628c247d118b2be09b 100644
--- a/src/startup/mldr/stack.c
+++ b/src/startup/mldr/stack.c
@@ -43,7 +43,10 @@
 
 #define EXECUTABLE_PATH "executable_path="
 #define ROOTLESS_INIT_ENV "DARLING_ROOTLESS=1"
-#define ROOTLESS_TRACE_ENV "DARLING_BOOT_TRACE=/private/var/log/.west-rootless-boot.log"
+/* This environment is consumed after the handoff, inside the Darwin guest.
+ * Keep the trace in guest tmp: it is available and writable before launchd
+ * has initialized its usual logging directories. */
+#define ROOTLESS_TRACE_ENV "DARLING_BOOT_TRACE=/private/var/tmp/.west-rootless-boot.log"
 
 #define __put_user(value, pointer) ({ \
 		__typeof__(value) _tmpval = (value); \

From f4613a436bccaf351032c3f78f689c81d151214f Mon Sep 17 00:00:00 2001
From: Ilya Gulya <ilya.gulya@indriver.com>
Date: Sat, 11 Jul 2026 06:04:04 +0000
Subject: [PATCH] rootless: separate host and guest boot traces

---
 src/startup/darling.c   | 2 +-
 src/startup/mldr/mldr.c | 2 +-
 2 files changed, 2 insertions(+), 2 deletions(-)

diff --git a/src/startup/darling.c b/src/startup/darling.c
index 4e05e51417337058cab0ac61ceee43bf10a433d5..32c109b20d3b8061f47f2c635777dfeb531ffe51 100644
--- a/src/startup/darling.c
+++ b/src/startup/darling.c
@@ -60,7 +60,7 @@ static bool rootlessModeEnabled(void)
 
 static void rootlessBootTrace(const char* stage)
 {
-	const char* path = getenv("DARLING_BOOT_TRACE");
+	const char* path = getenv("DARLING_HOST_BOOT_TRACE");
 	if (!rootlessModeEnabled() || !path || !*path)
 		return;
 	int fd = open(path, O_WRONLY | O_CREAT | O_APPEND | O_CLOEXEC, 0600);
diff --git a/src/startup/mldr/mldr.c b/src/startup/mldr/mldr.c
index cfeb8197ffcf59ca2ea42f63e318acec2f3695dd..7aaefd6e346abbe3f8df55065e376162be918c77 100644
--- a/src/startup/mldr/mldr.c
+++ b/src/startup/mldr/mldr.c
@@ -112,7 +112,7 @@ void __mldr_postfork_child(void);
 
 static void rootless_boot_trace(const char* stage)
 {
-	const char* path = getenv("DARLING_BOOT_TRACE");
+	const char* path = getenv("DARLING_HOST_BOOT_TRACE");
 	if (!path || !*path)
 		return;
 	int fd = open(path, O_WRONLY | O_CREAT | O_APPEND | O_CLOEXEC, 0600);
