From c82877b302c8318dafed286e98ea1df9bc2df3c8 Mon Sep 17 00:00:00 2001
From: Ilya Gulyagin <ilyagulya@users.noreply.github.com>
Date: Sat, 11 Jul 2026 11:38:02 +0000
Subject: [PATCH] rootless: trace vchroot to launchd handoff

---
 src/launchd/src/launchd.c |  9 +++++----
 src/vchroot/vchroot.c     | 24 ++++++++++++++++++++++--
 2 files changed, 27 insertions(+), 6 deletions(-)

diff --git a/src/launchd/src/launchd.c b/src/launchd/src/launchd.c
index 89e87825c7a43159e90335ec4cf985d978ac5914..08476a9fb975d62fa7a50d81dd5a1a95311a72b3 100644
--- a/src/launchd/src/launchd.c
+++ b/src/launchd/src/launchd.c
@@ -131,10 +131,6 @@ rootless_bootstrap_environment(void)
 static void
 rootless_boot_trace(const char *stage)
 {
-	if (!rootless_mode_enabled()) {
-		return;
-	}
-
 	int fd = -1;
 	bool close_fd = false;
 	const char *fd_text = getenv("DARLING_BOOT_TRACE_FD");
@@ -146,6 +142,9 @@ rootless_boot_trace(const char *stage)
 		}
 	}
 	if (fd < 0) {
+		if (!rootless_mode_enabled()) {
+			return;
+		}
 		const char *path = getenv("DARLING_BOOT_TRACE");
 		if (path == NULL || *path == '\0') {
 			return;
@@ -178,6 +177,8 @@ main(int argc, char *const *argv)
 {
 	bool sflag = false;
 	int ch;
+	/* The inherited FD is available before rootless environment repair. */
+	rootless_boot_trace("entry");
 	rootless_bootstrap_environment();
 	rootless_boot_trace("start");
 
diff --git a/src/vchroot/vchroot.c b/src/vchroot/vchroot.c
index 3a2639eba0f5daf51d0d63e92ee02874088d0755..8ad1afa6070b0d1e6601802bc060271bfb6d8c3a 100644
--- a/src/vchroot/vchroot.c
+++ b/src/vchroot/vchroot.c
@@ -3,17 +3,36 @@
 #include <unistd.h>
 #include <fcntl.h>
 #include <errno.h>
+#include <limits.h>
 
 extern int lkm_call(int nr, ...);
 extern int __darling_vchroot(int dfd);
 
+static void rootless_boot_trace(const char* stage)
+{
+	const char* fd_text = getenv("DARLING_BOOT_TRACE_FD");
+	if (fd_text == NULL || *fd_text == '\0') {
+		return;
+	}
+
+	char* end = NULL;
+	long candidate = strtol(fd_text, &end, 10);
+	if (end == fd_text || *end != '\0' || candidate < 0 || candidate > INT_MAX) {
+		return;
+	}
+
+	dprintf((int)candidate, "vchroot pid=%d %s\n", getpid(), stage);
+}
+
 int main(int argc, const char** argv)
 {
-    if (argc < 3)
+	rootless_boot_trace("entry");
+	if (argc < 3)
 	{
 		fprintf(stderr, "vchroot <dir> <binary> [args...]\n");
 		return 1;
 	}
+	rootless_boot_trace("args-ready");
 
 	char buf[4096];
 	sprintf(buf, "%s%s", argv[1], argv[2]);
@@ -42,6 +61,7 @@ int main(int argc, const char** argv)
 		perror("vchroot");
 		return 3;
 	}
+	rootless_boot_trace("root-ready");
 
 	close(dfd);
 
@@ -49,9 +69,9 @@ int main(int argc, const char** argv)
 	unsetenv("DYLD_ROOT_PATH");
 
 	// printf("Will execv %s\n", argv[2]);
+	rootless_boot_trace("exec-target");
 	execv(argv[2], (char * const *) argv+2);
 	perror("execv");
 
 	return 4;
 }
-
