index 0000000000000000000000000000000000000000..52937c948d55efe063dce537c344afbcda392bb2
--- /dev/null
+++ b/src/startup/mldr/elfcalls/dthreads.c
@@ -0,0 +1,92 @@
+/*
+ * This file is part of Darling.
+ *
+ * Copyright (C) 2026 Darling contributors
