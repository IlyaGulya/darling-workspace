+set(DARLING_ROOTLESS_TOOLCHAIN_AVAILABLE TRUE)
+foreach(_toolchain_target IN LISTS DARLING_ROOTLESS_TOOLCHAIN_TARGETS)
+	if(NOT TARGET ${_toolchain_target})
