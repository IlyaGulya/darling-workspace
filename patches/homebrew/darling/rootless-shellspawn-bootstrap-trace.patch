From d67907c65edcf0c90e35eaec58119ec57f18238b Mon Sep 17 00:00:00 2001
From: Ilya Gulya <ilya.gulya@indriver.com>
Date: Sat, 11 Jul 2026 12:46:00 +0000
Subject: [PATCH] rootless: trace shellspawn bootstrap

---
 src/launchd/src/core.c      | 18 ++++++++++++++++++
 src/launchd/src/launchd.c   | 20 ++++++++++----------
 src/launchd/src/launchd.h   |  2 ++
 src/shellspawn/shellspawn.c | 18 ++++++++++++++++++
 4 files changed, 48 insertions(+), 10 deletions(-)

diff --git a/src/launchd/src/core.c b/src/launchd/src/core.c
index a68739ff0d5857fb3b8f62ec7e032d55110f1be9..16108aa468ef8700f28c8912517486e2f9673ef9 100644
--- a/src/launchd/src/core.c
+++ b/src/launchd/src/core.c
@@ -798,6 +798,22 @@ static void job_log_perf_statistics(job_t j, struct rusage_info_v1 *ri, int64_t
 #if HAVE_SYSTEMSTATS
 static void job_log_systemstats(pid_t pid, uint64_t uniqueid, uint64_t parent_uniqueid, pid_t req_pid, uint64_t req_uniqueid, const char *name, struct rusage_info_v1 *ri, int64_t exit_status);
 #endif
+
+static void
+rootless_shellspawn_trace(const char *stage, const char *target, int error)
+{
+	if (target == NULL || strcmp(target, "/usr/libexec/shellspawn") != 0) {
+		return;
+	}
+
+	char message[128];
+	if (error == 0) {
+		snprintf(message, sizeof(message), "shellspawn %s", stage);
+	} else {
+		snprintf(message, sizeof(message), "shellspawn %s errno=%d", stage, error);
+	}
+	launchd_rootless_boot_trace(message);
+}
 static void job_set_exception_port(job_t j, mach_port_t port);
 static kern_return_t job_mig_spawn_internal(job_t j, vm_offset_t indata, mach_msg_type_number_t indataCnt, mach_port_t asport, job_t *outj);
 static void job_open_shutdown_transaction(job_t ji);
@@ -4748,7 +4764,9 @@ job_start_child(job_t j)
 		file2exec = j->prog ? j->prog : argv[0];
 	}
 
+	rootless_shellspawn_trace("spawn-attempt", file2exec, 0);
 	errno = psf(NULL, file2exec, NULL, &spattr, (char *const *)argv, environ);
+	rootless_shellspawn_trace("spawn-returned", file2exec, errno);
 
 #if HAVE_SANDBOX && !TARGET_OS_EMBEDDED
 out_bad:
diff --git a/src/launchd/src/launchd.c b/src/launchd/src/launchd.c
index 08476a9fb975d62fa7a50d81dd5a1a95311a72b3..3f3c42d281e20d06ad06bdb45e8dd87a7a57b0fb 100644
--- a/src/launchd/src/launchd.c
+++ b/src/launchd/src/launchd.c
@@ -128,8 +128,8 @@ rootless_bootstrap_environment(void)
 	unsetenv("__mldr_rootless_pid1");
 }
 
-static void
-rootless_boot_trace(const char *stage)
+void
+launchd_rootless_boot_trace(const char *stage)
 {
 	int fd = -1;
 	bool close_fd = false;
@@ -178,9 +178,9 @@ main(int argc, char *const *argv)
 	bool sflag = false;
 	int ch;
 	/* The inherited FD is available before rootless environment repair. */
-	rootless_boot_trace("entry");
+	launchd_rootless_boot_trace("entry");
 	rootless_bootstrap_environment();
-	rootless_boot_trace("start");
+	launchd_rootless_boot_trace("start");
 
 	/* This needs to be cleaned up. Currently, we risk tripping assumes() macros
 	 * before we've properly set things like launchd's log database paths, the
@@ -192,7 +192,7 @@ main(int argc, char *const *argv)
 	testfd_or_openfd(STDIN_FILENO, _PATH_DEVNULL, O_RDONLY);
 	testfd_or_openfd(STDOUT_FILENO, _PATH_DEVNULL, O_WRONLY);
 	testfd_or_openfd(STDERR_FILENO, _PATH_DEVNULL, O_WRONLY);
-	rootless_boot_trace("stdio-ready");
+	launchd_rootless_boot_trace("stdio-ready");
 
 	if (launchd_use_gmalloc) {
 		if (!getenv("DYLD_INSERT_LIBRARIES")) {
@@ -228,10 +228,10 @@ bool darling_rootless = rootless_mode_enabled();
 		fprintf(stderr, "%s: This program is not meant to be run directly.\n", getprogname());
 		exit(EXIT_FAILURE);
 	}
-	rootless_boot_trace("identity-accepted");
+	launchd_rootless_boot_trace("identity-accepted");
 
 	launchd_runtime_init();
-	rootless_boot_trace("runtime-ready");
+	launchd_rootless_boot_trace("runtime-ready");
 
 	if (NULL == getenv("PATH")) {
 		setenv("PATH", _PATH_STDPATH, 1);
@@ -239,7 +239,7 @@ bool darling_rootless = rootless_mode_enabled();
 
 	if (pid1_magic) {
 		pid1_magic_init();
-		rootless_boot_trace("pid1-ready");
+		launchd_rootless_boot_trace("pid1-ready");
 
 		int cfd = -1;
 		if ((cfd = open(_PATH_CONSOLE, O_WRONLY | O_NOCTTY)) != -1) {
@@ -339,10 +339,10 @@ bool darling_rootless = rootless_mode_enabled();
 
 	monitor_networking_state();
 	jobmgr_init(sflag);
-	rootless_boot_trace("jobs-ready");
+	launchd_rootless_boot_trace("jobs-ready");
 
 	launchd_runtime_init2();
-	rootless_boot_trace("runtime-loop");
+	launchd_rootless_boot_trace("runtime-loop");
 	launchd_runtime();
 }
 
diff --git a/src/launchd/src/launchd.h b/src/launchd/src/launchd.h
index d16d6a859c7ec889b62bcd23397fe5c92c791940..c17d4d2981d7f86217b5c16a3dc735543c3c38e6 100644
--- a/src/launchd/src/launchd.h
+++ b/src/launchd/src/launchd.h
@@ -32,6 +32,8 @@ struct conncb;
 
 extern bool pid1_magic;
 extern bool launchd_shutting_down;
+
+void launchd_rootless_boot_trace(const char *stage);
 extern bool fake_launchd_shutting_down;
 extern bool network_up;
 extern FILE *launchd_console;
diff --git a/src/shellspawn/shellspawn.c b/src/shellspawn/shellspawn.c
index f5ba615bbc9c2a74c801ef5178fd2e4fd7b4a75f..5691d42b955418ea7b5da11e5ca80a3ce3f531a0 100644
--- a/src/shellspawn/shellspawn.c
+++ b/src/shellspawn/shellspawn.c
@@ -27,6 +27,7 @@ along with Darling.  If not, see <http://www.gnu.org/licenses/>.
 #include <string.h>
 #include <stdio.h>
 #include <errno.h>
+#include <limits.h>
 #include <sys/poll.h>
 #include <sys/types.h>
 #include <sys/wait.h>
@@ -48,14 +49,31 @@ void setupSigchild(void);
 void restoreSigchild(void);
 void reapAll(void);
 
+static void rootlessBootTrace(const char* stage)
+{
+	const char* rootless = getenv("DARLING_ROOTLESS");
+	const char* fdText = getenv("DARLING_BOOT_TRACE_FD");
+	if (rootless == NULL || strcmp(rootless, "1") != 0 || fdText == NULL || *fdText == '\0')
+		return;
+
+	char* end = NULL;
+	long candidate = strtol(fdText, &end, 10);
+	if (end == fdText || *end != '\0' || candidate < 0 || candidate > INT_MAX)
+		return;
+
+	dprintf((int)candidate, "shellspawn pid=%d %s\n", getpid(), stage);
+}
+
 int main(int argc, const char** argv)
 {
 	// shellspawn (daemon) --fork()--> shellspawn (child) --fork()--> exec /bin/bash
 	// in order to read the exit status of the shell process,
 	// we have to allow it to become a zombie, therefore we need to
 	// restore the sigaction of SIGCHLD of the child shellspawn
+	rootlessBootTrace("entry");
 	setupSigchild();
 	setupSocket();
+	rootlessBootTrace("socket-ready");
 	listenForConnections();
 
 	if (g_serverSocket != -1)
