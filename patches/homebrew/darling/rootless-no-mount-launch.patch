From ec15d9380fd93422b507b932945f659db5437139 Mon Sep 17 00:00:00 2001
From: Ilya Gulya <ilya.gulya@indriver.com>
Date: Sat, 11 Jul 2026 02:45:17 +0000
Subject: [PATCH] startup: trace rootless bootstrap milestones

---
 src/startup/darling.c   | 15 +++++++++++++++
 src/startup/mldr/mldr.c | 13 +++++++++++++
 2 files changed, 28 insertions(+)

diff --git a/src/startup/darling.c b/src/startup/darling.c
index 3daf5061b51027307b1e386f670657839081577e..4e05e51417337058cab0ac61ceee43bf10a433d5 100644
--- a/src/startup/darling.c
+++ b/src/startup/darling.c
@@ -58,6 +58,18 @@ static bool rootlessModeEnabled(void)
 	return value != NULL && value[0] == '1' && value[1] == '\0';
 }
 
+static void rootlessBootTrace(const char* stage)
+{
+	const char* path = getenv("DARLING_BOOT_TRACE");
+	if (!rootlessModeEnabled() || !path || !*path)
+		return;
+	int fd = open(path, O_WRONLY | O_CREAT | O_APPEND | O_CLOEXEC, 0600);
+	if (fd >= 0) {
+		dprintf(fd, "launcher pid=%d %s\n", getpid(), stage);
+		close(fd);
+	}
+}
+
 int main(int argc, char ** argv)
 {
 	pid_t pidInit;
@@ -69,6 +81,7 @@ int main(int argc, char ** argv)
 	}
 
 	const bool rootless = rootlessModeEnabled();
+	rootlessBootTrace("start");
 
 	if (!rootless && geteuid() != 0)
 	{
@@ -194,8 +207,10 @@ int main(int argc, char ** argv)
 		unlink(socketPath);
 		
 		setupWorkdir();
+		rootlessBootTrace("spawn-darlingserver");
 		pidInit = spawnInitProcess();
 		putInitPid(pidInit);
+		rootlessBootTrace("waiting-for-shellspawn");
 		
 		// Wait until shellspawn starts
 		for (int i = 0; i < 15; i++)
