From 894fc1e5e1a72b95f3b0791f7514228bf8bb1eb3 Mon Sep 17 00:00:00 2001
From: Ilya Gulya <ilya.gulya@indriver.com>
Date: Sat, 11 Jul 2026 15:12:36 +0000
Subject: [PATCH] rootless: trace shellspawn client handoff

---
 src/startup/darling.c | 9 ++++++++-
 1 file changed, 8 insertions(+), 1 deletion(-)

diff --git a/src/startup/darling.c b/src/startup/darling.c
index 32c109b20d3b8061f47f2c635777dfeb531ffe51..6a75a36bcd381960b4121724555d1e1b867f7da4 100644
--- a/src/startup/darling.c
+++ b/src/startup/darling.c
@@ -201,6 +201,7 @@ int main(int argc, char ** argv)
 	if (pidInit == 0)
 	{
 		char socketPath[4096];
+		bool shellspawnReady = false;
 		
 		snprintf(socketPath, sizeof(socketPath), "%s"  SHELLSPAWN_SOCKPATH, prefix);
 		
@@ -215,10 +216,13 @@ int main(int argc, char ** argv)
 		// Wait until shellspawn starts
 		for (int i = 0; i < 15; i++)
 		{
-			if (access(socketPath, F_OK) == 0)
+			if (access(socketPath, F_OK) == 0) {
+				shellspawnReady = true;
 				break;
+			}
 			sleep(1);
 		}
+		rootlessBootTrace(shellspawnReady ? "shellspawn-ready" : "shellspawn-wait-expired");
 	}
 
 #if USE_LINUX_4_11_HACK
@@ -600,6 +604,7 @@ int connectToShellspawn(void)
 	snprintf(addr.sun_path, sizeof(addr.sun_path), "%s"  SHELLSPAWN_SOCKPATH, prefix);
 #endif
 
+	rootlessBootTrace("shellspawn-connect-enter");
 	sockfd = socket(AF_UNIX, SOCK_STREAM, 0);
 	if (sockfd == -1)
 	{
@@ -612,6 +617,7 @@ int connectToShellspawn(void)
 		fprintf(stderr, "Error connecting to shellspawn in the container (%s): %s\n", addr.sun_path, strerror(errno));
 		exit(1);
 	}
+	rootlessBootTrace("shellspawn-connect-ready");
 
 	return sockfd;
 }
@@ -704,6 +710,7 @@ void setupFDs(int fds[3], int* master)
 void spawnGo(int sockfd, int fds[3], int master)
 {
 	pushShellspawnCommandFDs(sockfd, SHELLSPAWN_GO, fds);
+	rootlessBootTrace("shellspawn-command-sent");
 	close(fds[0]);
 
 	shellLoop(sockfd, master);
