From d5e46fac68148664e9c68e55a57970ee7919916c Mon Sep 17 00:00:00 2001
From: Ilya Gulya <ilya@gulya.me>
Date: Sat, 27 Jun 2026 14:10:07 +0000
Subject: [PATCH] libsystem_kernel: abort_with_payload re-raises to self, not
 the process group

sys_abort_with_payload did sys_kill(0, SIGABRT). Linux kill(0, sig) targets the
caller's ENTIRE PROCESS GROUP, so a process aborting via abort_with_payload (e.g.
gnulib/gettext conftests through libsystem os/assumes.c) broadcast SIGABRT to its
parent and siblings sharing the pgid and killed them too -- observed taking down
the parent brew Ruby with a spurious SI_USER SIGABRT during `brew reinstall -s
gettext` (dar-cps). macOS abort_with_payload terminates only the calling process.

Re-raise to THIS thread via tgkill(getpid, gettid, SIGABRT) (raise() semantics),
matching the dar-gwn.6.4 fix for the sigexc default-effect kill(0) path.

Bead: dar-cps. RED->GREEN proven by tests/regression/abort_with_payload_no_group_broadcast.c
(unfixed: parent_got_SIGABRT=1; fixed: parent survives, child dies only).
---
 .../bsd/impl/misc/abort_with_payload.c        | 15 +++-
 .../abort_with_payload_no_group_broadcast.c   | 88 +++++++++++++++++++
 ...n-abort-with-payload-no-group-broadcast.sh | 36 ++++++++
 3 files changed, 138 insertions(+), 1 deletion(-)
 create mode 100644 darling/src/libsystem_kernel/tests/abort_with_payload_no_group_broadcast.c
 create mode 100755 darling/src/libsystem_kernel/tests/run-abort-with-payload-no-group-broadcast.sh

diff --git a/darling/src/libsystem_kernel/emulation/src/xnu_syscall/bsd/impl/misc/abort_with_payload.c b/darling/src/libsystem_kernel/emulation/src/xnu_syscall/bsd/impl/misc/abort_with_payload.c
index 4328a5fad82f83efa36e4ec16f985749c4046b51..983db4ff8f31cf7684fb707967c2554011ff0a1b 100644
--- a/darling/src/libsystem_kernel/emulation/src/xnu_syscall/bsd/impl/misc/abort_with_payload.c
+++ b/darling/src/libsystem_kernel/emulation/src/xnu_syscall/bsd/impl/misc/abort_with_payload.c
@@ -4,10 +4,23 @@
 
 #include <darling/emulation/xnu_syscall/bsd/impl/signal/kill.h>
 #include <darling/emulation/common/simple.h>
+#include <darling/emulation/conversion/signal/duct_signals.h>
+#include <darling/emulation/linux_premigration/linux-syscalls/linux.h>
 
 long sys_abort_with_payload(unsigned int reason_namespace, unsigned long long reason_code, void *payload, unsigned int payload_size, const char *reason_string, unsigned long long reason_flags)
 {
 	__simple_printf("abort_with_payload: reason: %s; code: %lu\n", reason_string, reason_code);
-	sys_kill(0, SIGABRT, 1);
+
+	// macOS abort_with_payload terminates ONLY the calling process. Do NOT use
+	// kill(0, SIGABRT): kill(0, sig) targets the caller's ENTIRE PROCESS GROUP,
+	// so a conftest aborting (e.g. gnulib via os/assumes.c -> abort_with_payload)
+	// would broadcast SIGABRT to its parent/sibling processes sharing the pgid and
+	// kill them too -- observed taking down the parent brew Ruby with a spurious
+	// SI_USER SIGABRT (dar-cps; same family as dar-gwn.1.5 / dar-gwn.6.4). Re-raise
+	// to THIS thread (raise() semantics) via tgkill(pid, tid, SIGABRT) so only this
+	// process is affected.
+	int self_pid = LINUX_SYSCALL(__NR_getpid);
+	int self_tid = LINUX_SYSCALL(__NR_gettid);
+	LINUX_SYSCALL(__NR_tgkill, self_pid, self_tid, signum_bsd_to_linux(SIGABRT));
 	return 0;
 }
diff --git a/darling/src/libsystem_kernel/tests/abort_with_payload_no_group_broadcast.c b/darling/src/libsystem_kernel/tests/abort_with_payload_no_group_broadcast.c
new file mode 100644
index 0000000000000000000000000000000000000000..395a955e3bcbccb3df164f0d130e26a9ff0dfbc8
--- /dev/null
+++ b/darling/src/libsystem_kernel/tests/abort_with_payload_no_group_broadcast.c
@@ -0,0 +1,88 @@
+// Regression test for dar-cps: abort_with_payload() must terminate ONLY the
+// calling process, never broadcast SIGABRT to its process group.
+//
+// macOS abort_with_payload (reached by gnulib/gettext conftests via libsystem's
+// os/assumes.c -> abort_with_payload) terminates only the aborting process. Darling
+// implemented the sys_abort_with_payload syscall as sys_kill(0, SIGABRT), and Linux
+// kill(0, sig) targets the caller's ENTIRE PROCESS GROUP. So a conftest that aborts
+// broadcast SIGABRT to its parent/sibling processes sharing the pgid and killed them
+// too -- observed taking down the parent brew Ruby with a spurious SI_USER SIGABRT
+// during `brew reinstall -s gettext` (dar-cps; same family as dar-gwn.1.5 /
+// dar-gwn.6.4, whose sigexc default-effect path was already fixed to tgkill-self).
+// Fix: sys_abort_with_payload re-raises to THIS thread via tgkill(pid, tid, SIGABRT).
+//
+// This is a GUEST test: it must run inside Darling so abort_with_payload() resolves
+// to Darling's libsystem sys_abort_with_payload. See run-abort-with-payload-no-group-broadcast.sh.
+//
+// Method (deterministic RED->GREEN):
+//   - parent and child share one process group; parent installs a SIGABRT HANDLER
+//     so a broadcast is observable (sets a flag) instead of lethal,
+//   - child restores SIG_DFL and calls abort_with_payload() exactly like a conftest,
+//   - RED (broken): the kill(0) broadcast reaches the parent -> parent_got_SIGABRT=1,
+//   - GREEN (fixed/macOS): abort stays local; parent survives, only the child dies.
+// Exit 0 == GREEN (parent survived). Exit 1 == RED (broadcast hit the parent).
+#include <stdio.h>
+#include <stdlib.h>
+#include <unistd.h>
+#include <signal.h>
+#include <string.h>
+#include <stdint.h>
+#include <sys/wait.h>
+#include <sys/types.h>
+
+// The real macOS libsystem entry; lives in libSystem. Declared directly so the
+// test does not depend on a private <sys/reason.h> being present.
+extern void abort_with_payload(uint32_t reason_namespace, uint64_t reason_code,
+                               void *payload, uint32_t payload_size,
+                               const char *reason_string, uint64_t reason_flags);
+
+#define OS_REASON_LIBSYSTEM 5
+
+static volatile sig_atomic_t parent_got_abrt = 0;
+static void on_abrt(int sig) { (void)sig; parent_got_abrt = 1; }
+
+int main(void) {
+	setpgid(0, 0);
+	pid_t pgrp = getpgrp();
+
+	struct sigaction sa;
+	memset(&sa, 0, sizeof(sa));
+	sa.sa_handler = on_abrt;
+	sigemptyset(&sa.sa_mask);
+	sa.sa_flags = 0;
+	if (sigaction(SIGABRT, &sa, NULL) != 0) { perror("sigaction"); return 2; }
+
+	fflush(stdout);
+	pid_t pid = fork();
+	if (pid < 0) { perror("fork"); return 2; }
+
+	if (pid == 0) {
+		signal(SIGABRT, SIG_DFL);  // child dies of its own SIGABRT, like a conftest
+		setpgid(0, pgrp);
+		abort_with_payload(OS_REASON_LIBSYSTEM, 0, (void*)0, 0u, "dar-cps regress", 0ULL);
+		// If the (fixed) implementation returned without terminating us, self-raise
+		// so the child still dies of SIGABRT for the child_died check. This is a
+		// thread-local raise() and does NOT broadcast.
+		raise(SIGABRT);
+		_exit(99);
+	}
+
+	int status = 0;
+	while (waitpid(pid, &status, 0) < 0) { if (parent_got_abrt) break; }
+	for (volatile int i = 0; i < 3000000 && !parent_got_abrt; i++) { }
+
+	int child_abrt = WIFSIGNALED(status) && WTERMSIG(status) == SIGABRT;
+	printf("child_died_of_SIGABRT=%d parent_got_SIGABRT=%d pgrp=%d\n",
+	       child_abrt, (int)parent_got_abrt, (int)pgrp);
+
+	if (parent_got_abrt) {
+		printf("RED: abort_with_payload BROADCAST SIGABRT to the process group (parent hit)\n");
+		return 1;
+	}
+	if (!child_abrt) {
+		printf("INCONCLUSIVE: child did not die of SIGABRT (status=0x%x)\n", status);
+		return 3;
+	}
+	printf("GREEN: abort_with_payload stayed local to the child; parent survived\n");
+	return 0;
+}
diff --git a/darling/src/libsystem_kernel/tests/run-abort-with-payload-no-group-broadcast.sh b/darling/src/libsystem_kernel/tests/run-abort-with-payload-no-group-broadcast.sh
new file mode 100755
index 0000000000000000000000000000000000000000..01483011d2c88e30221e85f1b657461b7fbe3a47
--- /dev/null
+++ b/darling/src/libsystem_kernel/tests/run-abort-with-payload-no-group-broadcast.sh
@@ -0,0 +1,36 @@
+#!/usr/bin/env bash
+# Regression test for dar-cps: abort_with_payload() must NOT broadcast SIGABRT to the
+# process group (it must terminate only the calling process, like macOS).
+#
+# This is a GUEST test: abort_with_payload() must resolve to Darling's libsystem
+# sys_abort_with_payload, so it runs inside Darling. It boots a prefix, has the guest
+# compile abort_with_payload_no_group_broadcast.c and run it, and asserts GREEN.
+#
+# Requires a Darling install + a writable prefix. Configure via env:
+#   DARLING   = path to the `darling` launcher (default: darling on PATH)
+#   DPREFIX   = the prefix to boot (must exist)
+# Exit 0 on PASS (GREEN: parent survived). Exit 1 on FAIL (RED: parent got SIGABRT).
+set -euo pipefail
+
+here="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
+LAUNCH="${DARLING:-darling}"
+: "${DPREFIX:?set DPREFIX to a bootable Darling prefix}"
+
+src="$here/abort_with_payload_no_group_broadcast.c"
+verdict="$DPREFIX/tmp/awp_nogroup.verdict"
+rm -f "$verdict" 2>/dev/null || true
+
+# Host writes to DPREFIX/tmp are NOT visible to the guest /tmp overlay; only guest
+# writes round-trip. So the guest writes its own copy of the source via heredoc.
+DPREFIX="$DPREFIX" "$LAUNCH" shell /bin/bash --login -c '
+  cat > /tmp/awp_nogroup.c <<"SRCEOF"
+'"$(cat "$src")"'
+SRCEOF
+  clang -O0 -o /tmp/awp_nogroup /tmp/awp_nogroup.c 2>&1
+  /tmp/awp_nogroup > /tmp/awp_nogroup.verdict 2>&1
+  echo "ORACLE_RC=$?" >> /tmp/awp_nogroup.verdict
+' 2>&1 | grep -vE "Xlib|libGL|MESA|X11" || true
+
+echo "=== verdict ==="
+cat "$verdict" 2>/dev/null || { echo "no verdict produced"; exit 2; }
+grep -q "^GREEN:" "$verdict" && grep -q "ORACLE_RC=0" "$verdict"
