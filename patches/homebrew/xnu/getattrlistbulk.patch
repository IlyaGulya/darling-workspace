From 69775cf24aa169d585921818695fff0ae19b3e64 Mon Sep 17 00:00:00 2001
From: Ilya Gulya <ilya@gulya.me>
Date: Thu, 11 Jun 2026 05:42:08 +0000
Subject: [PATCH] libsystem_kernel: implement getattrlistbulk (was ENOTSUP)

Iterate the directory via getdents64 and pack each entry in the canonical
getattrlistbulk layout: a u32 length, an optional ATTR_CMN_RETURNED_ATTRS
attribute_set_t, then the requested attributes in ascending-bit order. When
the caller requests ATTR_CMN_RETURNED_ATTRS (mandatory per the man page and
honoured by fts/NSDirectoryEnumerator), unsupported attributes are omitted
and reported via the returned set rather than failing with EINVAL; without
it we keep the strict fixed-layout contract and EINVAL on any unsupported
attribute.

Supported: ATTR_CMN_NAME, ATTR_CMN_OBJTYPE, ATTR_CMN_OBJTAG,
ATTR_CMN_FNDRINFO, ATTR_CMN_ERROR, ATTR_DIR_ENTRYCOUNT, ATTR_FILE_RSRCLENGTH.
Object type comes from the dirent d_type, falling back to fstatat for
DT_UNKNOWN. '.' and '..' are skipped. Entries that do not fit are left for
the next call by rewinding the directory to the last packed entry's d_off
cookie via lseek, so iteration spans multiple calls without loss or
duplication (verified: /usr/bin = 534 entries across 4 calls, exact match
with readdir).

Mirrors the ATTR_CMN_NAME/OBJTYPE work in getattrlist_generic.c; uses the
i386 __NR_fstatat64 / x86_64 __NR_newfstatat split.
---
 .../bsd/impl/xattr/getattrlistbulk.h          |   4 +-
 .../bsd/impl/xattr/getattrlistbulk.c          | 366 +++++++++++++++++-
 2 files changed, 367 insertions(+), 3 deletions(-)

diff --git a/darling/src/libsystem_kernel/emulation/include/xnu_syscall/bsd/impl/xattr/getattrlistbulk.h b/darling/src/libsystem_kernel/emulation/include/xnu_syscall/bsd/impl/xattr/getattrlistbulk.h
index b04390ef402de5126b7f5ad4f34b54218b73a7e9..49a44fc7f6b0fe4cb125be22c571ffa9f04db166 100644
--- a/darling/src/libsystem_kernel/emulation/include/xnu_syscall/bsd/impl/xattr/getattrlistbulk.h
+++ b/darling/src/libsystem_kernel/emulation/include/xnu_syscall/bsd/impl/xattr/getattrlistbulk.h
@@ -1,6 +1,8 @@
 #ifndef LINUX_GETATTRLISTBULK_H
 #define LINUX_GETATTRLISTBULK_H
 
-long sys_getattrlistbulk();
+#include <darling/emulation/conversion/xattr/getattrlist.h>
+
+long sys_getattrlistbulk(int fd, struct xnu_attrlist* alist, void* attributeBuffer, __SIZE_TYPE__ bufferSize, unsigned long options);
 
 #endif // LINUX_GETATTRLISTBULK_H
diff --git a/darling/src/libsystem_kernel/emulation/src/xnu_syscall/bsd/impl/xattr/getattrlistbulk.c b/darling/src/libsystem_kernel/emulation/src/xnu_syscall/bsd/impl/xattr/getattrlistbulk.c
index 6bd386bf72d8dde492a6a0b27675739de14f0e10..84c9a7c27a9ce3dd77101befd5b2467fd97cea32 100644
--- a/darling/src/libsystem_kernel/emulation/src/xnu_syscall/bsd/impl/xattr/getattrlistbulk.c
+++ b/darling/src/libsystem_kernel/emulation/src/xnu_syscall/bsd/impl/xattr/getattrlistbulk.c
@@ -1,11 +1,373 @@
 #include <darling/emulation/xnu_syscall/bsd/impl/xattr/getattrlistbulk.h>
 
+#include <stddef.h>
 #include <sys/errno.h>
 
 #include <darling/emulation/common/base.h>
 #include <darling/emulation/conversion/errno.h>
+#include <darling/emulation/conversion/xattr/getattrlist.h>
+#include <darling/emulation/conversion/dirent/getdirentries.h>
+#include <darling/emulation/conversion/stat/common.h>
+#include <darling/emulation/xnu_syscall/bsd/impl/unistd/close.h>
+#include <darling/emulation/xnu_syscall/bsd/impl/unistd/lseek.h>
+#include <darling/emulation/linux_premigration/linux-syscalls/linux.h>
 
-long sys_getattrlistbulk()
+#define ATTR_BIT_MAP_COUNT 5
+
+// Attribute bits we understand (sys/attr.h).
+#define ATTR_CMN_NAME            0x00000001
+#define ATTR_CMN_OBJTYPE         0x00000008
+#define ATTR_CMN_OBJTAG          0x00000010
+#define ATTR_CMN_FNDRINFO        0x00004000
+#define ATTR_CMN_ERROR           0x40000000
+#define ATTR_CMN_RETURNED_ATTRS  0x80000000
+
+#define ATTR_DIR_ENTRYCOUNT      0x00000002
+#define ATTR_FILE_RSRCLENGTH     0x00001000
+
+#define COMMON_SUPPORTED (ATTR_CMN_RETURNED_ATTRS | ATTR_CMN_NAME | ATTR_CMN_OBJTYPE | ATTR_CMN_OBJTAG | ATTR_CMN_FNDRINFO | ATTR_CMN_ERROR)
+#define DIR_SUPPORTED    (ATTR_DIR_ENTRYCOUNT)
+#define FILE_SUPPORTED   (ATTR_FILE_RSRCLENGTH)
+
+// fsobj_type_t values (sys/vnode.h).
+#define DTAPE_VNON  0
+#define DTAPE_VREG  1
+#define DTAPE_VDIR  2
+#define DTAPE_VBLK  3
+#define DTAPE_VCHR  4
+#define DTAPE_VLNK  5
+#define DTAPE_VSOCK 6
+#define DTAPE_VFIFO 7
+
+// Linux dirent d_type values.
+#define LINUX_DT_FIFO    1
+#define LINUX_DT_CHR     2
+#define LINUX_DT_DIR     4
+#define LINUX_DT_BLK     6
+#define LINUX_DT_REG     8
+#define LINUX_DT_LNK     10
+#define LINUX_DT_SOCK    12
+
+#define LINUX_S_IFMT   0170000
+#define LINUX_S_IFSOCK 0140000
+#define LINUX_S_IFLNK  0120000
+#define LINUX_S_IFREG  0100000
+#define LINUX_S_IFBLK  0060000
+#define LINUX_S_IFDIR  0040000
+#define LINUX_S_IFCHR  0020000
+#define LINUX_S_IFIFO  0010000
+
+#ifndef LINUX_AT_SYMLINK_NOFOLLOW
+#define LINUX_AT_SYMLINK_NOFOLLOW 0x100
+#endif
+
+#define LINUX_O_RDONLY    0
+#define LINUX_O_DIRECTORY 0200000
+
+#define LINUX_SEEK_SET 0
+
+#define VT_HFS 16
+
+// attrreference_t for variable-length attributes (e.g. ATTR_CMN_NAME).
+struct dtape_attrreference {
+	int attr_dataoffset;
+	unsigned int attr_length;
+};
+
+// attribute_set_t reported for ATTR_CMN_RETURNED_ATTRS.
+struct dtape_attribute_set {
+	unsigned int commonattr;
+	unsigned int volattr;
+	unsigned int dirattr;
+	unsigned int fileattr;
+	unsigned int forkattr;
+};
+
+extern void *memcpy(void *dest, const void *src, __SIZE_TYPE__ n);
+extern void *memset(void *s, int c, __SIZE_TYPE__ n);
+extern __SIZE_TYPE__ strlen(const char *s);
+
+static int is_dot_or_dotdot(const char* name)
+{
+	if (name[0] != '.')
+		return 0;
+	if (name[1] == '\0')
+		return 1;
+	if (name[1] == '.' && name[2] == '\0')
+		return 1;
+	return 0;
+}
+
+static unsigned int objtype_from_mode(unsigned int mode)
+{
+	switch (mode & LINUX_S_IFMT)
+	{
+		case LINUX_S_IFREG:  return DTAPE_VREG;
+		case LINUX_S_IFDIR:  return DTAPE_VDIR;
+		case LINUX_S_IFLNK:  return DTAPE_VLNK;
+		case LINUX_S_IFBLK:  return DTAPE_VBLK;
+		case LINUX_S_IFCHR:  return DTAPE_VCHR;
+		case LINUX_S_IFSOCK: return DTAPE_VSOCK;
+		case LINUX_S_IFIFO:  return DTAPE_VFIFO;
+		default:             return DTAPE_VNON;
+	}
+}
+
+static unsigned int objtype_from_dtype(unsigned char d_type)
+{
+	switch (d_type)
+	{
+		case LINUX_DT_REG:  return DTAPE_VREG;
+		case LINUX_DT_DIR:  return DTAPE_VDIR;
+		case LINUX_DT_LNK:  return DTAPE_VLNK;
+		case LINUX_DT_BLK:  return DTAPE_VBLK;
+		case LINUX_DT_CHR:  return DTAPE_VCHR;
+		case LINUX_DT_SOCK: return DTAPE_VSOCK;
+		case LINUX_DT_FIFO: return DTAPE_VFIFO;
+		default:            return DTAPE_VNON; // DT_UNKNOWN -> caller must stat
+	}
+}
+
+// Count the entries in a subdirectory (excluding "." and ".."), used for
+// ATTR_DIR_ENTRYCOUNT. Returns 0 on any failure (best effort).
+static unsigned int dir_entry_count(int dirfd, const char* name)
+{
+	int subfd = LINUX_SYSCALL(__NR_openat, dirfd, name, LINUX_O_RDONLY | LINUX_O_DIRECTORY, 0);
+	if (subfd < 0)
+		return 0;
+
+	unsigned int n = 0;
+	char buf[2048];
+	while (1)
+	{
+		long r = LINUX_SYSCALL(__NR_getdents64, subfd, buf, sizeof(buf));
+		if (r <= 0)
+			break;
+		for (char* it = buf; it < buf + r; it += ((struct linux_dirent64*) it)->d_reclen)
+		{
+			if (!is_dot_or_dotdot(((struct linux_dirent64*) it)->d_name))
+				++n;
+		}
+	}
+
+	close_internal(subfd);
+	return n;
+}
+
+long sys_getattrlistbulk(int fd, struct xnu_attrlist* alist, void* attributeBuffer, __SIZE_TYPE__ bufferSize, unsigned long options)
 {
-	return -ENOTSUP;
+	if (!alist || !attributeBuffer)
+		return -EFAULT;
+
+	if (alist->bitmapcount < ATTR_BIT_MAP_COUNT)
+		return -EINVAL;
+
+	const int wantReturned = (alist->commonattr & ATTR_CMN_RETURNED_ATTRS) != 0;
+
+	// Without ATTR_CMN_RETURNED_ATTRS the caller assumes a fixed layout of exactly
+	// the attributes it asked for, so we may not silently drop unsupported ones.
+	// With it, we report what we actually packed and unsupported attributes are
+	// simply omitted (the documented, most-compatible behaviour).
+	if (!wantReturned)
+	{
+		if ((alist->commonattr & COMMON_SUPPORTED) != alist->commonattr)
+			return -EINVAL;
+		if (alist->volattr != 0)
+			return -EINVAL;
+		if ((alist->dirattr & DIR_SUPPORTED) != alist->dirattr)
+			return -EINVAL;
+		if ((alist->fileattr & FILE_SUPPORTED) != alist->fileattr)
+			return -EINVAL;
+		if (alist->forkattr != 0)
+			return -EINVAL;
+	}
+
+	// We need the object type if it was requested directly, or to decide whether
+	// the per-entry directory/file attributes apply.
+	const int needType = (alist->commonattr & ATTR_CMN_OBJTYPE)
+		|| (alist->dirattr & DIR_SUPPORTED)
+		|| (alist->fileattr & FILE_SUPPORTED);
+
+	char* outp = (char*) attributeBuffer;
+	__SIZE_TYPE__ outRemaining = bufferSize;
+	int count = 0;
+
+	// Loop over getdents64 blocks: a block consisting solely of "." / ".." would
+	// otherwise look like end-of-directory, so keep reading until we pack at least
+	// one entry, run out of buffer, or hit the real EOF.
+	while (1)
+	{
+		char dbuf[4096];
+		long n = LINUX_SYSCALL(__NR_getdents64, fd, dbuf, sizeof(dbuf));
+		if (n < 0)
+			return errno_linux_to_bsd(n);
+		if (n == 0)
+			return count; // real end of directory
+
+		long long committedOff = -1; // d_off of the last entry we are done with
+		int stoppedEarly = 0;
+
+		for (char* iter = dbuf; iter < dbuf + n; )
+		{
+			struct linux_dirent64* de = (struct linux_dirent64*) iter;
+			char* deNext = iter + de->d_reclen;
+
+			if (is_dot_or_dotdot(de->d_name))
+			{
+				committedOff = (long long) de->d_off;
+				iter = deNext;
+				continue;
+			}
+
+			// Resolve object type (from d_type, falling back to a stat).
+			unsigned int objType = DTAPE_VNON;
+			if (needType)
+			{
+				objType = objtype_from_dtype(de->d_type);
+				if (objType == DTAPE_VNON)
+				{
+					struct linux_stat lst;
+					long sr;
+#ifdef __NR_newfstatat
+					sr = LINUX_SYSCALL(__NR_newfstatat, fd, de->d_name, &lst, LINUX_AT_SYMLINK_NOFOLLOW);
+#else
+					sr = LINUX_SYSCALL(__NR_fstatat64, fd, de->d_name, &lst, LINUX_AT_SYMLINK_NOFOLLOW);
+#endif
+					if (sr >= 0)
+						objType = objtype_from_mode(lst.st_mode);
+				}
+			}
+
+			const int packDirEntryCount = (objType == DTAPE_VDIR) && (alist->dirattr & ATTR_DIR_ENTRYCOUNT);
+			const int packRsrcLength    = (objType == DTAPE_VREG) && (alist->fileattr & ATTR_FILE_RSRCLENGTH);
+
+			__SIZE_TYPE__ nameLen = strlen(de->d_name);
+			__SIZE_TYPE__ nameFieldLen = nameLen + 1;
+			__SIZE_TYPE__ nameAligned = (nameFieldLen + 3) & ~(__SIZE_TYPE__) 3;
+
+			// Compute the exact byte size of this entry; must mirror the packing below.
+			__SIZE_TYPE__ spaceNeeded = 4; // leading uint32_t length
+			if (wantReturned)
+				spaceNeeded += sizeof(struct dtape_attribute_set);
+			if (alist->commonattr & ATTR_CMN_NAME)
+				spaceNeeded += sizeof(struct dtape_attrreference) + nameAligned;
+			if (alist->commonattr & ATTR_CMN_OBJTYPE)
+				spaceNeeded += sizeof(uint32_t);
+			if (alist->commonattr & ATTR_CMN_OBJTAG)
+				spaceNeeded += sizeof(uint32_t);
+			if (alist->commonattr & ATTR_CMN_FNDRINFO)
+				spaceNeeded += 32;
+			if (alist->commonattr & ATTR_CMN_ERROR)
+				spaceNeeded += sizeof(uint32_t);
+			if (packDirEntryCount)
+				spaceNeeded += sizeof(uint32_t);
+			if (packRsrcLength)
+				spaceNeeded += sizeof(uint64_t);
+
+			if (spaceNeeded > outRemaining)
+			{
+				stoppedEarly = 1;
+				break;
+			}
+
+			// --- pack the entry ---
+			char* p = outp;
+			char* lenField = p;
+			p += 4;
+
+			struct dtape_attribute_set* retp = 0;
+			if (wantReturned)
+			{
+				retp = (struct dtape_attribute_set*) p;
+				p += sizeof(struct dtape_attribute_set);
+			}
+
+			unsigned int rCmn = wantReturned ? ATTR_CMN_RETURNED_ATTRS : 0;
+			unsigned int rDir = 0, rFile = 0;
+
+			char* nameRef = 0;
+			if (alist->commonattr & ATTR_CMN_NAME)
+			{
+				nameRef = p;
+				p += sizeof(struct dtape_attrreference);
+				rCmn |= ATTR_CMN_NAME;
+			}
+			if (alist->commonattr & ATTR_CMN_OBJTYPE)
+			{
+				*((uint32_t*) p) = objType;
+				p += sizeof(uint32_t);
+				rCmn |= ATTR_CMN_OBJTYPE;
+			}
+			if (alist->commonattr & ATTR_CMN_OBJTAG)
+			{
+				*((uint32_t*) p) = VT_HFS; // pretend we're always on HFS
+				p += sizeof(uint32_t);
+				rCmn |= ATTR_CMN_OBJTAG;
+			}
+			if (alist->commonattr & ATTR_CMN_FNDRINFO)
+			{
+				memset(p, 0, 32); // no Finder info under Linux
+				p += 32;
+				rCmn |= ATTR_CMN_FNDRINFO;
+			}
+			if (alist->commonattr & ATTR_CMN_ERROR)
+			{
+				*((uint32_t*) p) = 0; // per-entry error: success
+				p += sizeof(uint32_t);
+				rCmn |= ATTR_CMN_ERROR;
+			}
+			if (packDirEntryCount)
+			{
+				*((uint32_t*) p) = dir_entry_count(fd, de->d_name);
+				p += sizeof(uint32_t);
+				rDir |= ATTR_DIR_ENTRYCOUNT;
+			}
+			if (packRsrcLength)
+			{
+				*((uint64_t*) p) = 0; // no resource fork under Linux
+				p += sizeof(uint64_t);
+				rFile |= ATTR_FILE_RSRCLENGTH;
+			}
+			if (nameRef)
+			{
+				struct dtape_attrreference* ref = (struct dtape_attrreference*) nameRef;
+				ref->attr_dataoffset = (int) (p - nameRef);
+				ref->attr_length = (unsigned int) nameFieldLen;
+				memcpy(p, de->d_name, nameFieldLen);
+				p += nameAligned;
+			}
+			if (retp)
+			{
+				retp->commonattr = rCmn;
+				retp->volattr = 0;
+				retp->dirattr = rDir;
+				retp->fileattr = rFile;
+				retp->forkattr = 0;
+			}
+
+			*((uint32_t*) lenField) = (uint32_t) (p - lenField);
+
+			outp = p;
+			outRemaining -= spaceNeeded;
+			committedOff = (long long) de->d_off;
+			++count;
+			iter = deNext;
+		}
+
+		if (stoppedEarly)
+		{
+			// Rewind the directory so the entries we could not fit are re-read on the
+			// next call. d_off is the opaque seek cookie produced by getdents64.
+			if (committedOff >= 0)
+				sys_lseek(fd, committedOff, LINUX_SEEK_SET);
+			if (count == 0)
+				return -EINVAL; // buffer too small to hold even a single entry
+			return count;
+		}
+
+		// Whole block consumed. If we packed anything, return it; otherwise the block
+		// was all "." / ".." so loop to read the next block.
+		if (count > 0)
+			return count;
+	}
 }
