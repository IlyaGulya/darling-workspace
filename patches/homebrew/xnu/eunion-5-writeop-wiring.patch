diff --git a/darling/src/libsystem_kernel/emulation/include/linux_premigration/vchroot_expand.h b/darling/src/libsystem_kernel/emulation/include/linux_premigration/vchroot_expand.h
index ae8485394af27f756a5c7847489d3aa3f31aa345..f95a71dadac7e5a3ccef1c129432a3c14ee8f1ef 100644
--- a/darling/src/libsystem_kernel/emulation/include/linux_premigration/vchroot_expand.h
+++ b/darling/src/libsystem_kernel/emulation/include/linux_premigration/vchroot_expand.h
@@ -25,4 +25,21 @@ int vchroot_expand(struct vchroot_expand_args* args);
 int vchroot_unexpand(struct vchroot_unexpand_args* args);
 int vchroot_fdpath(struct vchroot_fdpath_args* args);
 
+#ifdef EUNION
+// E-UNION: writable-upper / read-only-lower union by path translation.
+// Copy-up / whiteout / opaque / merged-readdir primitives.
+int vchroot_copyup(const char* guest);
+int vchroot_whiteout(const char* guest);
+int vchroot_unwhiteout(const char* guest);
+int vchroot_set_opaque(const char* guest);
+int vchroot_readdir_merge(const char* guest, char* out, int cap);
+// Thin policy helpers the syscall-emulation sites call (see vchroot_userspace.c):
+//   vchroot_prepare_write(guest) BEFORE a write/mutate (expand then hits upper);
+//   vchroot_post_unlink(guest)   AFTER a successful unlink/rmdir;
+//   vchroot_pre_mkdir(guest)     BEFORE re-creating a possibly-deleted name.
+int vchroot_prepare_write(const char* guest);
+int vchroot_post_unlink(const char* guest);
+int vchroot_pre_mkdir(const char* guest);
+#endif // EUNION
+
 #endif // _VCHROOT_EXPAND_H
diff --git a/darling/src/libsystem_kernel/emulation/src/linux_premigration/vchroot_userspace.c b/darling/src/libsystem_kernel/emulation/src/linux_premigration/vchroot_userspace.c
index df2c0c6eea5c2fc32dfbc9f97737a0052b9c232f..f5268aa68e674022d0d463b97eed38e4b3ef8374 100644
--- a/darling/src/libsystem_kernel/emulation/src/linux_premigration/vchroot_userspace.c
+++ b/darling/src/libsystem_kernel/emulation/src/linux_premigration/vchroot_userspace.c
@@ -478,6 +478,80 @@ int vchroot_set_opaque(const char* guest)
 	return eunion_set_marker(up, EUNION_OPAQUE_XATTR);
 }
 
+// -------- E-UNION write-op wiring helpers --------------------------------
+//
+// These are the thin entrypoints the syscall-emulation sites call so the union
+// policy stays in one place. The pattern at a mutating site is:
+//   vchroot_prepare_write(guest);   // BEFORE vchroot_expand -> expand hits upper
+//   ... vchroot_expand(); real syscall ...
+//   vchroot_post_unlink(guest);     // AFTER a successful unlink/rmdir
+// All take an ABSOLUTE guest path (the shared template is addressed absolutely:
+// /usr, /System, ...). A relative or out-of-prefix path is a no-op success --
+// such writes never touch the read-only template, so there is nothing to do.
+
+// Is this a guest path we union-manage? (absolute, and a prefix is configured)
+static int eunion_manage(const char* guest)
+{
+	return libexec_path_len > 0 && prefix_path_len >= 0
+		&& guest && guest[0] == '/';
+}
+
+// Before a write/mutate: ensure the target lives in the writable upper layer so
+// the real syscall never mutates the shared template. If the path is lower-only
+// it is copied up; if it carries a whiteout the marker is cleared first (an
+// O_CREAT-style write resurrects a deleted name); absent-in-both and
+// already-upper are both no-op successes (the create lands in the upper).
+int vchroot_prepare_write(const char* guest)
+{
+	if (!eunion_manage(guest))
+		return 0;
+
+	// a whiteout means the name was deleted; writing it resurrects it
+	if (eunion_is_whiteout(guest))
+	{
+		int r = vchroot_unwhiteout(guest);
+		if (r < 0)
+			return r;
+		// fall through: nothing to copy up (it was deleted), create-in-upper
+		return 0;
+	}
+
+	int r = vchroot_copyup(guest);
+	if (r == -LINUX_ENOENT)
+		return 0; // absent in both layers: a create will make it fresh in upper
+	return r; // 0 if copied up or already upper; negative on real error
+}
+
+// After a successful unlink/rmdir of the upper object: if the name still exists
+// in the lower template, drop a whiteout so it stays deleted. If it was
+// upper-only (absent from lower), do nothing -- the unlink already removed it.
+int vchroot_post_unlink(const char* guest)
+{
+	if (!eunion_manage(guest))
+		return 0;
+
+	char lo[4096];
+	if (eunion_host_path(libexec_path, libexec_path_len, guest, lo, sizeof(lo)) < 0)
+		return -LINUX_ENAMETOOLONG;
+
+	stat_t lst;
+	if (eunion_lstat(lo, &lst) != 0)
+		return 0; // not in the template: nothing to hide
+
+	return vchroot_whiteout(guest);
+}
+
+// Before re-creating a name (mkdir/create over a previously deleted name): clear
+// any whiteout marker so the new object is visible. No-op if not whited out.
+int vchroot_pre_mkdir(const char* guest)
+{
+	if (!eunion_manage(guest))
+		return 0;
+	if (!eunion_is_whiteout(guest))
+		return 0;
+	return vchroot_unwhiteout(guest);
+}
+
 // helper: append `name` to a NUL-separated out buffer if it fits and is not a
 // duplicate of an already-appended name. Returns 1 if appended, 0 if dup, <0 on
 // overflow.
diff --git a/darling/src/libsystem_kernel/emulation/src/xnu_syscall/bsd/impl/fcntl/openat.c b/darling/src/libsystem_kernel/emulation/src/xnu_syscall/bsd/impl/fcntl/openat.c
index 0ad74ed2bb94441a8386f57b0d308f20bf16a419..2649e350e19787482530dd8e571016d205642b94 100644
--- a/darling/src/libsystem_kernel/emulation/src/xnu_syscall/bsd/impl/fcntl/openat.c
+++ b/darling/src/libsystem_kernel/emulation/src/xnu_syscall/bsd/impl/fcntl/openat.c
@@ -65,6 +65,20 @@ long sys_openat_nocancel(int fd, const char* filename, int flags, unsigned int m
 		return ret;
 	}
 
+#ifdef EUNION
+	// E-UNION: if this open writes/creates/truncates, materialize the target in
+	// the writable upper layer BEFORE expand so the real syscall never mutates the
+	// shared read-only template. Absolute guest paths only; relative/out-of-prefix
+	// is a no-op inside the helper. (Read-only opens are left alone.)
+	if (filename[0] == '/' &&
+	    ((flags & 0x3) == BSD_O_WRONLY || (flags & 0x3) == BSD_O_RDWR ||
+	     (flags & BSD_O_CREAT) || (flags & BSD_O_TRUNC))) {
+		int wr = vchroot_prepare_write(filename);
+		if (wr < 0)
+			return errno_linux_to_bsd(wr);
+	}
+#endif
+
 	struct vchroot_expand_args vc;
 	vc.flags = (flags & BSD_O_SYMLINK || flags & BSD_O_NOFOLLOW) ? 0 : VCHROOT_FOLLOW;
 	vc.dfd = atfd(fd);
diff --git a/darling/src/libsystem_kernel/emulation/src/xnu_syscall/bsd/impl/stat/mkdirat.c b/darling/src/libsystem_kernel/emulation/src/xnu_syscall/bsd/impl/stat/mkdirat.c
index e16d09fae2c55d583247653e862e55a0f572caf2..b0746e7bd404762ec22dc0a3a52dce36f0abcb5d 100644
--- a/darling/src/libsystem_kernel/emulation/src/xnu_syscall/bsd/impl/stat/mkdirat.c
+++ b/darling/src/libsystem_kernel/emulation/src/xnu_syscall/bsd/impl/stat/mkdirat.c
@@ -22,7 +22,14 @@ long sys_mkdirat(int fd, const char* path, unsigned int mode)
 
 	vc.flags = 0;
 	vc.dfd = atfd(fd);
-	
+
+#ifdef EUNION
+	// mkdir over a previously-deleted name must clear its whiteout so the new
+	// dir is visible in the merged view.
+	if (path[0] == '/')
+		vchroot_pre_mkdir(path);
+#endif
+
 	strcpy(vc.path, path);
 
 	ret = vchroot_expand(&vc);
diff --git a/darling/src/libsystem_kernel/emulation/src/xnu_syscall/bsd/impl/stat/mkfifo.c b/darling/src/libsystem_kernel/emulation/src/xnu_syscall/bsd/impl/stat/mkfifo.c
index fc2cdb753c9086e8cfc8f529c4889069b573e2f6..3e043b3f73bcf8a8246fae0a3d5d0c4354d8a637 100644
--- a/darling/src/libsystem_kernel/emulation/src/xnu_syscall/bsd/impl/stat/mkfifo.c
+++ b/darling/src/libsystem_kernel/emulation/src/xnu_syscall/bsd/impl/stat/mkfifo.c
@@ -22,7 +22,12 @@ long sys_mkfifo(const char* path, unsigned int mode)
 
 	vc.flags = 0;
 	vc.dfd = get_perthread_wd();
-	
+
+#ifdef EUNION
+	if (path[0] == '/')
+		vchroot_pre_mkdir(path); // clear any whiteout at the new name
+#endif
+
 	strcpy(vc.path, path);
 
 	ret = vchroot_expand(&vc);
diff --git a/darling/src/libsystem_kernel/emulation/src/xnu_syscall/bsd/impl/stat/rmdir.c b/darling/src/libsystem_kernel/emulation/src/xnu_syscall/bsd/impl/stat/rmdir.c
index dd9f2324489428e41647bfe4165922728ec9b4e9..b0aad3b43198e30a44a8f465458feec12482b87f 100644
--- a/darling/src/libsystem_kernel/emulation/src/xnu_syscall/bsd/impl/stat/rmdir.c
+++ b/darling/src/libsystem_kernel/emulation/src/xnu_syscall/bsd/impl/stat/rmdir.c
@@ -34,5 +34,12 @@ long sys_rmdir(const char* path)
 	if (ret < 0)
 		return errno_linux_to_bsd(ret);
 
+#ifdef EUNION
+	// the upper dir was removed; if the lower template still has it, whiteout so
+	// the merged view keeps it deleted instead of resurrecting the template dir.
+	if (path[0] == '/')
+		vchroot_post_unlink(path);
+#endif
+
 	return 0;
 }
diff --git a/darling/src/libsystem_kernel/emulation/src/xnu_syscall/bsd/impl/time/utimes.c b/darling/src/libsystem_kernel/emulation/src/xnu_syscall/bsd/impl/time/utimes.c
index 8f861021336415aef29a308d3af07377b0bf46c4..fab46ded33f00a2a11c424521c4f9a5c4c22badb 100644
--- a/darling/src/libsystem_kernel/emulation/src/xnu_syscall/bsd/impl/time/utimes.c
+++ b/darling/src/libsystem_kernel/emulation/src/xnu_syscall/bsd/impl/time/utimes.c
@@ -24,10 +24,19 @@ long sys_utimes(const char* path, struct bsd_timeval* tv)
 
 	vc.flags = VCHROOT_FOLLOW;
 	vc.dfd = get_perthread_wd();
-	
+
 	if (!path)
 		return -EFAULT;
 
+#ifdef EUNION
+	// utimes mutates metadata: copy up first so the change lands on the upper copy.
+	if (path[0] == '/') {
+		int wr = vchroot_prepare_write(path);
+		if (wr < 0)
+			return errno_linux_to_bsd(wr);
+	}
+#endif
+
 	strcpy(vc.path, path);
 
 	ret = vchroot_expand(&vc);
diff --git a/darling/src/libsystem_kernel/emulation/src/xnu_syscall/bsd/impl/unistd/chmod_extended.c b/darling/src/libsystem_kernel/emulation/src/xnu_syscall/bsd/impl/unistd/chmod_extended.c
index 986f6d3ea6b6085b99d4ecc024ddca58a426c874..43ac837cd158364a2f819aa293f0aeadad96fd97 100644
--- a/darling/src/libsystem_kernel/emulation/src/xnu_syscall/bsd/impl/unistd/chmod_extended.c
+++ b/darling/src/libsystem_kernel/emulation/src/xnu_syscall/bsd/impl/unistd/chmod_extended.c
@@ -18,6 +18,15 @@ long sys_chmod_extended(const char* path, int uid, int gid, int mode, void* xsec
 	if (!path)
 		return -EFAULT;
 
+#ifdef EUNION
+	// chmod+chown mutate metadata: copy up first so the change lands on the upper.
+	if (path[0] == '/') {
+		int wr = vchroot_prepare_write(path);
+		if (wr < 0)
+			return errno_linux_to_bsd(wr);
+	}
+#endif
+
 	strcpy(vc.path, path);
 	ret = vchroot_expand(&vc);
 	if (ret < 0)
diff --git a/darling/src/libsystem_kernel/emulation/src/xnu_syscall/bsd/impl/unistd/fchmodat.c b/darling/src/libsystem_kernel/emulation/src/xnu_syscall/bsd/impl/unistd/fchmodat.c
index d749ef6f4cfeeeb69b7f15d9a9c961e14ec89b4c..78a9de0cb8e0de207c8e1998c575a7af2ae181df 100644
--- a/darling/src/libsystem_kernel/emulation/src/xnu_syscall/bsd/impl/unistd/fchmodat.c
+++ b/darling/src/libsystem_kernel/emulation/src/xnu_syscall/bsd/impl/unistd/fchmodat.c
@@ -69,6 +69,16 @@ long sys_fchmodat(int fd, const char* path, int mode, int flag)
 	if (!path)
 		return -EFAULT;
 
+#ifdef EUNION
+	// chmod mutates metadata: copy up from the template first so the change lands
+	// on the per-prefix upper copy, not the shared lower file.
+	if (path[0] == '/') {
+		int wr = vchroot_prepare_write(path);
+		if (wr < 0)
+			return errno_linux_to_bsd(wr);
+	}
+#endif
+
 	strcpy(vc.path, path);
 
 	ret = vchroot_expand(&vc);
diff --git a/darling/src/libsystem_kernel/emulation/src/xnu_syscall/bsd/impl/unistd/linkat.c b/darling/src/libsystem_kernel/emulation/src/xnu_syscall/bsd/impl/unistd/linkat.c
index dcc0dc73c2ef43967cc57d289737e9d2826ad96e..77d08a120085aa549e7b743115e024acf9088b02 100644
--- a/darling/src/libsystem_kernel/emulation/src/xnu_syscall/bsd/impl/unistd/linkat.c
+++ b/darling/src/libsystem_kernel/emulation/src/xnu_syscall/bsd/impl/unistd/linkat.c
@@ -29,6 +29,20 @@ long sys_linkat(int fd, const char* path, int fdlink, const char* link, int flag
 
 	strcpy(vc2.path, link);
 
+#ifdef EUNION
+	// hardlink: the source must live in the writable upper layer (you cannot link
+	// a file out of the read-only template into it), and the new name must clear
+	// any whiteout. Note: copy-up breaks link identity (st_nlink resets) -- same
+	// behaviour as gVisor; documented in DESIGN.md.
+	if (path[0] == '/') {
+		int wr = vchroot_prepare_write(path);
+		if (wr < 0)
+			return errno_linux_to_bsd(wr);
+	}
+	if (link[0] == '/')
+		vchroot_pre_mkdir(link);
+#endif
+
 	ret = vchroot_expand(&vc);
 	if (ret < 0)
 		return errno_linux_to_bsd(ret);
diff --git a/darling/src/libsystem_kernel/emulation/src/xnu_syscall/bsd/impl/unistd/mknod.c b/darling/src/libsystem_kernel/emulation/src/xnu_syscall/bsd/impl/unistd/mknod.c
index bd15136d7a9f0134ffa417e9392371484a5eec76..82736c196d6c03881563f13748abcfbd639ce21a 100644
--- a/darling/src/libsystem_kernel/emulation/src/xnu_syscall/bsd/impl/unistd/mknod.c
+++ b/darling/src/libsystem_kernel/emulation/src/xnu_syscall/bsd/impl/unistd/mknod.c
@@ -15,10 +15,14 @@ long sys_mknod(const char* path, int mode, int dev)
 
 	vc.flags = 0;
 	vc.dfd = get_perthread_wd();
-	
 	if (!path)
 		return -EFAULT;
 
+#ifdef EUNION
+	if (path[0] == '/')
+		vchroot_pre_mkdir(path); // clear any whiteout at the new name
+#endif
+
 	strcpy(vc.path, path);
 
 	ret = vchroot_expand(&vc);
diff --git a/darling/src/libsystem_kernel/emulation/src/xnu_syscall/bsd/impl/unistd/renameat.c b/darling/src/libsystem_kernel/emulation/src/xnu_syscall/bsd/impl/unistd/renameat.c
index 23a1912a9f63c3cd5d446f8ef788d61cb2c4e429..ee0e02869804fd89a7eeaa400b08f97064725f1c 100644
--- a/darling/src/libsystem_kernel/emulation/src/xnu_syscall/bsd/impl/unistd/renameat.c
+++ b/darling/src/libsystem_kernel/emulation/src/xnu_syscall/bsd/impl/unistd/renameat.c
@@ -26,6 +26,24 @@ long sys_renameat(int oldfd, const char* oldpath, int newfd, const char* newpath
 
 	strcpy(vc2.path, newpath);
 
+#ifdef EUNION
+	// rename across the union: the source must be in the writable upper layer
+	// (rename cannot move out of the read-only template), and the destination
+	// name must clear any whiteout. After a successful rename the source name is
+	// gone from upper -- if the template still has it, whiteout the origin so it
+	// does not resurrect from the lower layer.
+	// PoC limitation: a lower-only *directory* source only copies up its top dir
+	// here, not its descendants (gVisor F.3 recursion); files and empty dirs are
+	// correct. Tracked in DESIGN.md.
+	if (oldpath[0] == '/') {
+		int wr = vchroot_prepare_write(oldpath);
+		if (wr < 0)
+			return errno_linux_to_bsd(wr);
+	}
+	if (newpath[0] == '/')
+		vchroot_pre_mkdir(newpath);
+#endif
+
 	ret = vchroot_expand(&vc);
 	if (ret < 0)
 		return errno_linux_to_bsd(ret);
@@ -38,5 +56,10 @@ long sys_renameat(int oldfd, const char* oldpath, int newfd, const char* newpath
 	if (ret < 0)
 		return errno_linux_to_bsd(ret);
 
+#ifdef EUNION
+	if (oldpath[0] == '/')
+		vchroot_post_unlink(oldpath);
+#endif
+
 	return 0;
 }
diff --git a/darling/src/libsystem_kernel/emulation/src/xnu_syscall/bsd/impl/unistd/symlinkat.c b/darling/src/libsystem_kernel/emulation/src/xnu_syscall/bsd/impl/unistd/symlinkat.c
