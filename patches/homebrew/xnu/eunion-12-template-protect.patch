From f03bea64366c3662d444e2e6f850b2774d9cd63b Mon Sep 17 00:00:00 2001
From: Ilya Gulya <ilya@gulya.me>
Date: Tue, 16 Jun 2026 05:10:27 +0000
Subject: [PATCH] EXPERIMENT E-UNION: template-protection for
 delete/rename/create/fd-meta (PoC, #ifdef EUNION)

The lower template is a SHARED live directory, not a read-only mount, so any
mutating syscall that reaches a lower host path silently corrupts the template
for ALL prefixes. The earlier wiring assumed such syscalls would just EROFS;
they do not. This adds the policy primitives the emulation sites call BEFORE the
real syscall so a mutation can never land in the template, and wires them in:

  vchroot_prepare_unlink(guest)  -- lower-only name: drop a whiteout + return
      SKIP so the site does NOT run the host delete (would erase the template);
      upper present: PROCEED (+ post_unlink whiteouts a lower namesake).
  vchroot_prepare_rename_dest(guest) -- copy up the dest parent (else the rename
      moves INTO the template) and whiteout a lower-only dest namesake.
  vchroot_prepare_create(guest)  -- copy up a lower-only parent (else the create
      lands in the template) and clear any whiteout at the new name.
  vchroot_prepare_write_fd(fd,out,cap) -- recover an fd's guest path, copy it up,
      return the guest path so a metadata op can re-open the upper copy (the
      original fd still references the lower inode).
  eunion_copyup_parent(guest)    -- shared helper for the above.

Sites wired: unlinkat, rmdir (prepare_unlink + post_unlink); renameat (source
copyup_tree, dest prepare_rename_dest); mkdirat/mknod/mkfifo/symlinkat and
openat O_CREAT (prepare_create, replacing the partial pre_mkdir).

Validated in the hermetic resolver harness (experiments/e-union): U1-U3, RN1-RN2,
CR1, FD1 each proven to fail (RED) under a targeted mutation that disables the
guard, and pass with it. Full -DDARLING_EUNION build compiles and links.

Beads: dar-test-infra-sp5.8.4.4.1/.2/.3.

Co-Authored-By: Claude Opus 4.8 (1M context) <noreply@anthropic.com>
---
 .../linux_premigration/vchroot_expand.h       |  17 ++
 .../linux_premigration/vchroot_userspace.c    | 163 ++++++++++++++++++
 .../src/xnu_syscall/bsd/impl/fcntl/openat.c   |   8 +
 .../src/xnu_syscall/bsd/impl/stat/mkdirat.c   |  12 +-
 .../src/xnu_syscall/bsd/impl/stat/mkfifo.c    |   9 +-
 .../src/xnu_syscall/bsd/impl/stat/rmdir.c     |  16 +-
 .../src/xnu_syscall/bsd/impl/unistd/mknod.c   |   9 +-
 .../xnu_syscall/bsd/impl/unistd/renameat.c    |  11 +-
 .../xnu_syscall/bsd/impl/unistd/symlinkat.c   |  10 +-
 .../xnu_syscall/bsd/impl/unistd/unlinkat.c    |  15 ++
 10 files changed, 256 insertions(+), 14 deletions(-)

diff --git a/darling/src/libsystem_kernel/emulation/include/linux_premigration/vchroot_expand.h b/darling/src/libsystem_kernel/emulation/include/linux_premigration/vchroot_expand.h
index 24f1af11bcd256acf8f64b240ac644af59969055..d8f6eaadc86557ac4b025948449382a9f1f4624b 100644
--- a/darling/src/libsystem_kernel/emulation/include/linux_premigration/vchroot_expand.h
+++ b/darling/src/libsystem_kernel/emulation/include/linux_premigration/vchroot_expand.h
@@ -49,6 +49,23 @@ int vchroot_prepare_write(const char* guest);
 // *at() variant: resolve a dirfd-relative target to a guest-absolute path via
 // the dirfd, then prepare_write. For openat/mkdirat/etc. with a relative path.
 int vchroot_prepare_write_at(int dfd, const char* rel);
+// fd variant for metadata ops (fchmod/futimes/fsetxattr) on a possibly-lower fd:
+// recovers the fd's guest path, copies it up, returns the guest path in `out`
+// (len > 0) so the caller can re-open the upper copy. 0 = not union-managed.
+int vchroot_prepare_write_fd(int fd, char* out, int cap);
+// BEFORE unlink/rmdir: decide policy and tell the caller whether to run the host
+// delete. The lower template is shared+live (not RO), so a lower-only name must
+// be hidden with a whiteout, never deleted on disk.
+#define VCHROOT_UNLINK_PROCEED 0  // caller runs the host delete
+#define VCHROOT_UNLINK_SKIP    1  // caller must NOT delete (whiteout already set)
+int vchroot_prepare_unlink(const char* guest);
+// BEFORE a rename destination is committed: copy up the dest's parent dir and
+// whiteout a lower-only dest namesake, so the host rename lands in the upper
+// layer and never moves into / overwrites the shared template.
+int vchroot_prepare_rename_dest(const char* guest);
+// BEFORE a create (mkdir/mknod/mkfifo/symlink): copy up the parent dir so the
+// new entry lands in the upper layer, and clear any whiteout at the new name.
+int vchroot_prepare_create(const char* guest);
 int vchroot_post_unlink(const char* guest);
 int vchroot_pre_mkdir(const char* guest);
 #endif // EUNION
diff --git a/darling/src/libsystem_kernel/emulation/src/linux_premigration/vchroot_userspace.c b/darling/src/libsystem_kernel/emulation/src/linux_premigration/vchroot_userspace.c
index 38bbed8a5cbca6880494d12598ee48d9888d91e8..6f5f780b94d46cbc66add6f1448c749731f4fd19 100644
--- a/darling/src/libsystem_kernel/emulation/src/linux_premigration/vchroot_userspace.c
+++ b/darling/src/libsystem_kernel/emulation/src/linux_premigration/vchroot_userspace.c
@@ -707,6 +707,169 @@ int vchroot_prepare_write_at(int dfd, const char* rel)
 	return vchroot_prepare_write(guest);
 }
 
+// fd variant: a metadata op on an fd (fchmod/futimes/fsetxattr) has no path. If
+// the fd was opened on a lower-only object the inode is the template's; mutating
+// via the fd hits the shared template. Recover the fd's guest path, copy it up,
+// and return the guest path in `out` so the caller can RE-OPEN the upper copy and
+// retarget the op (the original fd still references the lower inode). Returns the
+// guest-path length (>0) on success, 0 if unmanaged / the fd escapes the union
+// (caller proceeds with the original fd), or a negative errno.
+int vchroot_prepare_write_fd(int fd, char* out, int cap)
+{
+	if (!out || cap <= 0)
+		return 0; // no buffer to return a path in: caller proceeds with the fd
+	out[0] = '\0';
+
+	char guest[4096];
+	struct vchroot_fdpath_args fp;
+	fp.fd = fd; fp.path = guest; fp.maxlen = sizeof(guest);
+	if (vchroot_fdpath(&fp) < 0)
+		return 0; // cannot map the fd: proceed with the original fd
+	if (guest[0] != '/')
+		return 0; // fd escapes the guest (EXIT_PATH): not union-managed
+
+	if (!eunion_manage(guest))
+		return 0;
+
+	int r = vchroot_prepare_write(guest);
+	if (r < 0)
+		return r;
+
+	int gl = (int)strlen(guest);
+	if (gl + 1 > cap)
+		return -LINUX_ENAMETOOLONG;
+	memcpy(out, guest, gl + 1);
+	return gl;
+}
+
+// BEFORE an unlink/rmdir: decide the union policy and tell the caller whether to
+// run the host delete syscall. The lower template is a SHARED live directory
+// (not a read-only mount), so a delete that reaches a lower host path would
+// physically remove the object from the template for EVERY prefix. We must never
+// let the real syscall touch a lower-only name.
+//
+//   lower-only name  -> drop a whiteout, return VCHROOT_UNLINK_SKIP: the caller
+//                       must NOT call the host syscall (the name is now hidden).
+//   upper present    -> return VCHROOT_UNLINK_PROCEED: the caller deletes the
+//                       upper object, then calls vchroot_post_unlink() to drop a
+//                       whiteout if the name also exists in the template.
+//   absent in both / unmanaged -> VCHROOT_UNLINK_PROCEED (let the syscall ENOENT
+//                       naturally; nothing to hide).
+int vchroot_prepare_unlink(const char* guest)
+{
+	if (!eunion_manage(guest))
+		return VCHROOT_UNLINK_PROCEED;
+
+	// upper object present? then the real delete targets the upper copy -> proceed
+	char up[4096];
+	if (eunion_host_path(prefix_path, prefix_path_len, guest, up, sizeof(up)) < 0)
+		return -LINUX_ENAMETOOLONG;
+	stat_t ust;
+	if (eunion_lstat(up, &ust) == 0)
+		return VCHROOT_UNLINK_PROCEED; // delete the upper; post_unlink handles lower
+
+	// no upper object. is it in the lower template?
+	char lo[4096];
+	if (eunion_host_path(libexec_path, libexec_path_len, guest, lo, sizeof(lo)) < 0)
+		return -LINUX_ENAMETOOLONG;
+	stat_t lst;
+	if (eunion_lstat(lo, &lst) != 0)
+		return VCHROOT_UNLINK_PROCEED; // absent in both: let the syscall ENOENT
+
+	// lower-only: NEVER delete from the shared template. Hide it with a whiteout
+	// and tell the caller to skip the host delete entirely.
+	int r = vchroot_whiteout(guest);
+	if (r < 0)
+		return r;
+	return VCHROOT_UNLINK_SKIP;
+}
+
+// Copy the guest path's PARENT directory up into the writable upper layer. Used
+// before a create/rename so the new entry lands in the upper, not the template.
+// No-op success if there is no parent (root) or the path is unmanaged.
+static int eunion_copyup_parent(const char* guest)
+{
+	if (!eunion_manage(guest))
+		return 0;
+	// find the last '/'
+	int last = -1;
+	for (int i = 0; guest[i]; i++)
+		if (guest[i] == '/') last = i;
+	if (last <= 0)
+		return 0; // parent is "/" (root): always present in upper
+	char parent[4096];
+	if (last >= (int)sizeof(parent))
+		return -LINUX_ENAMETOOLONG;
+	memcpy(parent, guest, last);
+	parent[last] = '\0';
+	int r = vchroot_copyup(parent);
+	return (r == -LINUX_ENOENT) ? 0 : r; // absent-in-both parent: a create makes it
+}
+
+// BEFORE a rename's DESTINATION is committed: ensure the move lands in the upper
+// layer and never mutates the shared template.
+//   * copy up the destination's PARENT dir (if lower-only, the expanded dest
+//     would otherwise point into the template and the host rename would move
+//     INTO it);
+//   * if the destination NAME exists only in the lower template, whiteout it so
+//     the old template content is hidden once the renamed object takes the name
+//     (the host rename targets the upper path; the lower namesake stays on disk
+//     but must be masked).
+//   * if a whiteout already sits at the dest, clear it (the rename recreates it).
+int vchroot_prepare_rename_dest(const char* guest)
+{
+	if (!eunion_manage(guest))
+		return 0;
+
+	int r = eunion_copyup_parent(guest);
+	if (r < 0)
+		return r;
+
+	// a stale whiteout at the dest must be cleared so the moved object is visible
+	if (eunion_is_whiteout(guest))
+	{
+		r = vchroot_unwhiteout(guest);
+		if (r < 0)
+			return r;
+		return 0; // it was deleted; nothing in the template to mask
+	}
+
+	// dest present in the upper already? the host rename overwrites it -> fine
+	char up[4096];
+	if (eunion_host_path(prefix_path, prefix_path_len, guest, up, sizeof(up)) < 0)
+		return -LINUX_ENAMETOOLONG;
+	stat_t ust;
+	if (eunion_lstat(up, &ust) == 0)
+		return 0;
+
+	// dest only in the lower template: mask it with a whiteout so the old content
+	// does not show through after the rename publishes the new upper object.
+	char lo[4096];
+	if (eunion_host_path(libexec_path, libexec_path_len, guest, lo, sizeof(lo)) < 0)
+		return -LINUX_ENAMETOOLONG;
+	stat_t lst;
+	if (eunion_lstat(lo, &lst) == 0)
+		return vchroot_whiteout(guest);
+
+	return 0; // absent in both: a plain create-in-upper
+}
+
+// BEFORE creating a new entry (mkdir/mknod/mkfifo/symlink/...): ensure the
+// PARENT dir lives in the writable upper layer (else the create lands inside the
+// shared template) and clear any whiteout at the new name (an explicit create
+// resurrects a previously deleted name). Does NOT create the entry itself.
+int vchroot_prepare_create(const char* guest)
+{
+	if (!eunion_manage(guest))
+		return 0;
+	int r = eunion_copyup_parent(guest);
+	if (r < 0)
+		return r;
+	if (eunion_is_whiteout(guest))
+		return vchroot_unwhiteout(guest);
+	return 0;
+}
+
 // After a successful unlink/rmdir of the upper object: if the name still exists
 // in the lower template, drop a whiteout so it stays deleted. If it was
 // upper-only (absent from lower), do nothing -- the unlink already removed it.
diff --git a/darling/src/libsystem_kernel/emulation/src/xnu_syscall/bsd/impl/fcntl/openat.c b/darling/src/libsystem_kernel/emulation/src/xnu_syscall/bsd/impl/fcntl/openat.c
index 2faa203b7c13ce10945699d5b82e7658c18772e3..e4ccb2e26ea4fc6729c61426a93ebe453b1a1ac4 100644
--- a/darling/src/libsystem_kernel/emulation/src/xnu_syscall/bsd/impl/fcntl/openat.c
+++ b/darling/src/libsystem_kernel/emulation/src/xnu_syscall/bsd/impl/fcntl/openat.c
@@ -78,6 +78,14 @@ long sys_openat_nocancel(int fd, const char* filename, int flags, unsigned int m
 			: vchroot_prepare_write_at(atfd(fd), filename);
 		if (wr < 0)
 			return errno_linux_to_bsd(wr);
+		// O_CREAT of a new file in a lower-only directory: prepare_write is a
+		// no-op for an absent target, so also copy up the PARENT dir, or the
+		// create lands inside the shared template. (Absolute paths only.)
+		if ((flags & BSD_O_CREAT) && filename[0] == '/') {
+			wr = vchroot_prepare_create(filename);
+			if (wr < 0)
+				return errno_linux_to_bsd(wr);
+		}
 	}
 #endif
 
diff --git a/darling/src/libsystem_kernel/emulation/src/xnu_syscall/bsd/impl/stat/mkdirat.c b/darling/src/libsystem_kernel/emulation/src/xnu_syscall/bsd/impl/stat/mkdirat.c
index b0746e7bd404762ec22dc0a3a52dce36f0abcb5d..29ddff2909a0187a55eabcb13b0ed5b8e24ab603 100644
--- a/darling/src/libsystem_kernel/emulation/src/xnu_syscall/bsd/impl/stat/mkdirat.c
+++ b/darling/src/libsystem_kernel/emulation/src/xnu_syscall/bsd/impl/stat/mkdirat.c
@@ -24,10 +24,14 @@ long sys_mkdirat(int fd, const char* path, unsigned int mode)
 	vc.dfd = atfd(fd);
 
 #ifdef EUNION
-	// mkdir over a previously-deleted name must clear its whiteout so the new
-	// dir is visible in the merged view.
-	if (path[0] == '/')
-		vchroot_pre_mkdir(path);
+	// copy up the parent dir (so the new dir lands in the upper layer, not the
+	// shared template) and clear any whiteout at the new name (mkdir over a
+	// previously-deleted name resurrects it).
+	if (path[0] == '/') {
+		int wr = vchroot_prepare_create(path);
+		if (wr < 0)
+			return errno_linux_to_bsd(wr);
+	}
 #endif
 
 	strcpy(vc.path, path);
diff --git a/darling/src/libsystem_kernel/emulation/src/xnu_syscall/bsd/impl/stat/mkfifo.c b/darling/src/libsystem_kernel/emulation/src/xnu_syscall/bsd/impl/stat/mkfifo.c
index 3e043b3f73bcf8a8246fae0a3d5d0c4354d8a637..eb7b06e58c637d6c184d1aeb07e860b109b53647 100644
--- a/darling/src/libsystem_kernel/emulation/src/xnu_syscall/bsd/impl/stat/mkfifo.c
+++ b/darling/src/libsystem_kernel/emulation/src/xnu_syscall/bsd/impl/stat/mkfifo.c
@@ -24,8 +24,13 @@ long sys_mkfifo(const char* path, unsigned int mode)
 	vc.dfd = get_perthread_wd();
 
 #ifdef EUNION
-	if (path[0] == '/')
-		vchroot_pre_mkdir(path); // clear any whiteout at the new name
+	// copy up the parent dir (so the fifo lands in the upper layer, not the
+	// shared template) and clear any whiteout at the new name.
+	if (path[0] == '/') {
+		int wr = vchroot_prepare_create(path);
+		if (wr < 0)
+			return errno_linux_to_bsd(wr);
+	}
 #endif
 
 	strcpy(vc.path, path);
diff --git a/darling/src/libsystem_kernel/emulation/src/xnu_syscall/bsd/impl/stat/rmdir.c b/darling/src/libsystem_kernel/emulation/src/xnu_syscall/bsd/impl/stat/rmdir.c
index b0aad3b43198e30a44a8f465458feec12482b87f..9ca110de37ab442dce1a5cf84047ea342960952e 100644
--- a/darling/src/libsystem_kernel/emulation/src/xnu_syscall/bsd/impl/stat/rmdir.c
+++ b/darling/src/libsystem_kernel/emulation/src/xnu_syscall/bsd/impl/stat/rmdir.c
@@ -22,9 +22,23 @@ long sys_rmdir(const char* path)
 
 	vc.flags = 0;
 	vc.dfd = get_perthread_wd();
-	
+
 	strcpy(vc.path, path);
 
+#ifdef EUNION
+	// E-UNION: a lower-only directory must be hidden with a whiteout, never
+	// rmdir'd out of the shared template. SKIP => already whited-out, done.
+	// PROCEED => the dir is in the upper layer; rmdir it, then whiteout if a
+	// template namesake remains. (See vchroot_prepare_unlink.)
+	if (path[0] == '/') {
+		int pol = vchroot_prepare_unlink(path);
+		if (pol < 0)
+			return errno_linux_to_bsd(pol);
+		if (pol == VCHROOT_UNLINK_SKIP)
+			return 0;
+	}
+#endif
+
 	ret = vchroot_expand(&vc);
 	if (ret < 0)
 		return errno_linux_to_bsd(ret);
diff --git a/darling/src/libsystem_kernel/emulation/src/xnu_syscall/bsd/impl/unistd/mknod.c b/darling/src/libsystem_kernel/emulation/src/xnu_syscall/bsd/impl/unistd/mknod.c
index 82736c196d6c03881563f13748abcfbd639ce21a..28fc410fba1492ea011f3be8b219bb58a4f6da62 100644
--- a/darling/src/libsystem_kernel/emulation/src/xnu_syscall/bsd/impl/unistd/mknod.c
+++ b/darling/src/libsystem_kernel/emulation/src/xnu_syscall/bsd/impl/unistd/mknod.c
@@ -19,8 +19,13 @@ long sys_mknod(const char* path, int mode, int dev)
 		return -EFAULT;
 
 #ifdef EUNION
-	if (path[0] == '/')
-		vchroot_pre_mkdir(path); // clear any whiteout at the new name
+	// copy up the parent dir (so the node lands in the upper layer, not the
+	// shared template) and clear any whiteout at the new name.
+	if (path[0] == '/') {
+		int wr = vchroot_prepare_create(path);
+		if (wr < 0)
+			return errno_linux_to_bsd(wr);
+	}
 #endif
 
 	strcpy(vc.path, path);
diff --git a/darling/src/libsystem_kernel/emulation/src/xnu_syscall/bsd/impl/unistd/renameat.c b/darling/src/libsystem_kernel/emulation/src/xnu_syscall/bsd/impl/unistd/renameat.c
index 633e2584fa551a6b1396f6d858bfeffe10acdb76..8c9e9bf6476b9bb68388722534e1fdfe89f57645 100644
--- a/darling/src/libsystem_kernel/emulation/src/xnu_syscall/bsd/impl/unistd/renameat.c
+++ b/darling/src/libsystem_kernel/emulation/src/xnu_syscall/bsd/impl/unistd/renameat.c
@@ -42,8 +42,15 @@ long sys_renameat(int oldfd, const char* oldpath, int newfd, const char* newpath
 		if (wr < 0)
 			return errno_linux_to_bsd(wr);
 	}
-	if (newpath[0] == '/')
-		vchroot_pre_mkdir(newpath);
+	// destination side: copy up the dest's parent (so the move lands in the upper
+	// layer, not the template) and whiteout a lower-only dest namesake. Also
+	// clears any stale whiteout at the dest. Replaces the old pre_mkdir, which
+	// only cleared a whiteout and left rename-into-template / dest-overwrite holes.
+	if (newpath[0] == '/') {
+		int wr = vchroot_prepare_rename_dest(newpath);
+		if (wr < 0)
+			return errno_linux_to_bsd(wr);
+	}
 #endif
 
 	ret = vchroot_expand(&vc);
diff --git a/darling/src/libsystem_kernel/emulation/src/xnu_syscall/bsd/impl/unistd/symlinkat.c b/darling/src/libsystem_kernel/emulation/src/xnu_syscall/bsd/impl/unistd/symlinkat.c
index b668f0945471fbfef22220ec7eb8bad6b93030a6..6b47bf3e21de5feeaae43b1fd6ca5ac7d68511c6 100644
--- a/darling/src/libsystem_kernel/emulation/src/xnu_syscall/bsd/impl/unistd/symlinkat.c
+++ b/darling/src/libsystem_kernel/emulation/src/xnu_syscall/bsd/impl/unistd/symlinkat.c
@@ -19,9 +19,13 @@ long sys_symlinkat(const char* path, int fd, const char* link)
 	vc.dfd = get_perthread_wd();
 
 #ifdef EUNION
-	// creating a symlink at `link`: clear any whiteout so the new name is visible.
-	if (link[0] == '/')
-		vchroot_pre_mkdir(link);
+	// creating a symlink at `link`: copy up its parent dir (so the link lands in
+	// the upper layer, not the shared template) and clear any whiteout at the name.
+	if (link[0] == '/') {
+		int wr = vchroot_prepare_create(link);
+		if (wr < 0)
+			return errno_linux_to_bsd(wr);
+	}
 #endif
 
 	strcpy(vc.path, link);
diff --git a/darling/src/libsystem_kernel/emulation/src/xnu_syscall/bsd/impl/unistd/unlinkat.c b/darling/src/libsystem_kernel/emulation/src/xnu_syscall/bsd/impl/unistd/unlinkat.c
index b4d3d2aecf492dae98000adea3bb5e852c336023..8450db1c5b5758ef2f9940e05834eb9ba29ac6a7 100644
--- a/darling/src/libsystem_kernel/emulation/src/xnu_syscall/bsd/impl/unistd/unlinkat.c
+++ b/darling/src/libsystem_kernel/emulation/src/xnu_syscall/bsd/impl/unistd/unlinkat.c
@@ -26,6 +26,21 @@ long sys_unlinkat(int fd, const char* path, int flag)
 
 	strcpy(vc.path, path);
 
+#ifdef EUNION
+	// E-UNION: NEVER delete a lower-only name from the shared template. Decide the
+	// policy BEFORE expand/syscall. SKIP => the name was lower-only and is now
+	// whited-out; report success without touching the template. PROCEED => the
+	// target is in the upper layer; delete it, then whiteout if it also shadows a
+	// template entry. (Absolute guest paths only; relative is left to the syscall.)
+	if (path[0] == '/') {
+		int pol = vchroot_prepare_unlink(path);
+		if (pol < 0)
+			return errno_linux_to_bsd(pol);
+		if (pol == VCHROOT_UNLINK_SKIP)
+			return 0; // hidden via whiteout; the template is untouched
+	}
+#endif
+
 	ret = vchroot_expand(&vc);
 	if (ret < 0)
 		return errno_linux_to_bsd(ret);
