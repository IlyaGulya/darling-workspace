+#endif
 
 __attribute__((weak))
 __attribute__((visibility("default")))
@@ -38,6 +41,11 @@ long sys_close_nocancel(int fd)
 		return 0;
 	}
 
+#ifdef EUNION
+	// release any per-fd directory-merge state before the fd number is recycled
+	vchroot_dir_closed(fd);
+#endif
+
 	ret = LINUX_SYSCALL1(__NR_close, fd);
 	if (ret < 0)
 		ret = errno_linux_to_bsd(ret);
@@ -51,6 +59,10 @@ long close_internal(int fd)
 {
 	int ret;
 
+#ifdef EUNION
+	vchroot_dir_closed(fd);
+#endif
+
 	ret = LINUX_SYSCALL1(__NR_close, fd);
 	if (ret < 0)
 		ret = errno_linux_to_bsd(ret);
