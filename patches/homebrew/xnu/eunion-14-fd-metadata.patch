From 20e7422962b4d99224e6d7dee5270b053ae3f2a6 Mon Sep 17 00:00:00 2001
From: Ilya Gulya <ilya@gulya.me>
Date: Tue, 16 Jun 2026 05:26:23 +0000
Subject: [PATCH] EXPERIMENT E-UNION: protect template on fd-metadata syscalls
 (PoC, #ifdef EUNION)

fchmod/fchmod_extended/futimes/fsetxattr/fremovexattr mutate an object via an fd
with no path. If the fd was opened on a lower-only object the fd references the
SHARED template inode, so the metadata change corrupts the template for every
prefix. (The existing FD1 primitive copied the object up but the caller's fd
still pointed at the lower inode -- the op had to be retargeted.)

Add vchroot_fd_for_meta_write(fd): copy up the fd's object if lower-only and
return a FRESH fd on the upper copy (O_RDONLY|O_NOFOLLOW -- sufficient for
chmod/utimensat/setxattr/removexattr, which check inode perms not the fd open
mode). Returns the ORIGINAL fd when the object is not union-managed. Uniform
caller rule: apply the op to the returned fd, close it iff it differs from the
original. Wire all five sites accordingly (#ifdef EUNION; OFF path byte-identical).

Also fixes vchroot_prepare_write_fd: a fd OUTSIDE both union layers detranslates
to the EXIT_PATH escape hatch ("/Volumes/SystemRoot/..."), an absolute path that
the old guest[0] != '/' check did not treat as an escape -- it would then try to
copy up a host path. Now recognized as unmanaged.

TDD (experiments/e-union, now 149 assertions): FD2 end-to-end (chmod via the
returned fd changes the UPPER copy, template mode UNTOUCHED) proven RED under a
mutation that disables the re-open; FD3 (upper-only) and FD4 (unmanaged
/dev/null -> original fd) pin the other branches. Full -DDARLING_EUNION build
compiles and links.

Bead: dar-test-infra-sp5.8.4.4.4.

Co-Authored-By: Claude Opus 4.8 (1M context) <noreply@anthropic.com>
---
 .../linux_premigration/vchroot_expand.h       |  6 ++
 .../linux_premigration/vchroot_userspace.c    | 68 ++++++++++++++++++-
 .../src/xnu_syscall/bsd/impl/time/futimes.c   | 13 ++++
 .../src/xnu_syscall/bsd/impl/unistd/fchmod.c  | 13 ++++
 .../bsd/impl/unistd/fchmod_extended.c         | 19 +++++-
 .../xnu_syscall/bsd/impl/xattr/fremovexattr.c | 12 ++++
 .../xnu_syscall/bsd/impl/xattr/fsetxattr.c    | 13 ++++
 7 files changed, 142 insertions(+), 2 deletions(-)

diff --git a/darling/src/libsystem_kernel/emulation/include/linux_premigration/vchroot_expand.h b/darling/src/libsystem_kernel/emulation/include/linux_premigration/vchroot_expand.h
index d8f6eaadc86557ac4b025948449382a9f1f4624b..59fbdb351dd87daea3cd2ec9fcfd364a28d82e2d 100644
--- a/darling/src/libsystem_kernel/emulation/include/linux_premigration/vchroot_expand.h
+++ b/darling/src/libsystem_kernel/emulation/include/linux_premigration/vchroot_expand.h
@@ -53,6 +53,12 @@ int vchroot_prepare_write_at(int dfd, const char* rel);
 // recovers the fd's guest path, copies it up, returns the guest path in `out`
 // (len > 0) so the caller can re-open the upper copy. 0 = not union-managed.
 int vchroot_prepare_write_fd(int fd, char* out, int cap);
+// High-level fd-metadata helper: copy up the fd's object if lower-only and return
+// a FRESH fd on the upper copy (caller applies the metadata op to it and closes
+// it). Returns the ORIGINAL fd unchanged if unmanaged/escape/no-copyup (caller
+// keeps using it, does not close it), or a negative errno. Used by fchmod/
+// fchmod_extended/futimes/fsetxattr/fremovexattr.
+int vchroot_fd_for_meta_write(int fd);
 // BEFORE unlink/rmdir: decide policy and tell the caller whether to run the host
 // delete. The lower template is shared+live (not RO), so a lower-only name must
 // be hidden with a whiteout, never deleted on disk.
diff --git a/darling/src/libsystem_kernel/emulation/src/linux_premigration/vchroot_userspace.c b/darling/src/libsystem_kernel/emulation/src/linux_premigration/vchroot_userspace.c
index 13d7dadc1444677c5f8a0da98a32392c7518ae7b..59f43550adba991bf5f912f5f4f63af36f45dfeb 100644
--- a/darling/src/libsystem_kernel/emulation/src/linux_premigration/vchroot_userspace.c
+++ b/darling/src/libsystem_kernel/emulation/src/linux_premigration/vchroot_userspace.c
@@ -744,7 +744,18 @@ int vchroot_prepare_write_fd(int fd, char* out, int cap)
 	if (vchroot_fdpath(&fp) < 0)
 		return 0; // cannot map the fd: proceed with the original fd
 	if (guest[0] != '/')
-		return 0; // fd escapes the guest (EXIT_PATH): not union-managed
+		return 0; // not an absolute guest path: not union-managed
+	// vchroot_fdpath detranslates a fd that lives OUTSIDE both union layers to the
+	// EXIT_PATH escape hatch ("/Volumes/SystemRoot/..."), which is a real absolute
+	// path but points at the native host root, NOT the union. Such a fd is not
+	// union-managed -- proceed with the original fd. (EXIT_PATH is defined further
+	// down; compare against the literal here.)
+	{
+		static const char esc[] = "/Volumes/SystemRoot";
+		int el = (int)sizeof(esc) - 1;
+		if (strncmp(guest, esc, el) == 0 && (guest[el] == '\0' || guest[el] == '/'))
+			return 0;
+	}
 
 	if (!eunion_manage(guest))
 		return 0;
@@ -760,6 +771,61 @@ int vchroot_prepare_write_fd(int fd, char* out, int cap)
 	return gl;
 }
 
+#ifndef LINUX_O_NOFOLLOW
+#define LINUX_O_NOFOLLOW 0400000 // Linux O_NOFOLLOW (x86); re-open the object itself
+#endif
+// High-level helper for the fd-metadata syscall sites (fchmod/fchmod_extended/
+// futimes/fsetxattr/fremovexattr). A metadata op on an fd has no path, so if the
+// fd was opened on a lower-only object the op hits the SHARED template. This
+// copies the object up (via vchroot_prepare_write_fd) and RE-OPENS the upper copy,
+// returning a fresh fd the caller must apply the op to -- the original fd still
+// references the lower inode after copy-up, so mutating it would still corrupt the
+// template.
+//
+// Caller contract (uniform): apply the metadata op to the RETURNED fd, and close
+// the returned fd iff it differs from the original.
+//
+// Returns:
+//   == fd            -> not union-managed / fd escapes the union; caller uses the
+//                       ORIGINAL fd and must NOT close it here.
+//   >= 0 and != fd   -> a fresh fd on the upper copy (after copy-up if the object
+//                       was lower-only; for an already-upper object this just
+//                       re-opens the same upper inode). Caller applies the op to
+//                       it and MUST close it when done.
+//   < 0              -> negative Linux errno.
+int vchroot_fd_for_meta_write(int fd)
+{
+	char guest[4096];
+	int r = vchroot_prepare_write_fd(fd, guest, sizeof(guest));
+	if (r < 0)
+		return r;          // negative errno
+	if (r == 0)
+		return fd;         // unmanaged / escape / no path: use the original fd
+
+	// The object was copied up; guest now resolves to the UPPER copy. The caller's
+	// original fd still references the LOWER inode, so re-open the upper copy and
+	// hand back a fresh fd. Expand the guest path (resolves to upper after copy-up)
+	// and open it. O_RDONLY is sufficient on Linux for fchmod/utimensat/fsetxattr/
+	// fremovexattr (they check inode perms, not the fd's open mode). O_NOFOLLOW so
+	// we mutate the object itself, never a symlink target.
+	struct vchroot_expand_args vc;
+	vc.flags = 0;          // do not follow the final symlink
+	vc.dfd = -100;         // AT_FDCWD-equivalent; guest is absolute
+	int gl = (int)strlen(guest);
+	if (gl + 1 > (int)sizeof(vc.path))
+		return -LINUX_ENAMETOOLONG;
+	memcpy(vc.path, guest, gl + 1);
+	int er = vchroot_expand(&vc);
+	if (er < 0)
+		return er;
+
+	int nfd = LINUX_SYSCALL(__NR_openat, LINUX_AT_FDCWD, vc.path,
+		LINUX_O_RDONLY | LINUX_O_NOFOLLOW, 0);
+	if (nfd < 0)
+		return nfd;
+	return nfd;            // != fd: caller applies the op to nfd and closes it
+}
+
 // BEFORE an unlink/rmdir: decide the union policy and tell the caller whether to
 // run the host delete syscall. The lower template is a SHARED live directory
 // (not a read-only mount), so a delete that reaches a lower host path would
diff --git a/darling/src/libsystem_kernel/emulation/src/xnu_syscall/bsd/impl/time/futimes.c b/darling/src/libsystem_kernel/emulation/src/xnu_syscall/bsd/impl/time/futimes.c
index 687a1b568d1219e83b8f43ea2ed891e0517ece89..b3fe291659d4cf261e103965fd1298894469d3d0 100644
--- a/darling/src/libsystem_kernel/emulation/src/xnu_syscall/bsd/impl/time/futimes.c
+++ b/darling/src/libsystem_kernel/emulation/src/xnu_syscall/bsd/impl/time/futimes.c
@@ -5,6 +5,7 @@
 #include <darling/emulation/common/base.h>
 #include <darling/emulation/conversion/errno.h>
 #include <darling/emulation/linux_premigration/linux-syscalls/linux.h>
+#include <darling/emulation/linux_premigration/vchroot_expand.h>
 
 
 long sys_futimes(int fd, struct bsd_timeval* tv)
@@ -17,7 +18,19 @@ long sys_futimes(int fd, struct bsd_timeval* tv)
 	ltv[1].tv_sec = tv[1].tv_sec;
 	ltv[1].tv_usec = tv[1].tv_usec;
 
+#ifdef EUNION
+	// E-UNION: copy up a lower-only object and stamp times on a fresh fd targeting
+	// the upper copy, never the shared template. (utimensat with a NULL path acts
+	// on the fd's object.)
+	int wfd = vchroot_fd_for_meta_write(fd);
+	if (wfd < 0)
+		return errno_linux_to_bsd(wfd);
+	ret = LINUX_SYSCALL(__NR_utimensat, wfd, NULL, ltv, 0);
+	if (wfd != fd)
+		LINUX_SYSCALL(__NR_close, wfd);
+#else
 	ret = LINUX_SYSCALL(__NR_utimensat, fd, NULL, ltv, 0);
+#endif
 	if (ret < 0)
 		ret = errno_linux_to_bsd(ret);
 
diff --git a/darling/src/libsystem_kernel/emulation/src/xnu_syscall/bsd/impl/unistd/fchmod.c b/darling/src/libsystem_kernel/emulation/src/xnu_syscall/bsd/impl/unistd/fchmod.c
index 13c130aef640b798e4277395ec099f9027e9b262..0b87bf29277e2e8b7e912eea2cb897434de0ceb8 100644
--- a/darling/src/libsystem_kernel/emulation/src/xnu_syscall/bsd/impl/unistd/fchmod.c
+++ b/darling/src/libsystem_kernel/emulation/src/xnu_syscall/bsd/impl/unistd/fchmod.c
@@ -3,12 +3,25 @@
 #include <darling/emulation/common/base.h>
 #include <darling/emulation/conversion/errno.h>
 #include <darling/emulation/linux_premigration/linux-syscalls/linux.h>
+#include <darling/emulation/linux_premigration/vchroot_expand.h>
 
 long sys_fchmod(int fd, int mode)
 {
 	int ret;
 
+#ifdef EUNION
+	// E-UNION: if `fd` was opened on a lower-only object, mutating its metadata
+	// via the fd would hit the SHARED template. Copy it up and operate on a fresh
+	// fd targeting the upper copy. Returns the original fd if unmanaged.
+	int wfd = vchroot_fd_for_meta_write(fd);
+	if (wfd < 0)
+		return errno_linux_to_bsd(wfd);
+	ret = LINUX_SYSCALL2(__NR_fchmod, wfd, mode);
+	if (wfd != fd)
+		LINUX_SYSCALL(__NR_close, wfd);
+#else
 	ret = LINUX_SYSCALL2(__NR_fchmod, fd, mode);
+#endif
 	if (ret < 0)
 		ret = errno_linux_to_bsd(ret);
 
diff --git a/darling/src/libsystem_kernel/emulation/src/xnu_syscall/bsd/impl/unistd/fchmod_extended.c b/darling/src/libsystem_kernel/emulation/src/xnu_syscall/bsd/impl/unistd/fchmod_extended.c
index 87f0d9052b4a9b0e983707639cb64fc2942767e8..add1ccd7a6bf70e0881c1fff4e480c19e57ee190 100644
--- a/darling/src/libsystem_kernel/emulation/src/xnu_syscall/bsd/impl/unistd/fchmod_extended.c
+++ b/darling/src/libsystem_kernel/emulation/src/xnu_syscall/bsd/impl/unistd/fchmod_extended.c
@@ -6,6 +6,7 @@
 #include <darling/emulation/common/base.h>
 #include <darling/emulation/conversion/errno.h>
 #include <darling/emulation/linux_premigration/linux-syscalls/linux.h>
+#include <darling/emulation/linux_premigration/vchroot_expand.h>
 
 long sys_fchmod_extended(int fd, int uid, int gid, int mode, void* xsec)
 {
@@ -16,13 +17,29 @@ long sys_fchmod_extended(int fd, int uid, int gid, int mode, void* xsec)
 		return 0;
 	}
 
+#ifdef EUNION
+	// E-UNION: copy up a lower-only object and apply chmod+chown to a fresh fd on
+	// the upper copy, never the shared template. Both ops target the same fd.
+	int wfd = vchroot_fd_for_meta_write(fd);
+	if (wfd < 0)
+		return errno_linux_to_bsd(wfd);
+	ret = LINUX_SYSCALL2(__NR_fchmod, wfd, mode);
+	if (ret >= 0)
+		ret = LINUX_SYSCALL(__NR_fchown, wfd, uid, gid);
+	if (wfd != fd)
+		LINUX_SYSCALL(__NR_close, wfd);
+	if (ret < 0)
+		return errno_linux_to_bsd(ret);
+	return ret;
+#else
 	ret = LINUX_SYSCALL2(__NR_fchmod, fd, mode);
 	if (ret < 0)
 		return errno_linux_to_bsd(ret);
-	
+
 	ret = LINUX_SYSCALL(__NR_fchown, fd, uid, gid);
 	if (ret < 0)
 		return errno_linux_to_bsd(ret);
 
 	return ret;
+#endif
 }
diff --git a/darling/src/libsystem_kernel/emulation/src/xnu_syscall/bsd/impl/xattr/fremovexattr.c b/darling/src/libsystem_kernel/emulation/src/xnu_syscall/bsd/impl/xattr/fremovexattr.c
index adaff442befea620c006ce5d465cc63482a36d3a..0775d276c76c3639ee7a274b42f761064ae2f89b 100644
--- a/darling/src/libsystem_kernel/emulation/src/xnu_syscall/bsd/impl/xattr/fremovexattr.c
+++ b/darling/src/libsystem_kernel/emulation/src/xnu_syscall/bsd/impl/xattr/fremovexattr.c
@@ -3,12 +3,24 @@
 #include <darling/emulation/common/base.h>
 #include <darling/emulation/conversion/errno.h>
 #include <darling/emulation/linux_premigration/linux-syscalls/linux.h>
+#include <darling/emulation/linux_premigration/vchroot_expand.h>
 
 long sys_fremovexattr(int fd, const char* name, int options)
 {
 	int ret;
 
+#ifdef EUNION
+	// E-UNION: copy up a lower-only object and remove the xattr from a fresh fd on
+	// the upper copy, never the shared template.
+	int wfd = vchroot_fd_for_meta_write(fd);
+	if (wfd < 0)
+		return errno_linux_to_bsd(wfd);
+	ret = LINUX_SYSCALL(__NR_fremovexattr, wfd, name);
+	if (wfd != fd)
+		LINUX_SYSCALL(__NR_close, wfd);
+#else
 	ret = LINUX_SYSCALL(__NR_fremovexattr, fd, name);
+#endif
 
 	if (ret < 0)
 		return errno_linux_to_bsd(ret);
diff --git a/darling/src/libsystem_kernel/emulation/src/xnu_syscall/bsd/impl/xattr/fsetxattr.c b/darling/src/libsystem_kernel/emulation/src/xnu_syscall/bsd/impl/xattr/fsetxattr.c
index 9aaef2c0453161429bda33f47fdd87f6bfb868d5..2968acebc251574a4ac7604a7df4dc34bee68216 100644
--- a/darling/src/libsystem_kernel/emulation/src/xnu_syscall/bsd/impl/xattr/fsetxattr.c
+++ b/darling/src/libsystem_kernel/emulation/src/xnu_syscall/bsd/impl/xattr/fsetxattr.c
@@ -5,6 +5,7 @@
 #include <darling/emulation/common/base.h>
 #include <darling/emulation/conversion/errno.h>
 #include <darling/emulation/linux_premigration/linux-syscalls/linux.h>
+#include <darling/emulation/linux_premigration/vchroot_expand.h>
 
 long sys_fsetxattr(int fd, const char* name, const void* value,
 		unsigned long size, unsigned int pos, int options)
@@ -14,7 +15,19 @@ long sys_fsetxattr(int fd, const char* name, const void* value,
 	if (pos != 0)
 		return -ERANGE;
 
+#ifdef EUNION
+	// E-UNION: copy up a lower-only object and set the xattr on a fresh fd on the
+	// upper copy, never the shared template. (Marker-namespace isolation for the
+	// path-based setxattr/removexattr is handled separately under .5.)
+	int wfd = vchroot_fd_for_meta_write(fd);
+	if (wfd < 0)
+		return errno_linux_to_bsd(wfd);
+	ret = LINUX_SYSCALL(__NR_fsetxattr, wfd, name, value, size);
+	if (wfd != fd)
+		LINUX_SYSCALL(__NR_close, wfd);
+#else
 	ret = LINUX_SYSCALL(__NR_fsetxattr, fd, name, value, size);
+#endif
 
 	if (ret < 0)
 		return errno_linux_to_bsd(ret);
