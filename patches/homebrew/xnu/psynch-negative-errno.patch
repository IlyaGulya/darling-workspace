From 10096d1101c0685ad53adfc9b057892f9d6f3506 Mon Sep 17 00:00:00 2001
From: Ilya Gulya <ilya@gulya.me>
Date: Wed, 8 Jul 2026 08:47:47 +0000
Subject: [PATCH] libsystem_kernel: route psynch wait errors through cerror

---
 .../bsd/impl/psynch/psynch_return.h           | 26 ++++++++++++++++
 .../bsd/impl/psynch/psynch_cvwait.c           |  5 +--
 .../bsd/impl/psynch/psynch_mutexwait.c        |  5 +--
 .../bsd/impl/psynch/psynch_rw_rdlock.c        |  5 +--
 .../bsd/impl/psynch/psynch_rw_wrlock.c        |  5 +--
 .../tests/psynch_return_contract_test.c       | 31 +++++++++++++++++++
 .../tests/run-psynch-return-contract.sh       | 12 +++++++
 7 files changed, 81 insertions(+), 8 deletions(-)
 create mode 100644 darling/src/libsystem_kernel/emulation/include/xnu_syscall/bsd/impl/psynch/psynch_return.h
 create mode 100644 darling/src/libsystem_kernel/tests/psynch_return_contract_test.c
 create mode 100755 darling/src/libsystem_kernel/tests/run-psynch-return-contract.sh

diff --git a/darling/src/libsystem_kernel/emulation/include/xnu_syscall/bsd/impl/psynch/psynch_return.h b/darling/src/libsystem_kernel/emulation/include/xnu_syscall/bsd/impl/psynch/psynch_return.h
new file mode 100644
index 0000000000000000000000000000000000000000..dd6593c057d7ce7dee319a746df60f9761017667
--- /dev/null
+++ b/darling/src/libsystem_kernel/emulation/include/xnu_syscall/bsd/impl/psynch/psynch_return.h
@@ -0,0 +1,26 @@
+#ifndef DARLING_XNU_SYSCALL_BSD_IMPL_PSYNCH_RETURN_H
+#define DARLING_XNU_SYSCALL_BSD_IMPL_PSYNCH_RETURN_H
+
+#include <stdint.h>
+
+static inline long darling_psynch_wait_error(int error)
+{
+	return -error;
+}
+
+static inline long darling_psynch_wait_return(int result, uint32_t retval)
+{
+	if (!result)
+		return retval;
+
+	/*
+	 * Darling's BSD syscall implementation returns negative errno values to
+	 * the generated public syscall wrapper, which then routes them through
+	 * cerror. Preserve the full psynch result here: condvars may include
+	 * ECVCLEARED/ECVPREPOST status bits above the low-byte errno, and
+	 * libpthread decodes those bits after cerror stores them in errno.
+	 */
+	return darling_psynch_wait_error(result);
+}
+
+#endif
diff --git a/darling/src/libsystem_kernel/emulation/src/xnu_syscall/bsd/impl/psynch/psynch_cvwait.c b/darling/src/libsystem_kernel/emulation/src/xnu_syscall/bsd/impl/psynch/psynch_cvwait.c
index d093b7392fb179a60803a543adc311f4f476fe71..45b9e82917925c18303007fb060b89555ab0b892 100644
--- a/darling/src/libsystem_kernel/emulation/src/xnu_syscall/bsd/impl/psynch/psynch_cvwait.c
+++ b/darling/src/libsystem_kernel/emulation/src/xnu_syscall/bsd/impl/psynch/psynch_cvwait.c
@@ -1,4 +1,5 @@
 #include <darling/emulation/xnu_syscall/bsd/impl/psynch/psynch_cvwait.h>
+#include <darling/emulation/xnu_syscall/bsd/impl/psynch/psynch_return.h>
 
 #include <darling/emulation/common/base.h>
 #include <darling/emulation/linux_premigration/linux-syscalls/linux.h>
@@ -15,11 +16,11 @@ long sys_psynch_cvwait(void* cv, uint64_t cvlsgen, uint32_t cvugen, void * mutex
 
 	if (ret < 0) {
 		if (ret == -LINUX_EINTR) {
-			return -EINTR;
+			return darling_psynch_wait_error(EINTR);
 		}
 		__simple_printf("psynch_cvwait failed internally: %d", ret);
 		__simple_abort();
 	}
 
-	return (ret) ? ret : retval;
+	return darling_psynch_wait_return(ret, retval);
 }
diff --git a/darling/src/libsystem_kernel/emulation/src/xnu_syscall/bsd/impl/psynch/psynch_mutexwait.c b/darling/src/libsystem_kernel/emulation/src/xnu_syscall/bsd/impl/psynch/psynch_mutexwait.c
index 2a0525128238bf15e6546be74b00fddb564251d2..a5425cf25df89f1c80706108477738c416d1f2a5 100644
--- a/darling/src/libsystem_kernel/emulation/src/xnu_syscall/bsd/impl/psynch/psynch_mutexwait.c
+++ b/darling/src/libsystem_kernel/emulation/src/xnu_syscall/bsd/impl/psynch/psynch_mutexwait.c
@@ -1,4 +1,5 @@
 #include <darling/emulation/xnu_syscall/bsd/impl/psynch/psynch_mutexwait.h>
+#include <darling/emulation/xnu_syscall/bsd/impl/psynch/psynch_return.h>
 
 
 #include <darling/emulation/common/base.h>
@@ -15,11 +16,11 @@ long sys_psynch_mutexwait(void* mutex, uint32_t mgen, uint32_t ugen, uint64_t ti
 
 	if (ret < 0) {
 		if (ret == -LINUX_EINTR) {
-			return -EINTR;
+			return darling_psynch_wait_error(EINTR);
 		}
 		__simple_printf("psynch_mutexwait failed internally: %d", ret);
 		__simple_abort();
 	}
 
-	return (ret) ? ret : retval;
+	return darling_psynch_wait_return(ret, retval);
 }
diff --git a/darling/src/libsystem_kernel/emulation/src/xnu_syscall/bsd/impl/psynch/psynch_rw_rdlock.c b/darling/src/libsystem_kernel/emulation/src/xnu_syscall/bsd/impl/psynch/psynch_rw_rdlock.c
index b002d68e81b76bc036a0b0014eb4375cae88908b..6b19dcf37ef84b6668473e87688c671e5b7b6e63 100644
--- a/darling/src/libsystem_kernel/emulation/src/xnu_syscall/bsd/impl/psynch/psynch_rw_rdlock.c
+++ b/darling/src/libsystem_kernel/emulation/src/xnu_syscall/bsd/impl/psynch/psynch_rw_rdlock.c
@@ -1,4 +1,5 @@
 #include <darling/emulation/xnu_syscall/bsd/impl/psynch/psynch_rw_rdlock.h>
+#include <darling/emulation/xnu_syscall/bsd/impl/psynch/psynch_return.h>
 
 #include <darling/emulation/common/base.h>
 #include <darling/emulation/linux_premigration/linux-syscalls/linux.h>
@@ -14,11 +15,11 @@ long sys_psynch_rw_rdlock(void* rwlock, uint32_t lgenval, uint32_t ugenval, uint
 
 	if (ret < 0) {
 		if (ret == -LINUX_EINTR) {
-			return -EINTR;
+			return darling_psynch_wait_error(EINTR);
 		}
 		__simple_printf("psynch_rw_rdlock failed internally: %d", ret);
 		__simple_abort();
 	}
 
-	return (ret) ? ret : retval;
+	return darling_psynch_wait_return(ret, retval);
 }
diff --git a/darling/src/libsystem_kernel/emulation/src/xnu_syscall/bsd/impl/psynch/psynch_rw_wrlock.c b/darling/src/libsystem_kernel/emulation/src/xnu_syscall/bsd/impl/psynch/psynch_rw_wrlock.c
index 38427a7260085ed73de9f4b2045546108c0a41c0..c1330ea254ef076423dbffbd05fcc12cabb04dce 100644
--- a/darling/src/libsystem_kernel/emulation/src/xnu_syscall/bsd/impl/psynch/psynch_rw_wrlock.c
+++ b/darling/src/libsystem_kernel/emulation/src/xnu_syscall/bsd/impl/psynch/psynch_rw_wrlock.c
@@ -1,4 +1,5 @@
 #include <darling/emulation/xnu_syscall/bsd/impl/psynch/psynch_rw_wrlock.h>
+#include <darling/emulation/xnu_syscall/bsd/impl/psynch/psynch_return.h>
 
 #include <darling/emulation/common/base.h>
 #include <darling/emulation/linux_premigration/linux-syscalls/linux.h>
@@ -14,11 +15,11 @@ long sys_psynch_rw_wrlock(void* rwlock, uint32_t lgenval, uint32_t ugenval, uint
 
 	if (ret < 0) {
 		if (ret == -LINUX_EINTR) {
-			return -EINTR;
+			return darling_psynch_wait_error(EINTR);
 		}
 		__simple_printf("psynch_rw_wrlock failed internally: %d", ret);
 		__simple_abort();
 	}
 
-	return (ret) ? ret : retval;
+	return darling_psynch_wait_return(ret, retval);
 }
diff --git a/darling/src/libsystem_kernel/tests/psynch_return_contract_test.c b/darling/src/libsystem_kernel/tests/psynch_return_contract_test.c
new file mode 100644
index 0000000000000000000000000000000000000000..00447f9a6fb0586970fc4adef21bfd1f128c49e2
--- /dev/null
+++ b/darling/src/libsystem_kernel/tests/psynch_return_contract_test.c
@@ -0,0 +1,31 @@
+#include <errno.h>
+#include <stdint.h>
+#include <stdio.h>
+
+#include <xnu_syscall/bsd/impl/psynch/psynch_return.h>
+
+static int expect_long(const char* what, long got, long want)
+{
+	if (got == want)
+		return 0;
+	fprintf(stderr, "%s: got %ld want %ld\n", what, got, want);
+	return 1;
+}
+
+int main(void)
+{
+	const uint32_t updateval = 0x12345678u;
+	const int augmented_eintr = EINTR | 0x200;
+
+	if (expect_long("success return", darling_psynch_wait_return(0, updateval), updateval))
+		return 1;
+
+	if (expect_long("augmented error return", darling_psynch_wait_return(augmented_eintr, updateval), -augmented_eintr))
+		return 1;
+
+	if (expect_long("transport EINTR return", darling_psynch_wait_error(EINTR), -EINTR))
+		return 1;
+
+	puts("PSYNCH_RETURN_CONTRACT_OK");
+	return 0;
+}
diff --git a/darling/src/libsystem_kernel/tests/run-psynch-return-contract.sh b/darling/src/libsystem_kernel/tests/run-psynch-return-contract.sh
new file mode 100755
index 0000000000000000000000000000000000000000..24c08e870a2c6c512454fa756ba872b515a049fd
--- /dev/null
+++ b/darling/src/libsystem_kernel/tests/run-psynch-return-contract.sh
@@ -0,0 +1,12 @@
+#!/usr/bin/env bash
+set -euo pipefail
+
+here="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
+root="${XNU_SRC_ROOT:-$(git -C "$here" rev-parse --show-toplevel)}"
+src="$here/psynch_return_contract_test.c"
+include="$root/darling/src/libsystem_kernel/emulation/include"
+out="$(mktemp /tmp/psynch-return-contract.XXXXXX)"
+trap 'rm -f "$out"' EXIT
+
+cc -std=c11 -Wall -Wextra -I "$include" "$src" -o "$out"
+"$out" | grep -q '^PSYNCH_RETURN_CONTRACT_OK$'

From 8df32150517d967213e1a4e9a87fa315d50917b9 Mon Sep 17 00:00:00 2001
From: Ilya Gulya <ilya@gulya.me>
Date: Fri, 10 Jul 2026 01:07:25 +0000
Subject: [PATCH] test: make psynch return contract behavioral

---
 .../tests/psynch_return_contract_test.c       | 124 +++++++++++++++++-
 .../tests/run-psynch-return-contract.sh       |  62 ++++++++-
 2 files changed, 177 insertions(+), 9 deletions(-)

diff --git a/darling/src/libsystem_kernel/tests/psynch_return_contract_test.c b/darling/src/libsystem_kernel/tests/psynch_return_contract_test.c
index 00447f9a6fb0586970fc4adef21bfd1f128c49e2..433c95c53052ac93237b9c6a4b107fde393983a6 100644
--- a/darling/src/libsystem_kernel/tests/psynch_return_contract_test.c
+++ b/darling/src/libsystem_kernel/tests/psynch_return_contract_test.c
@@ -2,9 +2,73 @@
 #include <stdint.h>
 #include <stdio.h>
 
-#include <xnu_syscall/bsd/impl/psynch/psynch_return.h>
+long sys_psynch_cvwait(void *cv, uint64_t cvlsgen, uint32_t cvugen,
+		void *mutex, uint64_t mugen, uint32_t flags, int64_t sec,
+		uint32_t nsec);
+long sys_psynch_mutexwait(void *mutex, uint32_t mgen, uint32_t ugen,
+		uint64_t tid, uint32_t flags);
+long sys_psynch_rw_rdlock(void *rwlock, uint32_t lgenval, uint32_t ugenval,
+		uint32_t rw_wc, int flags);
+long sys_psynch_rw_wrlock(void *rwlock, uint32_t lgenval, uint32_t ugenval,
+		uint32_t rw_wc, int flags);
 
-static int expect_long(const char* what, long got, long want)
+static int stub_rpc_ret;
+static uint32_t stub_rpc_retval;
+
+int dserver_rpc_psynch_cvwait(void *cv, uint64_t cvlsgen, uint32_t cvugen,
+		void *mutex, uint64_t mugen, uint32_t flags, int64_t sec,
+		uint32_t nsec, uint32_t *retval)
+{
+	(void)cv;
+	(void)cvlsgen;
+	(void)cvugen;
+	(void)mutex;
+	(void)mugen;
+	(void)flags;
+	(void)sec;
+	(void)nsec;
+	*retval = stub_rpc_retval;
+	return stub_rpc_ret;
+}
+
+int dserver_rpc_psynch_mutexwait(void *mutex, uint32_t mgen, uint32_t ugen,
+		uint64_t tid, uint32_t flags, uint32_t *retval)
+{
+	(void)mutex;
+	(void)mgen;
+	(void)ugen;
+	(void)tid;
+	(void)flags;
+	*retval = stub_rpc_retval;
+	return stub_rpc_ret;
+}
+
+int dserver_rpc_psynch_rw_rdlock(void *rwlock, uint32_t lgenval,
+		uint32_t ugenval, uint32_t rw_wc, int flags, uint32_t *retval)
+{
+	(void)rwlock;
+	(void)lgenval;
+	(void)ugenval;
+	(void)rw_wc;
+	(void)flags;
+	*retval = stub_rpc_retval;
+	return stub_rpc_ret;
+}
+
+int dserver_rpc_psynch_rw_wrlock(void *rwlock, uint32_t lgenval,
+		uint32_t ugenval, uint32_t rw_wc, int flags, uint32_t *retval)
+{
+	(void)rwlock;
+	(void)lgenval;
+	(void)ugenval;
+	(void)rw_wc;
+	(void)flags;
+	*retval = stub_rpc_retval;
+	return stub_rpc_ret;
+}
+
+static int
+expect_long(const char *what, long got, long want)
 {
 	if (got == want)
 		return 0;
@@ -12,18 +76,64 @@ static int expect_long(const char* what, long got, long want)
 	return 1;
 }
 
-int main(void)
+static int
+expect_wait_contract(const char *what, long (*call)(void))
 {
 	const uint32_t updateval = 0x12345678u;
-	const int augmented_eintr = EINTR | 0x200;
+	const int augmented_error = ETIMEDOUT | 0x100;
 
-	if (expect_long("success return", darling_psynch_wait_return(0, updateval), updateval))
+	stub_rpc_ret = 0;
+	stub_rpc_retval = updateval;
+	if (expect_long(what, call(), updateval))
 		return 1;
 
-	if (expect_long("augmented error return", darling_psynch_wait_return(augmented_eintr, updateval), -augmented_eintr))
+	stub_rpc_ret = augmented_error;
+	stub_rpc_retval = updateval;
+	if (expect_long(what, call(), -augmented_error))
 		return 1;
 
-	if (expect_long("transport EINTR return", darling_psynch_wait_error(EINTR), -EINTR))
+	stub_rpc_ret = -4;
+	stub_rpc_retval = updateval;
+	if (expect_long(what, call(), -EINTR))
+		return 1;
+
+	return 0;
+}
+
+static long
+call_cvwait(void)
+{
+	return sys_psynch_cvwait(0, 0, 0, 0, 0, 0, 0, 0);
+}
+
+static long
+call_mutexwait(void)
+{
+	return sys_psynch_mutexwait(0, 0, 0, 0, 0);
+}
+
+static long
+call_rw_rdlock(void)
+{
+	return sys_psynch_rw_rdlock(0, 0, 0, 0, 0);
+}
+
+static long
+call_rw_wrlock(void)
+{
+	return sys_psynch_rw_wrlock(0, 0, 0, 0, 0);
+}
+
+int
+main(void)
+{
+	if (expect_wait_contract("cvwait", call_cvwait))
+		return 1;
+	if (expect_wait_contract("mutexwait", call_mutexwait))
+		return 1;
+	if (expect_wait_contract("rw_rdlock", call_rw_rdlock))
+		return 1;
+	if (expect_wait_contract("rw_wrlock", call_rw_wrlock))
 		return 1;
 
 	puts("PSYNCH_RETURN_CONTRACT_OK");
diff --git a/darling/src/libsystem_kernel/tests/run-psynch-return-contract.sh b/darling/src/libsystem_kernel/tests/run-psynch-return-contract.sh
index 24c08e870a2c6c512454fa756ba872b515a049fd..3c21e309ba408d00fa8329e21d5bc649924a6da0 100755
--- a/darling/src/libsystem_kernel/tests/run-psynch-return-contract.sh
+++ b/darling/src/libsystem_kernel/tests/run-psynch-return-contract.sh
@@ -5,8 +5,66 @@ here="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
 root="${XNU_SRC_ROOT:-$(git -C "$here" rev-parse --show-toplevel)}"
 src="$here/psynch_return_contract_test.c"
 include="$root/darling/src/libsystem_kernel/emulation/include"
+impl="$root/darling/src/libsystem_kernel/emulation/src/xnu_syscall/bsd/impl/psynch"
+stub_include="$(mktemp -d /tmp/psynch-return-contract-include.XXXXXX)"
 out="$(mktemp /tmp/psynch-return-contract.XXXXXX)"
-trap 'rm -f "$out"' EXIT
+trap 'rm -rf "$stub_include" "$out"' EXIT
 
-cc -std=c11 -Wall -Wextra -I "$include" "$src" -o "$out"
+mkdir -p \
+	"$stub_include/darling/emulation/xnu_syscall/bsd/impl/psynch" \
+	"$stub_include/darling/emulation/common" \
+	"$stub_include/darling/emulation/conversion" \
+	"$stub_include/darling/emulation/linux_premigration/linux-syscalls" \
+	"$stub_include/darlingserver"
+
+cat > "$stub_include/darling/emulation/xnu_syscall/bsd/impl/psynch/psynch_cvwait.h" <<'EOF'
+#include <stdint.h>
+long sys_psynch_cvwait(void*, uint64_t, uint32_t, void*, uint64_t, uint32_t, int64_t, uint32_t);
+EOF
+cat > "$stub_include/darling/emulation/xnu_syscall/bsd/impl/psynch/psynch_mutexwait.h" <<'EOF'
+#include <stdint.h>
+long sys_psynch_mutexwait(void*, uint32_t, uint32_t, uint64_t, uint32_t);
+EOF
+cat > "$stub_include/darling/emulation/xnu_syscall/bsd/impl/psynch/psynch_rw_rdlock.h" <<'EOF'
+#include <stdint.h>
+long sys_psynch_rw_rdlock(void*, uint32_t, uint32_t, uint32_t, int);
+EOF
+cat > "$stub_include/darling/emulation/xnu_syscall/bsd/impl/psynch/psynch_rw_wrlock.h" <<'EOF'
+#include <stdint.h>
+long sys_psynch_rw_wrlock(void*, uint32_t, uint32_t, uint32_t, int);
+EOF
+cat > "$stub_include/darling/emulation/xnu_syscall/bsd/impl/psynch/psynch_return.h" <<'EOF'
+#include <xnu_syscall/bsd/impl/psynch/psynch_return.h>
+EOF
+cat > "$stub_include/darling/emulation/common/base.h" <<'EOF'
+#include <errno.h>
+EOF
+cat > "$stub_include/darling/emulation/linux_premigration/linux-syscalls/linux.h" <<'EOF'
+#define LINUX_EINTR 4
+EOF
+cat > "$stub_include/darling/emulation/common/simple.h" <<'EOF'
+#include <stdarg.h>
+#include <stdlib.h>
+static inline void __simple_printf(const char* format, ...) { (void)format; }
+static inline void __simple_abort(void) { abort(); }
+EOF
+cat > "$stub_include/darling/emulation/conversion/duct_errno.h" <<'EOF'
+EOF
+cat > "$stub_include/darlingserver/rpc.h" <<'EOF'
+#include <stdint.h>
+int dserver_rpc_psynch_cvwait(void*, uint64_t, uint32_t, void*, uint64_t, uint32_t, int64_t, uint32_t, uint32_t*);
+int dserver_rpc_psynch_mutexwait(void*, uint32_t, uint32_t, uint64_t, uint32_t, uint32_t*);
+int dserver_rpc_psynch_rw_rdlock(void*, uint32_t, uint32_t, uint32_t, int, uint32_t*);
+int dserver_rpc_psynch_rw_wrlock(void*, uint32_t, uint32_t, uint32_t, int, uint32_t*);
+EOF
+
+cc -std=c11 -Wall -Wextra \
+	-I "$stub_include" \
+	-I "$include" \
+	"$src" \
+	"$impl/psynch_cvwait.c" \
+	"$impl/psynch_mutexwait.c" \
+	"$impl/psynch_rw_rdlock.c" \
+	"$impl/psynch_rw_wrlock.c" \
+	-o "$out"
 "$out" | grep -q '^PSYNCH_RETURN_CONTRACT_OK$'
