From 10096d1101c0685ad53adfc9b057892f9d6f3506 Mon Sep 17 00:00:00 2001
From: Ilya Gulya <ilya@gulya.me>
Date: Wed, 8 Jul 2026 08:47:47 +0000
Subject: [PATCH] libsystem_kernel: route psynch wait errors through cerror

---
 .../bsd/impl/psynch/psynch_return.h           | 26 ++++++++++++++++
 .../bsd/impl/psynch/psynch_cvwait.c           |  5 +--
 .../bsd/impl/psynch/psynch_mutexwait.c        |  5 +--
 .../bsd/impl/psynch/psynch_rw_rdlock.c        |  5 +--
 .../bsd/impl/psynch/psynch_rw_wrlock.c        |  5 +--
 .../tests/psynch_return_contract_test.c       | 31 +++++++++++++++++++
 .../tests/run-psynch-return-contract.sh       | 12 +++++++
 7 files changed, 81 insertions(+), 8 deletions(-)
 create mode 100644 darling/src/libsystem_kernel/emulation/include/xnu_syscall/bsd/impl/psynch/psynch_return.h
 create mode 100644 darling/src/libsystem_kernel/tests/psynch_return_contract_test.c
 create mode 100755 darling/src/libsystem_kernel/tests/run-psynch-return-contract.sh

diff --git a/darling/src/libsystem_kernel/emulation/include/xnu_syscall/bsd/impl/psynch/psynch_return.h b/darling/src/libsystem_kernel/emulation/include/xnu_syscall/bsd/impl/psynch/psynch_return.h
new file mode 100644
index 0000000000000000000000000000000000000000..dd6593c057d7ce7dee319a746df60f9761017667
--- /dev/null
+++ b/darling/src/libsystem_kernel/emulation/include/xnu_syscall/bsd/impl/psynch/psynch_return.h
@@ -0,0 +1,26 @@
+#ifndef DARLING_XNU_SYSCALL_BSD_IMPL_PSYNCH_RETURN_H
+#define DARLING_XNU_SYSCALL_BSD_IMPL_PSYNCH_RETURN_H
+
+#include <stdint.h>
+
+static inline long darling_psynch_wait_error(int error)
+{
+	return -error;
+}
+
+static inline long darling_psynch_wait_return(int result, uint32_t retval)
+{
+	if (!result)
+		return retval;
+
+	/*
+	 * Darling's BSD syscall implementation returns negative errno values to
+	 * the generated public syscall wrapper, which then routes them through
+	 * cerror. Preserve the full psynch result here: condvars may include
+	 * ECVCLEARED/ECVPREPOST status bits above the low-byte errno, and
+	 * libpthread decodes those bits after cerror stores them in errno.
+	 */
+	return darling_psynch_wait_error(result);
+}
+
+#endif
diff --git a/darling/src/libsystem_kernel/emulation/src/xnu_syscall/bsd/impl/psynch/psynch_cvwait.c b/darling/src/libsystem_kernel/emulation/src/xnu_syscall/bsd/impl/psynch/psynch_cvwait.c
index d093b7392fb179a60803a543adc311f4f476fe71..45b9e82917925c18303007fb060b89555ab0b892 100644
--- a/darling/src/libsystem_kernel/emulation/src/xnu_syscall/bsd/impl/psynch/psynch_cvwait.c
+++ b/darling/src/libsystem_kernel/emulation/src/xnu_syscall/bsd/impl/psynch/psynch_cvwait.c
@@ -1,4 +1,5 @@
 #include <darling/emulation/xnu_syscall/bsd/impl/psynch/psynch_cvwait.h>
+#include <darling/emulation/xnu_syscall/bsd/impl/psynch/psynch_return.h>
 
 #include <darling/emulation/common/base.h>
 #include <darling/emulation/linux_premigration/linux-syscalls/linux.h>
@@ -15,11 +16,11 @@ long sys_psynch_cvwait(void* cv, uint64_t cvlsgen, uint32_t cvugen, void * mutex
 
 	if (ret < 0) {
 		if (ret == -LINUX_EINTR) {
-			return -EINTR;
+			return darling_psynch_wait_error(EINTR);
 		}
 		__simple_printf("psynch_cvwait failed internally: %d", ret);
 		__simple_abort();
 	}
 
-	return (ret) ? ret : retval;
+	return darling_psynch_wait_return(ret, retval);
 }
diff --git a/darling/src/libsystem_kernel/emulation/src/xnu_syscall/bsd/impl/psynch/psynch_mutexwait.c b/darling/src/libsystem_kernel/emulation/src/xnu_syscall/bsd/impl/psynch/psynch_mutexwait.c
