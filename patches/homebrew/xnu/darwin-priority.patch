From ccf4c98e0749805ffb864e9e28682ecb91d20be2 Mon Sep 17 00:00:00 2001
From: Ilya Gulya <ilya@gulya.me>
Date: Wed, 8 Jul 2026 11:48:55 +0000
Subject: [PATCH] getpriority/setpriority: handle PRIO_DARWIN_THREAD/PROCESS

Darwin-only priority classes must be handled in emulation instead of being forwarded verbatim to Linux getpriority/setpriority. Accept supported Darwin thread/process values and reject unsupported ones with EINVAL.

Add a host C fixture that stubs the Linux syscall path, checks Darwin classes do not pass through, and proves RED against the source-base tree.
---
 .../bsd/impl/process/getpriority.c            | 13 ++++
 .../bsd/impl/process/setpriority.c            | 21 ++++++
 tests/darwin_priority_contract.c              | 72 +++++++++++++++++++
 3 files changed, 106 insertions(+)
 create mode 100644 tests/darwin_priority_contract.c

diff --git a/darling/src/libsystem_kernel/emulation/src/xnu_syscall/bsd/impl/process/getpriority.c b/darling/src/libsystem_kernel/emulation/src/xnu_syscall/bsd/impl/process/getpriority.c
index a02f1e4cf263423a8cffd62cc88b041653a15bcd..e1adbd421eb5491a9d5638ea77274f0daf24a49c 100644
--- a/darling/src/libsystem_kernel/emulation/src/xnu_syscall/bsd/impl/process/getpriority.c
+++ b/darling/src/libsystem_kernel/emulation/src/xnu_syscall/bsd/impl/process/getpriority.c
@@ -1,6 +1,19 @@
 #include <darling/emulation/xnu_syscall/bsd/impl/process/getpriority.h>
+#include <errno.h>
 
 int sys_getpriority(int which, id_t who) {
+	if (which == PRIO_DARWIN_THREAD) {
+		if (who != 0) {
+			return EINVAL;
+		}
+
+		return 0;
+	}
+
+	if (which == PRIO_DARWIN_PROCESS) {
+		return 0;
+	}
+
 	return LINUX_SYSCALL(__NR_getpriority, which, who);
 
 	// TODO: Errors
diff --git a/darling/src/libsystem_kernel/emulation/src/xnu_syscall/bsd/impl/process/setpriority.c b/darling/src/libsystem_kernel/emulation/src/xnu_syscall/bsd/impl/process/setpriority.c
index ccac110c86f4eea8c95d2f02b23d5edb83956228..8c9e6a4e8a6aa3935119f4f4b631db9fbcb2a58b 100644
--- a/darling/src/libsystem_kernel/emulation/src/xnu_syscall/bsd/impl/process/setpriority.c
+++ b/darling/src/libsystem_kernel/emulation/src/xnu_syscall/bsd/impl/process/setpriority.c
@@ -1,6 +1,27 @@
 #include <darling/emulation/xnu_syscall/bsd/impl/process/setpriority.h>
+#include <errno.h>
 
 int sys_setpriority(int which, int who, int prio) {
+	if (which == PRIO_DARWIN_THREAD) {
+		if (who != 0) {
+			return EINVAL;
+		}
+
+		if (prio == 0 || prio == PRIO_DARWIN_BG || prio == PRIO_DARWIN_NONUI) {
+			return 0;
+		}
+
+		return EINVAL;
+	}
+
+	if (which == PRIO_DARWIN_PROCESS) {
+		if (prio == 0 || prio == PRIO_DARWIN_BG || prio == PRIO_DARWIN_NONUI) {
+			return 0;
+		}
+
+		return EINVAL;
+	}
+
 	return LINUX_SYSCALL(__NR_setpriority, which, who, prio);
 
 	// TODO: Errors
diff --git a/tests/darwin_priority_contract.c b/tests/darwin_priority_contract.c
new file mode 100644
index 0000000000000000000000000000000000000000..0b987e2b74b9f68525d4665b1f508518814998ff
--- /dev/null
+++ b/tests/darwin_priority_contract.c
@@ -0,0 +1,72 @@
+#include <errno.h>
+#include <stdarg.h>
+#include <stdint.h>
+#include <stdio.h>
+
+typedef int id_t;
+#define PRIO_DARWIN_THREAD 3
+#define PRIO_DARWIN_PROCESS 4
+#define PRIO_DARWIN_BG 0x1000
+#define PRIO_DARWIN_NONUI 0x1001
+#define __NR_getpriority 140
+#define __NR_setpriority 141
+
+static int linux_getpriority_calls;
+static int linux_setpriority_calls;
+
+long fake_linux_syscall(long nr, ...)
+{
+	va_list ap;
+	va_start(ap, nr);
+	va_end(ap);
+	if (nr == __NR_getpriority)
+	{
+		linux_getpriority_calls++;
+		return 42;
+	}
+	if (nr == __NR_setpriority)
+	{
+		linux_setpriority_calls++;
+		return 24;
+	}
+	fprintf(stderr, "unexpected syscall %ld\n", nr);
+	return -999;
+}
+
+#define LINUX_SYSCALL(nr, ...) fake_linux_syscall((nr), ##__VA_ARGS__)
+
+#include "getpriority.c"
+#include "setpriority.c"
+
+static int expect(int condition, const char* message)
+{
+	if (!condition)
+	{
+		fprintf(stderr, "%s\n", message);
+		return 1;
+	}
+	return 0;
+}
+
+int main(void)
+{
+	if (expect(sys_getpriority(PRIO_DARWIN_THREAD, 0) == 0, "thread getpriority should be accepted")) return 1;
+	if (expect(sys_getpriority(PRIO_DARWIN_THREAD, 7) == EINVAL, "thread getpriority nonzero who should fail")) return 1;
+	if (expect(sys_getpriority(PRIO_DARWIN_PROCESS, 99) == 0, "process getpriority should be accepted")) return 1;
+	if (expect(linux_getpriority_calls == 0, "Darwin getpriority classes must not reach Linux syscall")) return 1;
+
+	if (expect(sys_setpriority(PRIO_DARWIN_THREAD, 0, 0) == 0, "thread priority 0 should be accepted")) return 1;
+	if (expect(sys_setpriority(PRIO_DARWIN_THREAD, 0, PRIO_DARWIN_BG) == 0, "thread BG should be accepted")) return 1;
+	if (expect(sys_setpriority(PRIO_DARWIN_THREAD, 0, PRIO_DARWIN_NONUI) == 0, "thread NONUI should be accepted")) return 1;
+	if (expect(sys_setpriority(PRIO_DARWIN_THREAD, 1, 0) == EINVAL, "thread nonzero who should fail")) return 1;
+	if (expect(sys_setpriority(PRIO_DARWIN_THREAD, 0, 123) == EINVAL, "thread unknown priority should fail")) return 1;
+	if (expect(sys_setpriority(PRIO_DARWIN_PROCESS, 3, PRIO_DARWIN_BG) == 0, "process BG should be accepted")) return 1;
+	if (expect(sys_setpriority(PRIO_DARWIN_PROCESS, 3, 123) == EINVAL, "process unknown priority should fail")) return 1;
+	if (expect(linux_setpriority_calls == 0, "Darwin setpriority classes must not reach Linux syscall")) return 1;
+
+	if (expect(sys_getpriority(0, 0) == 42, "non-Darwin getpriority should pass through")) return 1;
+	if (expect(sys_setpriority(0, 0, 0) == 24, "non-Darwin setpriority should pass through")) return 1;
+	if (expect(linux_getpriority_calls == 1, "getpriority pass-through count")) return 1;
+	if (expect(linux_setpriority_calls == 1, "setpriority pass-through count")) return 1;
+	return 0;
+}
