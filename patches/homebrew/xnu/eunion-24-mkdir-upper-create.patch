From a6bb8d7f2d446c2c2fca53a7ba3064e3d68d75d5 Mon Sep 17 00:00:00 2001
From: Ilya Gulya <ilya@gulya.me>
Date: Thu, 9 Jul 2026 03:42:00 +0000
Subject: [PATCH] libsystem_kernel: create E-UNION mkdir targets in upper

---
 .../linux_premigration/vchroot_expand.h        |  4 ++++
 .../src/linux_premigration/vchroot_userspace.c | 18 ++++++++++++++++++
 .../src/xnu_syscall/bsd/impl/stat/mkdirat.c    | 18 +++++++++++++-----
 3 files changed, 35 insertions(+), 5 deletions(-)

diff --git a/darling/src/libsystem_kernel/emulation/include/linux_premigration/vchroot_expand.h b/darling/src/libsystem_kernel/emulation/include/linux_premigration/vchroot_expand.h
index d8c5e82d800653ea5260ee8b5f100e2529843660..4b5f6d686b1132c12ebfa1d760652a95dbd37461 100644
--- a/darling/src/libsystem_kernel/emulation/include/linux_premigration/vchroot_expand.h
+++ b/darling/src/libsystem_kernel/emulation/include/linux_premigration/vchroot_expand.h
@@ -88,6 +88,10 @@ int vchroot_prepare_rename_dest(const char* guest);
 // BEFORE a create (mkdir/mknod/mkfifo/symlink): copy up the parent dir so the
 // new entry lands in the upper layer, and clear any whiteout at the new name.
 int vchroot_prepare_create(const char* guest);
+// Same policy as vchroot_prepare_create(), but also returns the host upper path
+// where the create syscall must run. This avoids resolving a lower namesake back
+// to the template after the parent has been prepared.
+int vchroot_prepare_create_path(const char* guest, char* out, int cap);
 int vchroot_post_unlink(const char* guest);
 int vchroot_pre_mkdir(const char* guest);
 #endif // EUNION
diff --git a/darling/src/libsystem_kernel/emulation/src/linux_premigration/vchroot_userspace.c b/darling/src/libsystem_kernel/emulation/src/linux_premigration/vchroot_userspace.c
index 6b41a98c84cd47a9f54e413a31c1054760d1e6b8..0a8c86b8daf164d82f62ab09afcdb593a2e94bcd 100644
--- a/darling/src/libsystem_kernel/emulation/src/linux_premigration/vchroot_userspace.c
+++ b/darling/src/libsystem_kernel/emulation/src/linux_premigration/vchroot_userspace.c
@@ -1170,6 +1170,12 @@ int vchroot_prepare_create(const char* guest)
 {
 	if (!eunion_manage(guest))
 		return 0;
+	if (eunion_is_whiteout(guest))
+	{
+		int r = vchroot_unwhiteout(guest);
+		if (r < 0)
+			return r;
+	}
 	int r = eunion_copyup_parent(guest);
 	if (r < 0)
 		return r;
@@ -1178,6 +1184,18 @@ int vchroot_prepare_create(const char* guest)
 	return 0;
 }
 
+int vchroot_prepare_create_path(const char* guest, char* out, int cap)
+{
+	int r = vchroot_prepare_create(guest);
+	if (r < 0)
+		return r;
+	if (!eunion_manage(guest))
+		return 0;
+	if (eunion_host_path(prefix_path, prefix_path_len, guest, out, cap) < 0)
+		return -LINUX_ENAMETOOLONG;
+	return 1;
+}
+
 // After a successful unlink/rmdir of the upper object: if the name still exists
 // in the lower template, drop a whiteout so it stays deleted. If it was
 // upper-only (absent from lower), do nothing -- the unlink already removed it.
diff --git a/darling/src/libsystem_kernel/emulation/src/xnu_syscall/bsd/impl/stat/mkdirat.c b/darling/src/libsystem_kernel/emulation/src/xnu_syscall/bsd/impl/stat/mkdirat.c
index 8265263fa0fe122c817caeb9107d972b1d3a53bd..6d119ce1708ad0a5e70a0c5053e2a25772c75e7e 100644
--- a/darling/src/libsystem_kernel/emulation/src/xnu_syscall/bsd/impl/stat/mkdirat.c
+++ b/darling/src/libsystem_kernel/emulation/src/xnu_syscall/bsd/impl/stat/mkdirat.c
@@ -27,18 +27,26 @@ long sys_mkdirat(int fd, const char* path, unsigned int mode)
 	// copy up the parent dir (so the new dir lands in the upper layer, not the
 	// shared template) and clear any whiteout at the new name (mkdir over a
 	// previously-deleted name resurrects it).
+	int prepared_create_path = 0;
 	if (path[0] == '/') {
-		int wr = vchroot_prepare_create(path);
+		int wr = vchroot_prepare_create_path(path, vc.path, sizeof(vc.path));
 		if (wr < 0)
 			return errno_linux_to_bsd(wr);
+		prepared_create_path = wr > 0;
 	}
 #endif
 
-	strcpy(vc.path, path);
+#ifdef EUNION
+	if (!prepared_create_path) {
+#endif
+		strcpy(vc.path, path);
 
-	ret = vchroot_expand(&vc);
-	if (ret < 0)
-		return errno_linux_to_bsd(ret);
+		ret = vchroot_expand(&vc);
+		if (ret < 0)
+			return errno_linux_to_bsd(ret);
+#ifdef EUNION
+	}
+#endif
 
 	ret = LINUX_SYSCALL(__NR_mkdirat, vc.dfd, vc.path, mode);
 
