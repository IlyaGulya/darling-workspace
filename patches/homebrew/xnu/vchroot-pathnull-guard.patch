diff --git a/darling/src/libsystem_kernel/emulation/src/xnu_syscall/bsd/impl/stat/lstat.c b/darling/src/libsystem_kernel/emulation/src/xnu_syscall/bsd/impl/stat/lstat.c
index 0e86a8151a91381ea00d92d93a601ca44b87250a..8f7ba58a3e5553432dc5708c6315b00bdb7cd508 100644
--- a/darling/src/libsystem_kernel/emulation/src/xnu_syscall/bsd/impl/stat/lstat.c
+++ b/darling/src/libsystem_kernel/emulation/src/xnu_syscall/bsd/impl/stat/lstat.c
@@ -54,9 +54,12 @@ long sys_lstat64(const char* path, struct stat64* stat)
 	struct linux_stat lstat;
 	struct vchroot_expand_args vc;
 
+	if (!path)
+		return -EFAULT;
+
 	vc.flags = 0;
 	vc.dfd = get_perthread_wd();
-	
+
 	strcpy(vc.path, path);
 
 	ret = vchroot_expand(&vc);
