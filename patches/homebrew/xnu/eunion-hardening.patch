diff --git a/darling/src/libsystem_kernel/emulation/include/linux_premigration/eunion_resolver.h b/darling/src/libsystem_kernel/emulation/include/linux_premigration/eunion_resolver.h
new file mode 100644
index 0000000000000000000000000000000000000000..e0986fb78de35629ad733592cab2598a3ea423d7
--- /dev/null
+++ b/darling/src/libsystem_kernel/emulation/include/linux_premigration/eunion_resolver.h
@@ -0,0 +1,55 @@
+#ifndef _EUNION_RESOLVER_H
+#define _EUNION_RESOLVER_H
+
+#include <stddef.h>
+
+#define EUNION_RESOLVER_PATH_MAX 4096
+
+enum eunion_resolver_layer {
+	EUNION_RESOLVER_UPPER,
+	EUNION_RESOLVER_LOWER,
+	EUNION_RESOLVER_WHITEOUT,
+	EUNION_RESOLVER_MISSING,
+	EUNION_RESOLVER_ERROR,
+};
+
+// Filesystem callbacks return zero for a present path, `missing_status` when
+// absent, and a negative domain error for every other failure. Marker callbacks
+// return one when present, zero when absent, or a negative domain error.
+struct eunion_resolver_ops {
+	int (*path_status)(void* context, const char* host_path);
+	int (*marker_status)(void* context, const char* host_path, const char* marker);
+};
+
+struct eunion_resolver {
+	const char* upper_root;
+	const char* lower_root;
+	const char* whiteout_marker;
+	const char* opaque_marker;
+	int missing_status;
+	void* context;
+	struct eunion_resolver_ops ops;
+};
+
+struct eunion_resolver_result {
+	enum eunion_resolver_layer layer;
+	int error;
+	char host_path[EUNION_RESOLVER_PATH_MAX];
+};
+
+// Resolve one absolute guest path component-wise. The caller supplies the
+// current guest prefix (for example, /System or /System/Library) and keeps
+// walking after an upper/lower result. Upper wins; whiteout is distinct from a
+// missing path so callers can stop before case-fold lookup; an opaque parent
+// hides lower; non-absence filesystem errors are returned without fallback.
+int eunion_resolve_path(const struct eunion_resolver* resolver,
+	const char* guest_path, struct eunion_resolver_result* result);
+
+// Convert a host path rooted in either union layer back to its guest path. If
+// roots are nested, the longest matching root wins so a lower path is never
+// mistaken for a path inside the upper layer. Returns zero on success, one when
+// the host path is outside both roots, or -1 for invalid/oversized input.
+int eunion_guest_path_from_host(const struct eunion_resolver* resolver,
+	const char* host_path, char* guest_path, size_t guest_path_cap);
+
+#endif
diff --git a/darling/src/libsystem_kernel/emulation/include/linux_premigration/vchroot_expand.h b/darling/src/libsystem_kernel/emulation/include/linux_premigration/vchroot_expand.h
index 89519268259e4017349aab0c999c29410a86bfe0..4b5f6d686b1132c12ebfa1d760652a95dbd37461 100644
--- a/darling/src/libsystem_kernel/emulation/include/linux_premigration/vchroot_expand.h
+++ b/darling/src/libsystem_kernel/emulation/include/linux_premigration/vchroot_expand.h
@@ -29,9 +29,24 @@ int vchroot_fdpath(struct vchroot_fdpath_args* args);
 // E-UNION: writable-upper / read-only-lower union by path translation.
 // Copy-up / whiteout / opaque / merged-readdir primitives.
 int vchroot_copyup(const char* guest);
+// Recursive copy-up of a guest subtree (node + ALL descendants). Use for rename
+// of a lower-only directory, where the lazy dir-merge no longer applies after
+// the host moves the upper dir and whiteouts the source.
+int vchroot_copyup_tree(const char* guest);
 int vchroot_whiteout(const char* guest);
 int vchroot_unwhiteout(const char* guest);
 int vchroot_set_opaque(const char* guest);
+// AFTER a successful mkdir over a name that shadows a LOWER directory: mark the
+// new upper dir opaque so the stale lower children are not re-merged (delete-
+// recreate of a populated dir must not resurrect its old contents). No-op when
+// the name has no lower directory namesake. Call from the mkdir site after the
+// host mkdir returns success.
+int vchroot_post_mkdir(const char* guest);
+// Marker-namespace isolation: 1 if `name` is in the reserved `user.union.*`
+// overlay-private namespace. The xattr syscall sites use this to reject guest
+// attempts to forge a marker (setxattr/removexattr -> EPERM) and to hide markers
+// from the guest (getxattr -> ENOATTR, listxattr -> filtered out).
+int vchroot_xattr_is_marker(const char* name);
 int vchroot_readdir_merge(const char* guest, char* out, int cap);
 // Paged merged getdents for getdirentries (per-fd state); vchroot_dir_closed
 // MUST be called from close()/closedir() so the per-fd state is freed.
@@ -42,6 +57,41 @@ void vchroot_dir_closed(int fd);
 //   vchroot_post_unlink(guest)   AFTER a successful unlink/rmdir;
 //   vchroot_pre_mkdir(guest)     BEFORE re-creating a possibly-deleted name.
 int vchroot_prepare_write(const char* guest);
+// *at() variant: resolve a dirfd-relative target to a guest-absolute path via
+// the dirfd, then prepare_write. For openat/mkdirat/etc. with a relative path.
+int vchroot_prepare_write_at(int dfd, const char* rel);
+// fd variant for metadata ops (fchmod/futimes/fsetxattr) on a possibly-lower fd:
+// recovers the fd's guest path, copies it up, returns the guest path in `out`
+// (len > 0) so the caller can re-open the upper copy. 0 = not union-managed.
+int vchroot_prepare_write_fd(int fd, char* out, int cap);
+// High-level fd-metadata helper: copy up the fd's object if lower-only and return
+// a FRESH fd on the upper copy (caller applies the metadata op to it and closes
+// it). Returns the ORIGINAL fd unchanged if unmanaged/escape/no-copyup (caller
+// keeps using it, does not close it), or a negative errno. Used by fchmod/
+// fchmod_extended/futimes/fsetxattr/fremovexattr.
+int vchroot_fd_for_meta_write(int fd);
+// High-level helper for CONTENT-mutating fd ops (ftruncate): like
+// vchroot_fd_for_meta_write but the returned fd is opened O_RDWR (ftruncate needs
+// a writable fd; an O_RDONLY fd yields EINVAL). Returns the original fd if
+// unmanaged, or a negative errno.
+int vchroot_fd_for_content_write(int fd);
+// BEFORE unlink/rmdir: decide policy and tell the caller whether to run the host
+// delete. The lower template is shared+live (not RO), so a lower-only name must
+// be hidden with a whiteout, never deleted on disk.
+#define VCHROOT_UNLINK_PROCEED 0  // caller runs the host delete
+#define VCHROOT_UNLINK_SKIP    1  // caller must NOT delete (whiteout already set)
+int vchroot_prepare_unlink(const char* guest);
+// BEFORE a rename destination is committed: copy up the dest's parent dir and
+// whiteout a lower-only dest namesake, so the host rename lands in the upper
+// layer and never moves into / overwrites the shared template.
+int vchroot_prepare_rename_dest(const char* guest);
+// BEFORE a create (mkdir/mknod/mkfifo/symlink): copy up the parent dir so the
+// new entry lands in the upper layer, and clear any whiteout at the new name.
+int vchroot_prepare_create(const char* guest);
+// Same policy as vchroot_prepare_create(), but also returns the host upper path
+// where the create syscall must run. This avoids resolving a lower namesake back
+// to the template after the parent has been prepared.
+int vchroot_prepare_create_path(const char* guest, char* out, int cap);
 int vchroot_post_unlink(const char* guest);
 int vchroot_pre_mkdir(const char* guest);
 #endif // EUNION
diff --git a/darling/src/libsystem_kernel/emulation/src/linux_premigration/eunion_resolver.c b/darling/src/libsystem_kernel/emulation/src/linux_premigration/eunion_resolver.c
new file mode 100644
index 0000000000000000000000000000000000000000..31c89e838880310f4d07e6f8e447a60d8f67a5ab
--- /dev/null
+++ b/darling/src/libsystem_kernel/emulation/src/linux_premigration/eunion_resolver.c
@@ -0,0 +1,173 @@
+#include <linux_premigration/eunion_resolver.h>
+
+#include <string.h>
+
+static int eunion_join(const char* root, const char* guest, char* out, size_t cap)
+{
+	size_t root_len = strlen(root);
+	size_t guest_len = strlen(guest);
+
+	if (root_len + guest_len + 1 > cap)
+		return -1;
+	memcpy(out, root, root_len);
+	memcpy(out + root_len, guest, guest_len + 1);
+	return 0;
+}
+
+static int eunion_parent(const char* guest, char* out, size_t cap)
+{
+	size_t length = strlen(guest);
+
+	while (length > 1 && guest[length - 1] != '/')
+		length--;
+	if (length <= 1)
+		return 0;
+	length--;
+	if (length + 1 > cap)
+		return -1;
+	memcpy(out, guest, length);
+	out[length] = '\0';
+	return 1;
+}
+
+int eunion_guest_path_from_host(const struct eunion_resolver* resolver,
+	const char* host_path, char* guest_path, size_t guest_path_cap)
+{
+	const char* roots[2];
+	const char* selected = NULL;
+	size_t selected_len = 0;
+
+	if (!resolver || !host_path || !guest_path || guest_path_cap == 0 ||
+		!resolver->upper_root)
+		return -1;
+	roots[0] = resolver->upper_root;
+	roots[1] = resolver->lower_root;
+	for (size_t index = 0; index < sizeof(roots) / sizeof(roots[0]); ++index)
+	{
+		if (!roots[index])
+			continue;
+		size_t root_len = strlen(roots[index]);
+		if (root_len == 0 || strncmp(host_path, roots[index], root_len) != 0)
+			continue;
+		if (host_path[root_len] != '\0' && host_path[root_len] != '/')
+			continue;
+		if (root_len > selected_len)
+		{
+			selected = roots[index];
+			selected_len = root_len;
+		}
+	}
+	if (!selected)
+		return 1;
+
+	const char* suffix = host_path + selected_len;
+	if (*suffix == '\0')
+	{
+		if (guest_path_cap < 2)
+			return -1;
+		guest_path[0] = '/';
+		guest_path[1] = '\0';
+		return 0;
+	}
+	if (strlen(suffix) + 1 > guest_path_cap)
+		return -1;
+	strcpy(guest_path, suffix);
+	return 0;
+}
+
+int eunion_resolve_path(const struct eunion_resolver* resolver,
+	const char* guest_path, struct eunion_resolver_result* result)
+{
+	char upper[EUNION_RESOLVER_PATH_MAX];
+	char lower[EUNION_RESOLVER_PATH_MAX];
+	char parent[EUNION_RESOLVER_PATH_MAX];
+	int status;
+
+	if (!resolver || !guest_path || guest_path[0] != '/' || !result ||
+		!resolver->upper_root || !resolver->lower_root ||
+		!resolver->ops.path_status || !resolver->ops.marker_status)
+		return -1;
+	if (eunion_join(resolver->upper_root, guest_path, upper, sizeof(upper)) != 0 ||
+		eunion_join(resolver->lower_root, guest_path, lower, sizeof(lower)) != 0)
+		return -1;
+
+	status = resolver->ops.path_status(resolver->context, upper);
+	if (status == 0)
+	{
+		status = resolver->ops.marker_status(resolver->context, upper,
+			resolver->whiteout_marker);
+		if (status < 0)
+		{
+			result->layer = EUNION_RESOLVER_ERROR;
+			result->error = status;
+			strcpy(result->host_path, upper);
+			return 0;
+		}
+		if (status > 0)
+		{
+			result->layer = EUNION_RESOLVER_WHITEOUT;
+			strcpy(result->host_path, upper);
+			result->error = resolver->missing_status;
+			return 0;
+		}
+		result->layer = EUNION_RESOLVER_UPPER;
+		strcpy(result->host_path, upper);
+		result->error = 0;
+		return 0;
+	}
+	if (status != resolver->missing_status)
+	{
+		result->layer = EUNION_RESOLVER_ERROR;
+		result->error = status;
+		strcpy(result->host_path, upper);
+		return 0;
+	}
+
+	status = eunion_parent(guest_path, parent, sizeof(parent));
+	if (status < 0)
+		return -1;
+	if (status > 0)
+	{
+		char upper_parent[EUNION_RESOLVER_PATH_MAX];
+		if (eunion_join(resolver->upper_root, parent, upper_parent,
+			sizeof(upper_parent)) != 0)
+			return -1;
+		status = resolver->ops.marker_status(resolver->context, upper_parent,
+			resolver->opaque_marker);
+		if (status < 0)
+		{
+			result->layer = EUNION_RESOLVER_ERROR;
+			result->error = status;
+			strcpy(result->host_path, upper);
+			return 0;
+		}
+		if (status > 0)
+		{
+			result->layer = EUNION_RESOLVER_MISSING;
+			strcpy(result->host_path, upper);
+			result->error = resolver->missing_status;
+			return 0;
+		}
+	}
+
+	status = resolver->ops.path_status(resolver->context, lower);
+	if (status == 0)
+	{
+		result->layer = EUNION_RESOLVER_LOWER;
+		strcpy(result->host_path, lower);
+		result->error = 0;
+		return 0;
+	}
+	if (status == resolver->missing_status)
+	{
+		result->layer = EUNION_RESOLVER_MISSING;
+		strcpy(result->host_path, upper);
+		result->error = status;
+		return 0;
+	}
+
+	result->layer = EUNION_RESOLVER_ERROR;
+	result->error = status;
+	strcpy(result->host_path, lower);
+	return 0;
+}
