From 559d6bf31f36f0c28ef609c73346ca1734961fc4 Mon Sep 17 00:00:00 2001
From: Ilya Gulya <ilya@gulya.me>
Date: Sat, 20 Jun 2026 12:21:19 +0000
Subject: [PATCH] DOC E-UNION: warn that un-stubbing chown needs copy-up (PoC,
 doc-only)

fchown/fchownat/lchown are entirely under `#if 0` (return 0, no mutation), so
they are SAFE today. But un-stubbing any of them adds an INSTANT template-
corruption path: the disabled bodies vchroot_expand() / operate on a guest
target that, for a lower-only object, resolves to the SHARED lower template --
so a chown there mutates ownership for ALL prefixes at once.

Add a warning comment to each stub documenting the hazard and the required
copy-up before re-enabling: vchroot_prepare_write_fd(fd) for the fd-based
fchown, vchroot_prepare_write(path) for the path-based fchownat/lchown (with
lchown materializing the LINK, not its target). Doc-only: every added line is a
comment, so the generated code is byte-identical in all build configurations
(no logic, no #ifdef). Not RED-testable (the syscalls are compiled out).

Local experiment under dar-test-infra-sp5.8.4.4.8.

Co-Authored-By: Claude Opus 4.8 (1M context) <noreply@anthropic.com>
---
 .../emulation/src/xnu_syscall/bsd/impl/unistd/fchown.c   | 7 +++++++
 .../emulation/src/xnu_syscall/bsd/impl/unistd/fchownat.c | 9 +++++++++
 .../emulation/src/xnu_syscall/bsd/impl/unistd/lchown.c   | 9 +++++++++
 3 files changed, 25 insertions(+)

diff --git a/darling/src/libsystem_kernel/emulation/src/xnu_syscall/bsd/impl/unistd/fchown.c b/darling/src/libsystem_kernel/emulation/src/xnu_syscall/bsd/impl/unistd/fchown.c
index 1abab55bf69cd62c139f612eeecb890c4342522d..c8f7dba8fa840443351170c0670be4ded22c14a9 100644
--- a/darling/src/libsystem_kernel/emulation/src/xnu_syscall/bsd/impl/unistd/fchown.c
+++ b/darling/src/libsystem_kernel/emulation/src/xnu_syscall/bsd/impl/unistd/fchown.c
@@ -6,6 +6,13 @@
 
 long sys_fchown(int fd, int uid, int gid)
 {
+	// E-UNION HAZARD (dar-test-infra-sp5.8.4.4.8): this stub is SAFE only because
+	// it is disabled (returns 0, no mutation). If it is ever un-stubbed, it becomes
+	// an immediate template-corruption path: fchown() on an fd that still points at
+	// a shared LOWER-template file mutates ownership in the template for ALL
+	// prefixes. Before re-enabling, the fd MUST be copied up first --
+	// vchroot_prepare_write_fd(fd) -- and the chown applied to the returned UPPER
+	// fd, exactly as the fd-metadata syscalls (e.g. fchmod) already do under EUNION.
 #if 0
 	int ret;
 
diff --git a/darling/src/libsystem_kernel/emulation/src/xnu_syscall/bsd/impl/unistd/fchownat.c b/darling/src/libsystem_kernel/emulation/src/xnu_syscall/bsd/impl/unistd/fchownat.c
index c662f3d5129ab4a502c71faa136582aaf1adaee3..a56eef0f52ff7a64c6d29207d4b2077261f14c71 100644
--- a/darling/src/libsystem_kernel/emulation/src/xnu_syscall/bsd/impl/unistd/fchownat.c
+++ b/darling/src/libsystem_kernel/emulation/src/xnu_syscall/bsd/impl/unistd/fchownat.c
@@ -14,6 +14,15 @@ extern char* strcpy(char* dst, const char* src);
 
 long sys_fchownat(int fd, const char* path, int uid, int gid, int flag)
 {
+	// E-UNION HAZARD (dar-test-infra-sp5.8.4.4.8): this stub is SAFE only because
+	// it is disabled (returns 0, no mutation). If it is ever un-stubbed, it becomes
+	// an immediate template-corruption path: the body below vchroot_expand()s the
+	// guest path and chowns it -- but for a lower-only target that expanded path is
+	// the shared LOWER template, so the chown mutates ownership for ALL prefixes.
+	// Before re-enabling, copy the target up first -- vchroot_prepare_write(path)
+	// (path-based copy-up, as the path-based write syscalls already do under EUNION)
+	// -- so vchroot_expand resolves to the writable UPPER copy. Mind AT_SYMLINK_*
+	// flags: copy up the link itself vs its target consistently with `flag`.
 #if 0
 	int ret;
 	struct vchroot_expand_args vc;
diff --git a/darling/src/libsystem_kernel/emulation/src/xnu_syscall/bsd/impl/unistd/lchown.c b/darling/src/libsystem_kernel/emulation/src/xnu_syscall/bsd/impl/unistd/lchown.c
index 029d9a9615a47f95ba7de1dac543e28ef316147c..d013dec465337555dc5a281e3a6a56d8b100a2f1 100644
--- a/darling/src/libsystem_kernel/emulation/src/xnu_syscall/bsd/impl/unistd/lchown.c
+++ b/darling/src/libsystem_kernel/emulation/src/xnu_syscall/bsd/impl/unistd/lchown.c
@@ -10,6 +10,15 @@
 
 long sys_lchown(const char* path, int uid, int gid)
 {
+	// E-UNION HAZARD (dar-test-infra-sp5.8.4.4.8): this stub is SAFE only because
+	// it is disabled (returns 0, no mutation). If it is ever un-stubbed, it becomes
+	// an immediate template-corruption path: the body below vchroot_expand()s the
+	// guest path and lchowns it -- but for a lower-only target that expanded path is
+	// the shared LOWER template, so the chown mutates ownership for ALL prefixes.
+	// Before re-enabling, copy the target up first -- vchroot_prepare_write(path)
+	// (path-based copy-up). Because lchown operates on the symlink itself (no
+	// follow), the copy-up must materialize the LINK in the upper layer, not its
+	// target.
 #if 0
 	int ret;
 	struct vchroot_expand_args vc;
