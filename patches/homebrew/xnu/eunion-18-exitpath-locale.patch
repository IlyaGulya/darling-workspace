From 7c4af0d829b603a28ff0e326e3cf38ca33514f78 Mon Sep 17 00:00:00 2001
From: Ilya Gulya <ilya@gulya.me>
Date: Sat, 20 Jun 2026 12:12:29 +0000
Subject: [PATCH] FIX vchroot_run: drop NULL-locale strncasecmp_l in EXIT_PATH
 check

The EXIT_PATH escape-hatch compare used
  strncasecmp_l(current_path + current_root_len, EXIT_PATH,
                sizeof(EXIT_PATH)-1, LC_C_LOCALE)
with LC_C_LOCALE defined as ((locale_t)NULL). glibc's strncasecmp_l
DEREFERENCES the locale argument the instant the compared bytes match
(it reaches the per-locale case table), so a NULL locale SEGVs precisely
when a guest path equals EXIT_PATH ("/Volumes/SystemRoot") -- i.e. exactly
when the escape hatch is supposed to fire. gcc even warns
'argument 4 null where non-null expected [-Wnonnull]'. Darling's own
libsystem_c may tolerate a NULL "C locale", but the behaviour is undefined
and the build links against the host glibc in the linux_premigration layer.

EXIT_PATH is a pure-ASCII literal, so the case-insensitive match (kept for
HFS+-like case folding of the prefix) needs no locale at all. Replace the
call with a locale-free ASCII case-fold comparator (eunion_ascii_ncasecmp)
and remove the now-dead locale_t / LC_C_LOCALE / strncasecmp_l declarations.

This is a BASELINE fix (outside any #ifdef EUNION): the deref exists with or
without the union feature. Surfaced by the hermetic E-UNION harness, which had
to inject a real C locale and -Wno-nonnull to avoid crashing; both workarounds
are now removed. Mutation-verified (EP1-EP4: always-equal, no-fold, asymmetric
fold all caught). Local experiment under dar-test-infra-sp5.8.4.4.10.

Co-Authored-By: Claude Opus 4.8 (1M context) <noreply@anthropic.com>
---
 .../linux_premigration/vchroot_userspace.c    | 33 +++++++++++++++----
 1 file changed, 26 insertions(+), 7 deletions(-)

diff --git a/darling/src/libsystem_kernel/emulation/src/linux_premigration/vchroot_userspace.c b/darling/src/libsystem_kernel/emulation/src/linux_premigration/vchroot_userspace.c
index cf68e0bab22a5f95daf0cec4168e2c823bd12942..0562aff262ddbd15eba340546556aee1ba957a0e 100644
--- a/darling/src/libsystem_kernel/emulation/src/linux_premigration/vchroot_userspace.c
+++ b/darling/src/libsystem_kernel/emulation/src/linux_premigration/vchroot_userspace.c
@@ -46,16 +46,10 @@ typedef struct stat stat_t;
 
 typedef struct linux_stat stat_t;
 
-struct _xlocale;
-typedef struct _xlocale* locale_t;
-
-#define LC_C_LOCALE ((locale_t)NULL)
-
 extern __SIZE_TYPE__ strlen(const char* s);
 extern char* strcpy(char* dest, const char* src);
 extern int strcmp(const char* str1, const char* str2);
 extern int strncmp(const char* str1, const char* str2, __SIZE_TYPE__ n);
-extern int strncasecmp_l(const char* str1, const char* str2, __SIZE_TYPE__ n, locale_t locale);
 extern int strcasecmp(const char* str1, const char* str2);
 extern char* strcat(char* dest, const char* src);
 extern char *strchr(const char *s, int c);
@@ -1439,6 +1433,28 @@ int vchroot_getdents_merge(int fd, char* out, int cap)
 
 static const char EXIT_PATH[] = "/Volumes/SystemRoot";
 
+// ASCII case-insensitive compare of the first n bytes, with NO dependency on a
+// locale_t. The EXIT_PATH escape-hatch check used strncasecmp_l(..., LC_C_LOCALE)
+// where LC_C_LOCALE is ((locale_t)NULL); glibc's strncasecmp_l DEREFERENCES the
+// locale once the compared bytes match, so a NULL locale SEGVs precisely when the
+// path equals EXIT_PATH. EXIT_PATH is a pure-ASCII literal, so the case-fold (kept
+// because the prefix is matched case-insensitively, like HFS+) needs no locale at
+// all -- fold ASCII A-Z here and avoid the deref entirely. Returns 0 on equal.
+static int eunion_ascii_ncasecmp(const char* a, const char* b, __SIZE_TYPE__ n)
+{
+	for (__SIZE_TYPE__ i = 0; i < n; i++) {
+		unsigned char ca = (unsigned char) a[i];
+		unsigned char cb = (unsigned char) b[i];
+		if (ca >= 'A' && ca <= 'Z') ca = (unsigned char)(ca - 'A' + 'a');
+		if (cb >= 'A' && cb <= 'Z') cb = (unsigned char)(cb - 'A' + 'a');
+		if (ca != cb)
+			return (int) ca - (int) cb;
+		if (ca == '\0')
+			break; // both NUL at the same spot -> equal so far, stop
+	}
+	return 0;
+}
+
 #ifndef TEST
 #ifdef VARIANT_DYLD
 #define icase_enabled false
@@ -1946,7 +1962,10 @@ ignore_symlink:
 
 				if (ctxt->current_root_len > 0 && ctxt->current_path_len - ctxt->current_root_len == sizeof(EXIT_PATH)-1)
 				{
-					if (strncasecmp_l(ctxt->current_path + ctxt->current_root_len, EXIT_PATH, sizeof(EXIT_PATH) - 1, LC_C_LOCALE) == 0)
+					// locale-free ASCII case-fold compare: the old strncasecmp_l(...,
+					// LC_C_LOCALE=NULL) deref'd a NULL locale on glibc the instant the
+					// bytes matched -- i.e. exactly here, when the escape hatch fires.
+					if (eunion_ascii_ncasecmp(ctxt->current_path + ctxt->current_root_len, EXIT_PATH, sizeof(EXIT_PATH) - 1) == 0)
 					{
 						// Switch to the real system root
 						ctxt->current_path[0] = '\0';
