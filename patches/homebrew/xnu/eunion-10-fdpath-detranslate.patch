From 9daa9a4ff2fe30e250b97658d4ebfb8db7f0c2ce Mon Sep 17 00:00:00 2001
From: Ilya Gulya <ilya@gulya.me>
Date: Tue, 16 Jun 2026 02:49:38 +0000
Subject: [PATCH] EXPERIMENT E-UNION: detranslate lower-template fds/paths to
 guest paths (PoC)

vchroot_fdpath() and vchroot_unexpand() only knew the prefix (UPPER layer).
A fd or host path resolving into the read-only LOWER template lives OUTSIDE
the prefix (at libexec_path), so both fell through to the EXIT_PATH escape
hatch and produced a bogus /Volumes/SystemRoot/<host-template-path> guest
path.

This was the launchctl-bootstrap stall: `launchctl bootstrap -S System`
F_GETPATHs the System/Library/LaunchDaemons dir fd (which the union resolves
into the lower template) to build each child plist path. The escape-hatch
base made every plist lookup fail, so launchctl loaded ZERO daemons and then
waited 60s on services that never checked in -> shellspawn never started ->
launcher timed out on var/run/shellspawn.sock.

Fix (both functions, #ifdef EUNION): when the readlink/path result is under
libexec_path, strip it and return the bare guest path, exactly as the existing
prefix_path branch does. Genuinely-out-of-both paths still get EXIT_PATH.

With this, the EUNION zero-copy prefix boots a full guest pipeline in default
unprivileged docker: `darling shell echo HELLO_EUNION` -> HELLO_EUNION, rc=0,
prefix ~572K (vs ~524MB copy-mode). Hermetic suite 76/76 (adds F1-F5 pinning
lower/upper/out-of-both detranslation for both fdpath and unexpand).

Co-Authored-By: Claude Opus 4.8 (1M context) <noreply@anthropic.com>
---
 .../linux_premigration/vchroot_userspace.c    | 36 +++++++++++++++++++
 1 file changed, 36 insertions(+)

diff --git a/darling/src/libsystem_kernel/emulation/src/linux_premigration/vchroot_userspace.c b/darling/src/libsystem_kernel/emulation/src/linux_premigration/vchroot_userspace.c
index 4a3afbee6967647ccb5cf5e8eb134af44972c958..b1e0fcde8f3ac4e12a2ac19013999fcd54aff6bc 100644
--- a/darling/src/libsystem_kernel/emulation/src/linux_premigration/vchroot_userspace.c
+++ b/darling/src/libsystem_kernel/emulation/src/linux_premigration/vchroot_userspace.c
@@ -1407,6 +1407,27 @@ int vchroot_fdpath(struct vchroot_fdpath_args* args)
 		if (args->path[0] == '\0')
 			strcpy(args->path, "/");
 	}
+#ifdef EUNION
+	// E-UNION: a fd may resolve into the read-only LOWER template, which lives
+	// OUTSIDE the prefix (at libexec_path). Detranslate it to the guest path too
+	// -- otherwise it falls through to the EXIT_PATH escape hatch and yields a
+	// bogus /Volumes/SystemRoot/<host-template-path> guest path. launchctl uses
+	// F_GETPATH on the System/Library/LaunchDaemons dir fd (which resolves to the
+	// lower template) to build child plist paths; the escape-hatch path makes
+	// every plist lookup fail, so no daemons load and `bootstrap -S System`
+	// stalls on services that never check in.
+	else if (libexec_path_len > 0 && rv >= libexec_path_len
+	         && strncmp(link, libexec_path, libexec_path_len) == 0
+	         && (link[libexec_path_len] == '/' || link[libexec_path_len] == '\0'))
+	{
+		if (args->maxlen-1 < rv - libexec_path_len)
+			return -LINUX_ENAMETOOLONG;
+		strcpy(args->path, link + libexec_path_len);
+
+		if (args->path[0] == '\0')
+			strcpy(args->path, "/");
+	}
+#endif
 	else
 	{
 		if (args->maxlen < sizeof(EXIT_PATH) + rv)
@@ -1433,6 +1454,21 @@ int vchroot_unexpand(struct vchroot_unexpand_args* args)
 		if (args->path[0] == '\0')
 			strcpy(args->path, "/");
 	}
+#ifdef EUNION
+	// E-UNION: a host path under the read-only LOWER template detranslates to the
+	// guest path too (see vchroot_fdpath). Without this it escapes through
+	// EXIT_PATH to a bogus /Volumes/SystemRoot/<template-path> guest path.
+	else if (libexec_path_len > 0
+	         && memcmp(args->path, libexec_path, libexec_path_len) == 0
+	         && (args->path[libexec_path_len] == '/' || args->path[libexec_path_len] == '\0'))
+	{
+		int bytes = strlen(args->path + libexec_path_len) + 1;
+		memmove(args->path, args->path + libexec_path_len, bytes);
+
+		if (args->path[0] == '\0')
+			strcpy(args->path, "/");
+	}
+#endif
 	else
 	{
 		int bytes = strlen(args->path) + 1;
