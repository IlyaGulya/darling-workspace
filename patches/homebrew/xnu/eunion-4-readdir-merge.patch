From 17c86b8fdfc8efe6b614ad4546a9cfbeea81c90b Mon Sep 17 00:00:00 2001
From: Ilya Gulya <ilya@gulya.me>
Date: Mon, 15 Jun 2026 18:11:39 +0000
Subject: [PATCH] EXPERIMENT E-UNION: readdir-merge in vchroot (PoC, #ifdef
 EUNION)

Adds vchroot_readdir_merge(guest_dir): the merged directory listing for a dir
present in both layers. Modeled on gVisor overlay directory.go getDirentsLocked:

  * list the upper layer first; emit non-whiteout names; a whiteout placeholder
    is NOT surfaced but its name is recorded in a hidden set;
  * if the upper dir is opaque (user.union.opaque), stop -- do not merge lower;
  * list the lower layer; emit names not already seen (upper wins) and not in
    the whiteout set (lower namesake stays hidden);
  * '.'/'..' skipped; dedup across layers; NUL-separated name buffer.

This is the last self-contained union algorithm. Test runner now 46 assertions,
all green and stable across repeated runs (incl. the 16-way copy-up fork race):
read-only union (8) + copy-up (16) + whiteout/opaque (12) + readdir-merge (10).

Still #ifdef EUNION -> production untouched.

Core algorithms complete (resolve, copy-up, whiteout, opaque, readdir). Next:
wire copyup/whiteout into the write-op emulation sites (open-for-write, truncate,
unlink, mkdir, rename, ...) and getdirentries; then build real Darling -DEUNION
and verify full route 2 in default unprivileged docker.

Co-Authored-By: Claude Opus 4.8 (1M context) <noreply@anthropic.com>
---
 .../linux_premigration/vchroot_userspace.c    | 122 ++++++++++++++++++
 1 file changed, 122 insertions(+)

diff --git a/darling/src/libsystem_kernel/emulation/src/linux_premigration/vchroot_userspace.c b/darling/src/libsystem_kernel/emulation/src/linux_premigration/vchroot_userspace.c
index 1900faa7fa29d5af2b7a9dffebea18d9782dc5e7..df2c0c6eea5c2fc32dfbc9f97737a0052b9c232f 100644
--- a/darling/src/libsystem_kernel/emulation/src/linux_premigration/vchroot_userspace.c
+++ b/darling/src/libsystem_kernel/emulation/src/linux_premigration/vchroot_userspace.c
@@ -477,6 +477,128 @@ int vchroot_set_opaque(const char* guest)
 		return -LINUX_ENAMETOOLONG;
 	return eunion_set_marker(up, EUNION_OPAQUE_XATTR);
 }
+
+// helper: append `name` to a NUL-separated out buffer if it fits and is not a
+// duplicate of an already-appended name. Returns 1 if appended, 0 if dup, <0 on
+// overflow.
+static int eunion_emit_name(char* out, int cap, int* used, int* count, const char* name)
+{
+	// dedup against already-emitted names
+	const char* p = out;
+	for (int i = 0; i < *count; i++)
+	{
+		if (strcmp(p, name) == 0)
+			return 0;
+		p += strlen(p) + 1;
+	}
+	int nlen = (int)strlen(name) + 1;
+	if (*used + nlen > cap)
+		return -LINUX_ENAMETOOLONG;
+	memcpy(out + *used, name, nlen);
+	*used += nlen;
+	(*count)++;
+	return 1;
+}
+
+// is `name` present in a NUL-separated set of `n` names?
+static int name_in_set(const char* buf, int n, const char* name)
+{
+	const char* p = buf;
+	for (int i = 0; i < n; i++)
+	{
+		if (strcmp(p, name) == 0)
+			return 1;
+		p += strlen(p) + 1;
+	}
+	return 0;
+}
+
+// Produce the merged directory listing for guest dir `guest` as a NUL-separated
+// list of names in `out`. Upper layer wins on name clash; whiteouts hide the
+// lower namesake; an opaque upper dir is not merged with the lower. Returns the
+// number of names, or a negative Linux errno.
+int vchroot_readdir_merge(const char* guest, char* out, int cap)
+{
+	if (prefix_path_len < 0)
+		return -LINUX_ENOENT;
+
+	int used = 0, count = 0;
+
+	char up[4096], lo[4096];
+	int have_upper = (eunion_host_path(prefix_path, prefix_path_len, guest, up, sizeof(up)) >= 0);
+
+	// 1. upper layer: emit non-whiteout names; record whiteout names so the
+	//    lower namesake is suppressed (tracked in a separate seen-set).
+	char whbuf[4096]; int whused = 0, whcount = 0;
+	if (have_upper)
+	{
+		int dfd = LINUX_SYSCALL(__NR_openat, LINUX_AT_FDCWD, up, LINUX_O_RDONLY | LINUX_O_DIRECTORY, 0);
+		if (dfd >= 0)
+		{
+			char dirents[8192];
+			int len;
+			while ((len = LINUX_SYSCALL(__NR_getdents64, dfd, dirents, sizeof(dirents))) > 0)
+			{
+				int pos = 0;
+				while (pos < len)
+				{
+					struct linux_dirent64* de = (struct linux_dirent64*) &dirents[pos];
+					pos += de->d_reclen;
+					const char* nm = de->d_name;
+					if (nm[0] == '.' && (nm[1] == '\0' || (nm[1] == '.' && nm[2] == '\0')))
+						continue;
+
+					char child[4096];
+					int hl = (int)strlen(up), nl = (int)strlen(nm);
+					if (hl + 1 + nl + 1 > (int)sizeof(child))
+						continue;
+					memcpy(child, up, hl); child[hl] = '/'; memcpy(child + hl + 1, nm, nl + 1);
+
+					if (eunion_has_marker(child, EUNION_WH_XATTR))
+						eunion_emit_name(whbuf, sizeof(whbuf), &whused, &whcount, nm); // hidden
+					else
+						eunion_emit_name(out, cap, &used, &count, nm); // visible upper entry
+				}
+			}
+			LINUX_SYSCALL(__NR_close, dfd);
+		}
+
+		// 2. opaque upper dir -> do not merge lower
+		if (eunion_has_marker(up, EUNION_OPAQUE_XATTR))
+			return count;
+	}
+
+	// 3. lower layer: emit names not already visible (upper wins) and not
+	//    whited-out.
+	if (libexec_path_len > 0 && eunion_host_path(libexec_path, libexec_path_len, guest, lo, sizeof(lo)) >= 0)
+	{
+		int dfd = LINUX_SYSCALL(__NR_openat, LINUX_AT_FDCWD, lo, LINUX_O_RDONLY | LINUX_O_DIRECTORY, 0);
+		if (dfd >= 0)
+		{
+			char dirents[8192];
+			int len;
+			while ((len = LINUX_SYSCALL(__NR_getdents64, dfd, dirents, sizeof(dirents))) > 0)
+			{
+				int pos = 0;
+				while (pos < len)
+				{
+					struct linux_dirent64* de = (struct linux_dirent64*) &dirents[pos];
+					pos += de->d_reclen;
+					const char* nm = de->d_name;
+					if (nm[0] == '.' && (nm[1] == '\0' || (nm[1] == '.' && nm[2] == '\0')))
+						continue;
+					// suppressed by a whiteout in the upper?
+					if (name_in_set(whbuf, whcount, nm))
+						continue;
+					eunion_emit_name(out, cap, &used, &count, nm);
+				}
+			}
+			LINUX_SYSCALL(__NR_close, dfd);
+		}
+	}
+
+	return count;
+}
 #endif
 
 static const char EXIT_PATH[] = "/Volumes/SystemRoot";
