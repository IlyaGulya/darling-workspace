From 8a7797fd85b1522a528551fc9601b245c083b8e8 Mon Sep 17 00:00:00 2001
From: Ilya Gulya <ilya@gulya.me>
Date: Wed, 10 Jun 2026 10:06:33 +0000
Subject: [PATCH] psynch: fix cvsignal/cvbroad argument widths and cvbroad
 mutex arg

sys_psynch_cvsignal passed cvlsgen/mugen as uint32_t, truncating the
64-bit generation-count words the RPC expects; widen both to uint64_t.
sys_psynch_cvbroad passed mugen where the mutex pointer belongs, so the
server never saw the condvar's associated mutex; pass mutex.
---
 .../include/xnu_syscall/bsd/impl/psynch/psynch_cvsignal.h       | 2 +-
 .../emulation/src/xnu_syscall/bsd/impl/psynch/psynch_cvbroad.c  | 2 +-
 .../emulation/src/xnu_syscall/bsd/impl/psynch/psynch_cvsignal.c | 2 +-
 3 files changed, 3 insertions(+), 3 deletions(-)

diff --git a/darling/src/libsystem_kernel/emulation/include/xnu_syscall/bsd/impl/psynch/psynch_cvsignal.h b/darling/src/libsystem_kernel/emulation/include/xnu_syscall/bsd/impl/psynch/psynch_cvsignal.h
index 35e1ca1..48826e9 100644
--- a/darling/src/libsystem_kernel/emulation/include/xnu_syscall/bsd/impl/psynch/psynch_cvsignal.h
+++ b/darling/src/libsystem_kernel/emulation/include/xnu_syscall/bsd/impl/psynch/psynch_cvsignal.h
@@ -3,7 +3,7 @@
 
 #include <stdint.h>
 
-long sys_psynch_cvsignal(void* cv, uint32_t cvlsgen, uint32_t cvugen, int thread_port, void* mutex, uint32_t mugen,
+long sys_psynch_cvsignal(void* cv, uint64_t cvlsgen, uint32_t cvugen, int thread_port, void* mutex, uint64_t mugen,
 		uint64_t tid, uint32_t flags);
 
 #endif // LINUX_PSYNCH_CVSIGNAL_H
diff --git a/darling/src/libsystem_kernel/emulation/src/xnu_syscall/bsd/impl/psynch/psynch_cvbroad.c b/darling/src/libsystem_kernel/emulation/src/xnu_syscall/bsd/impl/psynch/psynch_cvbroad.c
index 997b2a8..f2dae28 100644
--- a/darling/src/libsystem_kernel/emulation/src/xnu_syscall/bsd/impl/psynch/psynch_cvbroad.c
+++ b/darling/src/libsystem_kernel/emulation/src/xnu_syscall/bsd/impl/psynch/psynch_cvbroad.c
@@ -10,7 +10,7 @@ long sys_psynch_cvbroad(void* cv, uint64_t cvlsgen, uint64_t cvudgen, uint32_t f
 		uint64_t tid)
 {
 	uint32_t retval;
-	int ret = dserver_rpc_psynch_cvbroad(cv, cvlsgen, cvudgen, flags, mugen, mugen, tid, &retval);
+	int ret = dserver_rpc_psynch_cvbroad(cv, cvlsgen, cvudgen, flags, mutex, mugen, tid, &retval);
 
 	if (ret < 0) {
 		__simple_printf("psynch_cvbroad failed internally: %d", ret);
diff --git a/darling/src/libsystem_kernel/emulation/src/xnu_syscall/bsd/impl/psynch/psynch_cvsignal.c b/darling/src/libsystem_kernel/emulation/src/xnu_syscall/bsd/impl/psynch/psynch_cvsignal.c
index a11c77c..53cdb04 100644
--- a/darling/src/libsystem_kernel/emulation/src/xnu_syscall/bsd/impl/psynch/psynch_cvsignal.c
+++ b/darling/src/libsystem_kernel/emulation/src/xnu_syscall/bsd/impl/psynch/psynch_cvsignal.c
@@ -6,7 +6,7 @@
 
 #include <darlingserver/rpc.h>
 
-long sys_psynch_cvsignal(void* cv, uint32_t cvlsgen, uint32_t cvugen, int thread_port, void* mutex, uint32_t mugen,
+long sys_psynch_cvsignal(void* cv, uint64_t cvlsgen, uint32_t cvugen, int thread_port, void* mutex, uint64_t mugen,
 		uint64_t tid, uint32_t flags)
 {
 	uint32_t retval;
-- 
2.43.0

