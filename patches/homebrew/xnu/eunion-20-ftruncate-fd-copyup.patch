From d5e8efb03497030714126778058ac24778f4ed2c Mon Sep 17 00:00:00 2001
From: Ilya Gulya <ilya@gulya.me>
Date: Sat, 20 Jun 2026 12:37:17 +0000
Subject: [PATCH] EXPERIMENT E-UNION: ftruncate fd copy-up (missed fd-write
 site) (PoC, #ifdef EUNION)

A full 216-file write-op audit of vchroot template protection found one
unprotected mutating site: sys_ftruncate hit __NR_ftruncate on the raw fd with
no copy-up. ftruncate mutates file CONTENT by descriptor -- structurally the
same class as the fd-metadata syscalls protected in dar-test-infra-sp5.8.4.4.4
(fchmod/fchmod_extended/futimes/fsetxattr/fremovexattr) but omitted from that
set. A writable fd on a lower-only (shared template) inode obtained outside the
protected write-open would let ftruncate shrink the template for ALL prefixes.

ftruncate differs from the .4 metadata ops in one way: it REQUIRES a writable
fd (an O_RDONLY fd yields EINVAL), whereas fchmod/utimensat/fsetxattr check
inode perms and work on the meta-write helper's O_RDONLY fd. So this adds a
sibling helper vchroot_fd_for_content_write(fd): identical copy-up to
vchroot_fd_for_meta_write but re-opens the upper copy O_RDWR. The existing .4
helper is left untouched (its O_RDONLY contract stays proven). sys_ftruncate is
wired to it under #ifdef EUNION; the #else path is the original (OFF
byte-identical -- verified: all additions in vchroot_userspace.c sit inside the
file's #ifdef EUNION block; ftruncate.c EUNION branch only, vchroot_expand.h
include is the same unconditional-decl pattern .4's fchmod.c/futimes.c use).

TDD: FT test (RED on the stub helper -> no upper copy, RO fd) -> GREEN. Mutation
audit: content helper opening O_RDONLY (the original bug) drives FT RED
(ftruncate EINVAL, upper not truncated); no-copy-up stub drives the DIFFERENT-fd
+ template-safety asserts RED. Hermetic suite 214 -> 222, 0 failed.

Local experiment under dar-test-infra-sp5.8.4.4.11.

Co-Authored-By: Claude Opus 4.8 (1M context) <noreply@anthropic.com>
---
 .../linux_premigration/vchroot_expand.h       |  5 +++
 .../linux_premigration/vchroot_userspace.c    | 40 +++++++++++++++++++
 .../xnu_syscall/bsd/impl/unistd/ftruncate.c   | 19 +++++++++
 3 files changed, 64 insertions(+)

diff --git a/darling/src/libsystem_kernel/emulation/include/linux_premigration/vchroot_expand.h b/darling/src/libsystem_kernel/emulation/include/linux_premigration/vchroot_expand.h
index d10ed59c67a42457645c692ea3e6e7e502815106..d8c5e82d800653ea5260ee8b5f100e2529843660 100644
--- a/darling/src/libsystem_kernel/emulation/include/linux_premigration/vchroot_expand.h
+++ b/darling/src/libsystem_kernel/emulation/include/linux_premigration/vchroot_expand.h
@@ -70,6 +70,11 @@ int vchroot_prepare_write_fd(int fd, char* out, int cap);
 // keeps using it, does not close it), or a negative errno. Used by fchmod/
 // fchmod_extended/futimes/fsetxattr/fremovexattr.
 int vchroot_fd_for_meta_write(int fd);
+// High-level helper for CONTENT-mutating fd ops (ftruncate): like
+// vchroot_fd_for_meta_write but the returned fd is opened O_RDWR (ftruncate needs
+// a writable fd; an O_RDONLY fd yields EINVAL). Returns the original fd if
+// unmanaged, or a negative errno.
+int vchroot_fd_for_content_write(int fd);
 // BEFORE unlink/rmdir: decide policy and tell the caller whether to run the host
 // delete. The lower template is shared+live (not RO), so a lower-only name must
 // be hidden with a whiteout, never deleted on disk.
diff --git a/darling/src/libsystem_kernel/emulation/src/linux_premigration/vchroot_userspace.c b/darling/src/libsystem_kernel/emulation/src/linux_premigration/vchroot_userspace.c
index 0562aff262ddbd15eba340546556aee1ba957a0e..fa504996ba1b091b6747d3a2f7a572d056792f21 100644
--- a/darling/src/libsystem_kernel/emulation/src/linux_premigration/vchroot_userspace.c
+++ b/darling/src/libsystem_kernel/emulation/src/linux_premigration/vchroot_userspace.c
@@ -862,6 +862,9 @@ int vchroot_prepare_write_fd(int fd, char* out, int cap)
 #ifndef LINUX_O_NOFOLLOW
 #define LINUX_O_NOFOLLOW 0400000 // Linux O_NOFOLLOW (x86); re-open the object itself
 #endif
+#ifndef LINUX_O_RDWR
+#define LINUX_O_RDWR 02 // Linux O_RDWR; for content-mutating fd ops (ftruncate)
+#endif
 // High-level helper for the fd-metadata syscall sites (fchmod/fchmod_extended/
 // futimes/fsetxattr/fremovexattr). A metadata op on an fd has no path, so if the
 // fd was opened on a lower-only object the op hits the SHARED template. This
@@ -914,6 +917,43 @@ int vchroot_fd_for_meta_write(int fd)
 	return nfd;            // != fd: caller applies the op to nfd and closes it
 }
 
+// High-level helper for CONTENT-mutating fd ops (ftruncate). Identical to
+// vchroot_fd_for_meta_write but re-opens the upper copy O_RDWR: unlike fchmod/
+// utimensat/fsetxattr (which only check inode perms and work on an O_RDONLY fd),
+// ftruncate REQUIRES a writable fd (an O_RDONLY fd yields EINVAL). Copy up the
+// fd's object if lower-only and hand back a FRESH writable fd on the upper copy
+// (caller applies the op and closes it). Returns the ORIGINAL fd unchanged if
+// unmanaged/escape/no-copyup, or a negative errno.
+int vchroot_fd_for_content_write(int fd)
+{
+	char guest[4096];
+	int r = vchroot_prepare_write_fd(fd, guest, sizeof(guest));
+	if (r < 0)
+		return r;          // negative errno
+	if (r == 0)
+		return fd;         // unmanaged / escape / no path: use the original fd
+
+	// Copied up; guest now resolves to the UPPER copy. Re-open it O_RDWR so the
+	// caller's content op (ftruncate) has a writable fd. O_NOFOLLOW so we mutate
+	// the object itself, never a symlink target.
+	struct vchroot_expand_args vc;
+	vc.flags = 0;          // do not follow the final symlink
+	vc.dfd = -100;         // AT_FDCWD-equivalent; guest is absolute
+	int gl = (int)strlen(guest);
+	if (gl + 1 > (int)sizeof(vc.path))
+		return -LINUX_ENAMETOOLONG;
+	memcpy(vc.path, guest, gl + 1);
+	int er = vchroot_expand(&vc);
+	if (er < 0)
+		return er;
+
+	int nfd = LINUX_SYSCALL(__NR_openat, LINUX_AT_FDCWD, vc.path,
+		LINUX_O_RDWR | LINUX_O_NOFOLLOW, 0);
+	if (nfd < 0)
+		return nfd;
+	return nfd;            // != fd: caller applies the op to nfd and closes it
+}
+
 // BEFORE an unlink/rmdir: decide the union policy and tell the caller whether to
 // run the host delete syscall. The lower template is a SHARED live directory
 // (not a read-only mount), so a delete that reaches a lower host path would
diff --git a/darling/src/libsystem_kernel/emulation/src/xnu_syscall/bsd/impl/unistd/ftruncate.c b/darling/src/libsystem_kernel/emulation/src/xnu_syscall/bsd/impl/unistd/ftruncate.c
index 67ed554d8415ddb39b3c62cd1109be628be04d14..0c56ec73a7ff03dec67e5878a523a61c83904402 100644
--- a/darling/src/libsystem_kernel/emulation/src/xnu_syscall/bsd/impl/unistd/ftruncate.c
+++ b/darling/src/libsystem_kernel/emulation/src/xnu_syscall/bsd/impl/unistd/ftruncate.c
@@ -3,15 +3,34 @@
 #include <darling/emulation/common/base.h>
 #include <darling/emulation/conversion/errno.h>
 #include <darling/emulation/linux_premigration/linux-syscalls/linux.h>
+#include <darling/emulation/linux_premigration/vchroot_expand.h>
 
 long sys_ftruncate(int fd, long long length)
 {
 	int ret;
 
+#ifdef EUNION
+	// E-UNION: ftruncate mutates file CONTENT by descriptor. If `fd` was opened on
+	// a lower-only object, truncating via the fd would shrink the SHARED template.
+	// Copy it up and operate on a fresh WRITABLE fd targeting the upper copy
+	// (ftruncate needs O_RDWR -- the meta-write helper's O_RDONLY fd would EINVAL).
+	// Returns the original fd if unmanaged.
+	int wfd = vchroot_fd_for_content_write(fd);
+	if (wfd < 0)
+		return errno_linux_to_bsd(wfd);
+#ifdef __NR_ftruncate64
+	ret = LINUX_SYSCALL(__NR_ftruncate64, wfd, LL_ARG(length));
+#else
+	ret = LINUX_SYSCALL(__NR_ftruncate, wfd, LL_ARG(length));
+#endif
+	if (wfd != fd)
+		LINUX_SYSCALL(__NR_close, wfd);
+#else
 #ifdef __NR_ftruncate64
 	ret = LINUX_SYSCALL(__NR_ftruncate64, fd, LL_ARG(length));
 #else
 	ret = LINUX_SYSCALL(__NR_ftruncate, fd, LL_ARG(length));
+#endif
 #endif
 	if (ret < 0)
 		ret = errno_linux_to_bsd(ret);
