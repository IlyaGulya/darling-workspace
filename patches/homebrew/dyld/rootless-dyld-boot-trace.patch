From: Ilya Gulya <ilya@gulya.me>
Date: Sat, 11 Jul 2026 10:05:04 +0000
Subject: [PATCH] dyld: enable rootless trace at bootstrap entry

---
 src/dyldInitialization.cpp | 5 ++++-
 1 file changed, 4 insertions(+), 1 deletion(-)

diff --git a/src/dyldInitialization.cpp b/src/dyldInitialization.cpp
index 450021e69c3b3f1ffa3896124357d2f38509886b..aa3d29141d5129602d07c8e97d521d141ddb60d5 100644
--- a/src/dyldInitialization.cpp
+++ b/src/dyldInitialization.cpp
@@ -53,7 +53,7 @@ const dyld::SyscallHelpers* gSyscallHelpers = NULL;
 #ifdef DARLING
 static int rootlessBootTraceFD(const char* const envp[])
 {
-	static const char rootlessPrefix[] = "DARLING_ROOTLESS_INIT=1";
+	static const char rootlessPrefix[] = "DARLING_ROOTLESS=1";
 	static const char tracePrefix[] = "DARLING_BOOT_TRACE_FD=";
 	bool rootless = false;
 	int fd = -1;
@@ -180,14 +180,17 @@ uintptr_t start(const dyld3::MachOLoaded* appsMachHeader, int argc, const char*
 				const dyld3::MachOLoaded* dyldsMachHeader, uintptr_t* startGlue)
 {
 
+#ifndef DARLING
     // Emit kdebug tracepoint to indicate dyld bootstrap has started <rdar://46878536>
     dyld3::kdebug_trace_dyld_marker(DBG_DYLD_TIMING_BOOTSTRAP_START, 0, 0, 0, 0);
+#endif
 
 	// kernel sets up env pointer to be just past end of agv array
 	const char** envp = &argv[argc+1];
 
 #ifdef DARLING
 	const int rootlessTraceFD = rootlessBootTraceFD(envp);
+	rootlessBootTrace(rootlessTraceFD, "dyld bootstrap-enter\n");
 #endif
 
 #ifndef DARLING

From 7f98ce668fa0356b0b6efb6bec88581a66fd64d2 Mon Sep 17 00:00:00 2001
From: Ilya Gulya <ilya@gulya.me>
Date: Sat, 11 Jul 2026 10:20:45 +0000
Subject: [PATCH] dyld: use raw write for rootless boot trace

---
 src/dyldInitialization.cpp | 40 ++++++++++++++++++++++++++++++--------
 1 file changed, 32 insertions(+), 8 deletions(-)

diff --git a/src/dyldInitialization.cpp b/src/dyldInitialization.cpp
index aa3d29141d5129602d07c8e97d521d141ddb60d5..f265ad11f5cfca84b9ea4276a800598952c3be5f 100644
--- a/src/dyldInitialization.cpp
+++ b/src/dyldInitialization.cpp
@@ -88,12 +88,36 @@ static int rootlessBootTraceFD(const char* const envp[])
 	return rootless ? fd : -1;
 }
 
-static void rootlessBootTrace(int fd, const char* stage)
+static void rootlessBootTrace(int fd, const char* stage, size_t stageLength)
 {
 	if (fd < 0)
 		return;
-	(void)::write(fd, stage, strlen(stage));
+
+#if defined(__x86_64__)
+	long result;
+	__asm__ volatile(
+		"syscall"
+		: "=a"(result)
+		: "a"(1L), "D"((long)fd), "S"(stage), "d"(stageLength)
+		: "rcx", "r11", "memory"
+	);
+	(void)result;
+#elif defined(__aarch64__)
+	register long x0 __asm__("x0") = fd;
+	register const char* x1 __asm__("x1") = stage;
+	register size_t x2 __asm__("x2") = stageLength;
+	register long x8 __asm__("x8") = 64;
+	__asm__ volatile("svc 0" : "+r"(x0) : "r"(x1), "r"(x2), "r"(x8) : "memory");
+#else
+	(void)stage;
+	(void)stageLength;
+#endif
 }
+
+#define ROOTLESS_BOOT_TRACE(fd, stage) \
+	do { \
+		rootlessBootTrace((fd), (stage), sizeof(stage) - 1); \
+	} while (0)
 #endif
 
 
@@ -153,9 +177,9 @@ static void rebaseDyld(const dyld3::MachOLoaded* dyldMH)
 
     // now that rebasing done, initialize mach/syscall layer
 #ifdef DARLING
-    rootlessBootTrace(rootlessTraceFD, "dyld mach-init-enter\n");
+    ROOTLESS_BOOT_TRACE(rootlessTraceFD, "dyld mach-init-enter\n");
     mach_init(apple);
-    rootlessBootTrace(rootlessTraceFD, "dyld mach-init-ready\n");
+    ROOTLESS_BOOT_TRACE(rootlessTraceFD, "dyld mach-init-ready\n");
 #else
     mach_init();
 #endif
@@ -190,7 +214,7 @@ uintptr_t start(const dyld3::MachOLoaded* appsMachHeader, int argc, const char*
 
 #ifdef DARLING
 	const int rootlessTraceFD = rootlessBootTraceFD(envp);
-	rootlessBootTrace(rootlessTraceFD, "dyld bootstrap-enter\n");
+	ROOTLESS_BOOT_TRACE(rootlessTraceFD, "dyld bootstrap-enter\n");
 #endif
 
 #ifndef DARLING
@@ -205,9 +229,9 @@ uintptr_t start(const dyld3::MachOLoaded* appsMachHeader, int argc, const char*
 	++apple;
 
 #ifdef DARLING
-	rootlessBootTrace(rootlessTraceFD, "dyld rebase-enter\n");
+	ROOTLESS_BOOT_TRACE(rootlessTraceFD, "dyld rebase-enter\n");
     rebaseDyld(dyldsMachHeader, apple, rootlessTraceFD);
-	rootlessBootTrace(rootlessTraceFD, "dyld rebase-ready\n");
+	ROOTLESS_BOOT_TRACE(rootlessTraceFD, "dyld rebase-ready\n");
 #endif
 
 	// set up random value for stack canary
@@ -226,7 +250,7 @@ uintptr_t start(const dyld3::MachOLoaded* appsMachHeader, int argc, const char*
 	// now that we are done bootstrapping dyld, call dyld's main
 
 #ifdef DARLING
-	rootlessBootTrace(rootlessTraceFD, "dyld main-ready\n");
+	ROOTLESS_BOOT_TRACE(rootlessTraceFD, "dyld main-ready\n");
 #endif
 	uintptr_t appsSlide = appsMachHeader->getSlide();
 	return dyld::_main((macho_header*)appsMachHeader, appsSlide, argc, argv, envp, apple, startGlue);

From e0c9445908d4a5226c98c62508bc91b7b6b595f2 Mon Sep 17 00:00:00 2001
From: Ilya Gulya <ilya@gulya.me>
Date: Sat, 11 Jul 2026 10:30:07 +0000
Subject: [PATCH] dyld: initialize program vars before mach init

---
 src/dyldInitialization.cpp | 29 +++++++++++++++++++++++++++--
 1 file changed, 27 insertions(+), 2 deletions(-)

diff --git a/src/dyldInitialization.cpp b/src/dyldInitialization.cpp
index f265ad11f5cfca84b9ea4276a800598952c3be5f..5375d81c60e213f5559679d3ac3ec8d01ecec242 100644
--- a/src/dyldInitialization.cpp
+++ b/src/dyldInitialization.cpp
@@ -39,6 +39,10 @@
 // from libc.a
 #ifdef DARLING
 extern "C" void mach_init(const char* apple[]);
+extern "C" void __program_vars_init(const ProgramVars* vars);
+extern "C" int NXArgc;
+extern "C" const char** NXArgv;
+extern "C" const char* __progname;
 #else
 extern "C" void mach_init();
 #endif
@@ -118,6 +122,24 @@ static void rootlessBootTrace(int fd, const char* stage, size_t stageLength)
 	do { \
 		rootlessBootTrace((fd), (stage), sizeof(stage) - 1); \
 	} while (0)
+
+static void initializeDyldProgramVars(const dyld3::MachOLoaded* dyldMH, int argc,
+		const char* argv[], const char* envp[])
+{
+	ProgramVars vars = {
+		dyldMH,
+		&NXArgc,
+		&NXArgv,
+		reinterpret_cast<const char***>(&environ),
+		&__progname,
+	};
+
+	NXArgc = argc;
+	NXArgv = argv;
+	environ = const_cast<char**>(envp);
+	__progname = ((argv != NULL) && (argv[0] != NULL)) ? argv[0] : "";
+	__program_vars_init(&vars);
+}
 #endif
 
 
@@ -160,7 +182,9 @@ static void runDyldInitializers(int argc, const char* argv[], const char* envp[]
 // They need to be fixed up to be real pointers to run.
 //
 #ifdef DARLING
-static void rebaseDyld(const dyld3::MachOLoaded* dyldMH, const char* apple[], int rootlessTraceFD)
+static void rebaseDyld(const dyld3::MachOLoaded* dyldMH, int argc,
+		const char* argv[], const char* envp[], const char* apple[],
+		int rootlessTraceFD)
 #else
 static void rebaseDyld(const dyld3::MachOLoaded* dyldMH)
 #endif
@@ -177,6 +201,7 @@ static void rebaseDyld(const dyld3::MachOLoaded* dyldMH)
 
     // now that rebasing done, initialize mach/syscall layer
 #ifdef DARLING
+	initializeDyldProgramVars(dyldMH, argc, argv, envp);
     ROOTLESS_BOOT_TRACE(rootlessTraceFD, "dyld mach-init-enter\n");
     mach_init(apple);
     ROOTLESS_BOOT_TRACE(rootlessTraceFD, "dyld mach-init-ready\n");
@@ -230,7 +255,7 @@ uintptr_t start(const dyld3::MachOLoaded* appsMachHeader, int argc, const char*
 
 #ifdef DARLING
 	ROOTLESS_BOOT_TRACE(rootlessTraceFD, "dyld rebase-enter\n");
-    rebaseDyld(dyldsMachHeader, apple, rootlessTraceFD);
+    rebaseDyld(dyldsMachHeader, argc, argv, envp, apple, rootlessTraceFD);
 	ROOTLESS_BOOT_TRACE(rootlessTraceFD, "dyld rebase-ready\n");
 #endif
 
