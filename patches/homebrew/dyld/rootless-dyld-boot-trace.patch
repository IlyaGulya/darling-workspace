 #ifndef DARLING
@@ -200,8 +202,8 @@ uintptr_t start(const dyld3::MachOLoaded* appsMachHeader, int argc, const char*
 	++apple;
 
 #ifdef DARLING
-    rebaseDyld(dyldsMachHeader, apple);
-	rootlessTraceFD = rootlessBootTraceFD(envp);
+	rootlessBootTrace(rootlessTraceFD, "dyld rebase-enter\n");
+    rebaseDyld(dyldsMachHeader, apple, rootlessTraceFD);
 	rootlessBootTrace(rootlessTraceFD, "dyld rebase-ready\n");
 #endif
 
@@ -260,4 +262,3 @@ uintptr_t start_sim(int argc, const char* argv[], const char* envp[], const char
 
 
 } // end of namespace
