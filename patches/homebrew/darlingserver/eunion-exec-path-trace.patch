From c9f536170d32d5f7c0b89f4f83fae33c7e9bba6c Mon Sep 17 00:00:00 2001
From: Ilya Gulya <ilya@gulya.me>
Date: Sat, 11 Jul 2026 23:23:13 +0000
Subject: [PATCH] test: trace guest executable paths

---
 .../darlingserver/test-diagnostics.hpp        |  1 +
 src/call.cpp                                  | 10 ++++++-
 src/test-diagnostics.cpp                      | 30 +++++++++++++++++++
 3 files changed, 40 insertions(+), 1 deletion(-)

diff --git a/internal-include/darlingserver/test-diagnostics.hpp b/internal-include/darlingserver/test-diagnostics.hpp
index a6a503475f5ec227712926a2cd25654605b8ec63..5fcbd6f5179d682638283b424143115ee69be33d 100644
--- a/internal-include/darlingserver/test-diagnostics.hpp
+++ b/internal-include/darlingserver/test-diagnostics.hpp
@@ -52,5 +52,6 @@ void tracePthreadMarkcancel(
 	bool canceledAfter,
 	int resultCode
 );
+void traceExecutablePath(int pid, int tid, const std::string& path, int resultCode);
 
 }
diff --git a/src/call.cpp b/src/call.cpp
index 2589facc1e720a785517be93cc1e945448d194e5..3b3693ed61007714a7bdece7eb6db8384e5fbdaa 100644
--- a/src/call.cpp
+++ b/src/call.cpp
@@ -1192,6 +1192,8 @@ void DarlingServer::Call::S2CPerform::processCall() {
 
 void DarlingServer::Call::SetExecutablePath::processCall() {
 	int code = 0;
+	std::string path;
+	bool pathSet = false;
 
 	if (auto thread = _thread.lock()) {
 		if (auto process = thread->process()) {
@@ -1200,7 +1202,9 @@ void DarlingServer::Call::SetExecutablePath::processCall() {
 			if (!process->readMemory((uintptr_t)_body.buffer, tmpstr.data(), _body.buffer_size, &code)) {
 				code = -code;
 			} else {
-				process->setExecutablePath(tmpstr.c_str());
+				path = tmpstr.c_str();
+				process->setExecutablePath(path);
+				pathSet = true;
 			}
 		} else {
 			code = -ESRCH;
@@ -1209,6 +1213,10 @@ void DarlingServer::Call::SetExecutablePath::processCall() {
 		code = -ESRCH;
 	}
 
+	if (TestDiagnostics::enabled()) {
+		TestDiagnostics::traceExecutablePath(_header.pid, _header.tid, pathSet ? path : std::string(), code);
+	}
+
 	_sendReply(code);
 }
 
diff --git a/src/test-diagnostics.cpp b/src/test-diagnostics.cpp
index c8d65e1b55e713e9b4ac45d8e77ab8463310dc9d..5fdb4deeac98bfd79d4d393249df0a11fc9e088d 100644
--- a/src/test-diagnostics.cpp
+++ b/src/test-diagnostics.cpp
@@ -1,6 +1,7 @@
 #include <darlingserver/test-diagnostics.hpp>
 
 #include <cerrno>
+#include <cctype>
 #include <cstdlib>
 #include <cstring>
 #include <mutex>
@@ -57,6 +58,24 @@ static const char* pthreadCancelOutcome(int resultCode) {
 	return "error";
 }
 
+static std::string traceValue(const std::string& value) {
+	static constexpr char Hex[] = "0123456789abcdef";
+	std::string escaped;
+	escaped.reserve(value.size());
+
+	for (unsigned char character : value) {
+		if (std::isalnum(character) || character == '/' || character == '.' || character == '-' || character == '_') {
+			escaped.push_back(static_cast<char>(character));
+		} else {
+			escaped += "\\x";
+			escaped.push_back(Hex[character >> 4]);
+			escaped.push_back(Hex[character & 0x0f]);
+		}
+	}
+
+	return escaped;
+}
+
 bool enabled() {
 	return std::getenv(TraceEnv) != nullptr;
 }
@@ -236,4 +255,15 @@ void tracePthreadMarkcancel(
 	);
 }
 
+void traceExecutablePath(int pid, int tid, const std::string& path, int resultCode) {
+	traceLine(
+		"process.executable_path operation=set_executable_path" +
+		std::string(" pid=") + std::to_string(pid) +
+		" tid=" + std::to_string(tid) +
+		" path=" + traceValue(path) +
+		" code=" + std::to_string(resultCode) +
+		" terminal=reply-enqueued"
+	);
+}
+
 }
