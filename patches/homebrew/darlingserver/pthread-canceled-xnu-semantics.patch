 duct-tape/include/darlingserver/duct-tape.h   | 10 ++++
 .../darlingserver/duct-tape/thread.h          | 15 ++++++
 duct-tape/src/thread.c                        | 49 +++++++++++++++++++
 src/call.cpp                                  | 18 +++++--
 4 files changed, 87 insertions(+), 5 deletions(-)

