+	assert(namespaceIDForPeer(4100, 4100, 4100) == initNamespaceID);
+	assert(namespaceIDForPeer(4100, 4101, initNamespaceID) == 4101);
+
+	assert(isMainThread(73, 8100, 73, 8100));
+	assert(isMainThread(8100, 8100, initNamespaceID, 8100));
+	assert(!isMainThread(8101, 8101, initNamespaceID, 8100));
+	assert(!isMainThread(8100, 8101, initNamespaceID, 8100));
+
+	return 0;
+}

From 044364ee983828570e4b8d11cc5fcadf20d70524 Mon Sep 17 00:00:00 2001
From: Ilya Gulya <ilya@gulya.me>
Date: Sat, 11 Jul 2026 02:24:36 +0000
Subject: [PATCH] darlingserver: reject rootless copy-mode startup

---
 src/darlingserver.cpp | 6 ++++++
 1 file changed, 6 insertions(+)

diff --git a/src/darlingserver.cpp b/src/darlingserver.cpp
index f3f5114a200afafd2687b37a3a469749b87fc6d8..08d702b2453504a240e3c4e96d61be0a5245f0bc 100644
--- a/src/darlingserver.cpp
+++ b/src/darlingserver.cpp
@@ -663,6 +663,12 @@ int main(int argc, char** argv) {
 	}
 	const bool useOverlayFs = !rootless && shouldUseOverlayFs();
 	const bool useEunionPrefix = !useOverlayFs && shouldUseEunionPrefix();
+	if (rootless && !useEunionPrefix) {
+		fprintf(stderr,
+			"Rootless no-mount startup requires DARLING_EUNION=1; "
+			"copy-mode would modify the shared template tree\n");
+		exit(1);
+	}
 
 	if (useOverlayFs) {
 		// Because systemd marks / as MS_SHARED and we would inherit this into the overlay mount,
