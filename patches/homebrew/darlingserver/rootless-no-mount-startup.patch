@@ -0,0 +1,21 @@
+#include <darlingserver/process-identity.hpp>
+
+#include <cassert>
+
+int main() {
+	using DarlingServer::ProcessIdentity::initNamespaceID;
+	using DarlingServer::ProcessIdentity::isMainThread;
+	using DarlingServer::ProcessIdentity::namespaceIDForPeer;
