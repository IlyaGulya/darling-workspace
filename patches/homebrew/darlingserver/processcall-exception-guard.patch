From 8a2c9c5994e65ea2101d7c821355e1a05ad55fc4 Mon Sep 17 00:00:00 2001
From: Ilya Gulya <ilya@gulya.me>
Date: Sun, 21 Jun 2026 14:40:33 +0000
Subject: [PATCH] thread/call/server: contain exceptions that can terminate the
 server

A Call::processCall() implementation may throw -- e.g. std::system_error
from a memory operation (writeMemory/readMemory/memoryInfo) on a guest
that died concurrently with an in-flight RPC, or std::runtime_error from
the exec-replacement path ("Main thread for process died?"). And message
construction in Call::callFromMessage() may throw too -- notably
std::runtime_error("Thread's pending call overwritten while active") from
Thread::setPendingCall() when an RPC races a still-pending call, plus
std::invalid_argument for a malformed/unknown call. None of these three
sites had a surrounding try/catch:

  - Thread::microthreadWorker() runs on a makecontext()-established fiber
    stack and never returns normally (it always setcontext()s away), so an
    uncaught exception unwinding out of it is undefined behavior and in
    practice reaches std::terminate -> the whole server dies.
  - Call::callFromMessage()'s kernelAsync path (thread-less calls) had the
    same exposure.
  - Call::callFromMessage() itself is invoked directly in the main event
    loop Server::start() with no try/catch, so a throw during message
    construction/dispatch (e.g. the pending-call-overwrite race) unwinds
    out of the event loop and terminates the server just the same.

When the server dies, every other guest with an in-flight RPC is stranded
forever blocked in recvmsg on its per-thread RPC socket, and the whole
guest tree is orphaned.

Fix: wrap all three.
  - In microthreadWorker, on a caught exception log the offending call and
    attempt Call::sendBasicReply(-code) so the client gets an error reply
    instead of hanging, then continue the normal post-call flow.
  - In the kernelAsync path there is no client thread to reply to, so log
    and drop.
  - In the event loop, log and drop just the one offending message so the
    server keeps serving every other guest.

This converts "one unlucky RPC race terminates the server and wedges every
guest" into "that one RPC fails (error reply or dropped); all other guests
keep working."
---
 .../darlingserver/processcall-guard.hpp       | 24 ++++++++++++++++
 src/call.cpp                                  | 18 +++++++++++-
 src/server.cpp                                | 28 +++++++++++++++++--
 src/thread.cpp                                | 28 ++++++++++++++++++-
 4 files changed, 93 insertions(+), 5 deletions(-)
 create mode 100644 internal-include/darlingserver/processcall-guard.hpp

diff --git a/internal-include/darlingserver/processcall-guard.hpp b/internal-include/darlingserver/processcall-guard.hpp
new file mode 100644
index 0000000000000000000000000000000000000000..eefc7f34910a935662340e2c4caef36987f584d5
--- /dev/null
+++ b/internal-include/darlingserver/processcall-guard.hpp
@@ -0,0 +1,24 @@
+#ifndef _DARLINGSERVER_PROCESSCALL_GUARD_HPP_
+#define _DARLINGSERVER_PROCESSCALL_GUARD_HPP_
+
+#include <cerrno>
+#include <exception>
+#include <system_error>
+
+namespace DarlingServer {
+	template <typename Function>
+	inline int processCallBasicReplyCode(Function&& function) {
+		try {
+			function();
+			return 0;
+		} catch (const std::system_error& err) {
+			return -err.code().value();
+		} catch (const std::exception&) {
+			return -EINVAL;
+		} catch (...) {
+			return -EINVAL;
+		}
+	}
+}
+
+#endif
diff --git a/src/call.cpp b/src/call.cpp
index 7ad16e8fc8c02ecdc14613fe1bfbb23ba26bd8d2..721031c7680c5c14317f793c138b0b80ca177c89 100644
--- a/src/call.cpp
+++ b/src/call.cpp
@@ -29,6 +29,7 @@
 #include <sys/fcntl.h>
 #include <sys/syscall.h>
 #include <darlingserver/kqchan.hpp>
+#include <system_error>
 
 static DarlingServer::Log callLog("calls");
 
@@ -220,7 +221,22 @@ std::shared_ptr<DarlingServer::Call> DarlingServer::Call::callFromMessage(Messag
 		return result;
 	} else {
 		Thread::kernelAsync([result]() {
-			result->processCall();
+			// Contain a throwing processCall so it cannot terminate the whole server
+			// (see the matching guard in Thread::microthreadWorker). This path has no
+			// client thread to reply to, so just log and drop.
+			try {
+				result->processCall();
+			} catch (const std::system_error& err) {
+				callLog.error() << "Uncaught std::system_error from kernel-async processCall (call "
+					<< DarlingServer::Call::callNumberToString(result->number()) << "): " << err.what()
+					<< " (code " << err.code().value() << ")" << callLog.endLog;
+			} catch (const std::exception& ex) {
+				callLog.error() << "Uncaught exception from kernel-async processCall (call "
+					<< DarlingServer::Call::callNumberToString(result->number()) << "): " << ex.what() << callLog.endLog;
+			} catch (...) {
+				callLog.error() << "Uncaught non-std exception from kernel-async processCall (call "
+					<< DarlingServer::Call::callNumberToString(result->number()) << ")" << callLog.endLog;
+			}
 		});
 		return nullptr;
 	}
diff --git a/src/server.cpp b/src/server.cpp
index e502e2854652c9053ad13e3f53653f795a19a48e..b71b4889a3de7978ef62b30f891cd314212f8622 100644
--- a/src/server.cpp
+++ b/src/server.cpp
@@ -538,9 +538,31 @@ void DarlingServer::Server::start() {
 
 			while (auto msg = _inbox.pop()) {
 				// TODO: this could be done concurrently
-				auto call = DarlingServer::Call::callFromMessage(std::move(*msg));
-				if (call) {
-					_workQueue.push(call->thread());
+				//
+				// callFromMessage() runs here on the main event loop and can throw:
+				//   * std::invalid_argument for a malformed/unknown call,
+				//   * std::runtime_error("Thread's pending call overwritten while active")
+				//     from Thread::setPendingCall when an RPC races a still-pending call
+				//     (routinely under a heavy fork/signal storm, e.g. building Homebrew),
+				//   * std::system_error from the dtape/registry machinery.
+				// There is no try/catch anywhere above this in Server::start(), so an
+				// uncaught throw here unwinds out of the event loop -> std::terminate ->
+				// the whole darlingserver process dies, orphaning every guest. (This is a
+				// distinct server-exit path from the processCall() guards in
+				// Thread::microthreadWorker / Call::kernelAsync, which do NOT cover message
+				// construction/dispatch.) Contain it: log and drop just this one message so
+				// the server keeps serving every other guest.
+				try {
+					auto call = DarlingServer::Call::callFromMessage(std::move(*msg));
+					if (call) {
+						_workQueue.push(call->thread());
+					}
+				} catch (const std::exception& ex) {
+					static DarlingServer::Log serverLog("server");
+					serverLog.error() << "Dropping message: callFromMessage threw: " << ex.what() << serverLog.endLog;
+				} catch (...) {
+					static DarlingServer::Log serverLog("server");
+					serverLog.error() << "Dropping message: callFromMessage threw a non-std exception" << serverLog.endLog;
 				}
 			}
 		}
diff --git a/src/thread.cpp b/src/thread.cpp
index 9e83b2da70d7a56aed5e1192c767de05b1d65fc4..0b95f72c36e946d7958353bfb17caff9d6a2ef05 100644
--- a/src/thread.cpp
+++ b/src/thread.cpp
@@ -20,6 +20,7 @@
 #include "darlingserver/registry.hpp"
 #include <darlingserver/thread.hpp>
 #include <darlingserver/microthread-resume.hpp>
+#include <darlingserver/processcall-guard.hpp>
 #include <darlingserver/process.hpp>
 #include <darlingserver/call.hpp>
 #include <darlingserver/server.hpp>
@@ -44,6 +45,8 @@
 #include <assert.h>
 
 #include <limits>
+#include <system_error>
+#include <cerrno>
 #include <sys/ptrace.h>
 #include <sys/user.h>
 #include <sys/wait.h>
@@ -344,7 +347,30 @@ void DarlingServer::Thread::microthreadWorker() {
 
 	currentContinuation = nullptr;
 	currentThreadVar->makePendingCallActive();
-	currentThreadVar->_activeCall->processCall();
+
+	// A processCall() implementation may throw (e.g. std::system_error from a memory
+	// operation on a guest that died concurrently, or std::runtime_error from the
+	// exec-replacement path). This worker runs on a makecontext()-established fiber
+	// stack and never returns normally (it always setcontext()s away below), so an
+	// uncaught exception unwinding out of here is undefined behavior -> std::terminate
+	// -> the whole darlingserver process dies, stranding every other guest with an
+	// in-flight RPC blocked forever in recvmsg. Contain it: turn the failure into an
+	// error reply when the call supports one, otherwise just log and drop it, and
+	// continue the normal post-call flow so the server stays alive.
+	int guardedReplyCode = DarlingServer::processCallBasicReplyCode([&]() {
+		currentThreadVar->_activeCall->processCall();
+	});
+	if (guardedReplyCode < 0) {
+		microthreadLog.error()
+			<< "Uncaught exception from processCall (call "
+			<< DarlingServer::Call::callNumberToString(currentThreadVar->_activeCall->number())
+			<< "); replying " << guardedReplyCode << microthreadLog.endLog;
+		try {
+			currentThreadVar->_activeCall->sendBasicReply(guardedReplyCode);
+		} catch (...) {
+			// call has no basic reply (returns data); nothing more we can do but survive
+		}
+	}
 
 	if (currentThreadVar->_handlingInterruptedCall) {
 		currentThreadVar->_didSyscallReturnDuringInterrupt = true;
