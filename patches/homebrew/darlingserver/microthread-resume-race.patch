From d2d76a9a16fdc8d05947b1acfb54285c062563b2 Mon Sep 17 00:00:00 2001
From: Ilya Gulya <ilya@gulya.me>
Date: Wed, 10 Jun 2026 10:05:56 +0000
Subject: [PATCH] thread: fix microthread resume-before-suspend lost wakeup

A wake (resume()) arriving before or during a microthread's physical
suspension was dropped, stranding the thread forever. Introduce a
coalesced _resumePermit recorded by resume() while the thread is
running or suspended, consumed by suspend() before sleeping and after
context capture, and replayed by doWork() if a wake lands after the
final suspend-side check (rescheduling only once the microthread has
physically stopped, so no two workers run it concurrently). Document
_running / _suspended / _resumePermit as orthogonal lifecycle
dimensions.
---
 .../darlingserver/microthread-resume.hpp      | 37 ++++++++++++++++
 internal-include/darlingserver/thread.hpp     |  5 +++
 src/thread.cpp                                | 44 ++++++++++++++++---
 3 files changed, 80 insertions(+), 6 deletions(-)
 create mode 100644 internal-include/darlingserver/microthread-resume.hpp

diff --git a/internal-include/darlingserver/microthread-resume.hpp b/internal-include/darlingserver/microthread-resume.hpp
new file mode 100644
index 0000000000000000000000000000000000000000..d5b3235d93271ee7da4cbae577951f39db3296ef
--- /dev/null
+++ b/internal-include/darlingserver/microthread-resume.hpp
@@ -0,0 +1,37 @@
+#ifndef _DARLINGSERVER_MICROTHREAD_RESUME_HPP_
+#define _DARLINGSERVER_MICROTHREAD_RESUME_HPP_
+
+namespace DarlingServer {
+	inline bool microthreadRecordResume(bool running, bool suspended, bool& resumePermit) {
+		if (!running && !suspended) {
+			return false;
+		}
+		if (resumePermit) {
+			return false;
+		}
+		resumePermit = true;
+		return suspended && !running;
+	}
+
+	inline bool microthreadConsumePendingResume(bool& resumePermit) {
+		if (!resumePermit) {
+			return false;
+		}
+		resumePermit = false;
+		return true;
+	}
+
+	inline bool microthreadConsumeResumeDuringSuspend(bool& suspended, bool& resumePermit) {
+		if (!microthreadConsumePendingResume(resumePermit)) {
+			return false;
+		}
+		suspended = false;
+		return true;
+	}
+
+	inline bool microthreadShouldScheduleAfterStop(bool resumePermit, bool suspended, bool terminating, bool dead) {
+		return resumePermit && suspended && !terminating && !dead;
+	}
+}
+
+#endif
diff --git a/internal-include/darlingserver/thread.hpp b/internal-include/darlingserver/thread.hpp
index 57117f2a77467316437a74a1749fc8d106836625..6871d5f6e2b83c08a57de51c0d8fc0d833d8fe3f 100644
--- a/internal-include/darlingserver/thread.hpp
+++ b/internal-include/darlingserver/thread.hpp
@@ -80,7 +80,12 @@ namespace DarlingServer {
 		Address _address;
 		mutable std::shared_mutex _rwlock;
 		StackPool::Stack _stack;
+		// These are orthogonal lifecycle dimensions, not one enum state:
+		// _running means a worker currently owns this microthread;
+		// _suspended means it has a resumable context; and _resumePermit is a
+		// coalesced wake request that bridges the transition between the two.
 		bool _suspended = false;
+		bool _resumePermit = false;
 		ucontext_t _resumeContext;
 		dtape_thread_t* _dtapeThread;
 		std::function<void()> _continuationCallback = nullptr;
diff --git a/src/thread.cpp b/src/thread.cpp
index 5563ad92cea6ff5f717abc55ec330b6a215a6ab6..9e83b2da70d7a56aed5e1192c767de05b1d65fc4 100644
--- a/src/thread.cpp
+++ b/src/thread.cpp
@@ -19,6 +19,7 @@
 
 #include "darlingserver/registry.hpp"
 #include <darlingserver/thread.hpp>
+#include <darlingserver/microthread-resume.hpp>
 #include <darlingserver/process.hpp>
 #include <darlingserver/call.hpp>
 #include <darlingserver/server.hpp>
@@ -423,6 +424,10 @@ void DarlingServer::Thread::doWork() {
 		goto doneWorking;
 	}
 
+	if (_suspended) {
+		// This execution was scheduled by resume(); consume that wake permit.
+		microthreadConsumePendingResume(_resumePermit);
+	}
 	_running = true;
 	currentThreadVar = shared_from_this();
 	dtape_thread_entering(_dtapeThread);
@@ -545,6 +550,10 @@ doneWorking:
 		currentThreadVar = nullptr;
 		_running = false;
 	}
+	// A wake can arrive after suspend()'s final permit check but before it
+	// physically switches back here. Now that _running is false, rescheduling
+	// is safe and cannot race another worker running this microthread.
+	bool resumeAfterWorking = microthreadShouldScheduleAfterStop(_resumePermit, _suspended, _terminating, _dead);
 	bool canRelease = false;
 	if (_dead) {
 		threadLog.debug() << *this << ": dead thread returning. active call? " << (!!_activeCall ? "true" : "false") << " terminating? " << (_terminating ? "true" : "false") << threadLog.endLog;
@@ -581,6 +590,9 @@ doneWorking:
 		unlockMeWhenSuspending = nullptr;
 	}
 	_runningCondvar.notify_all();
+	if (resumeAfterWorking) {
+		Server::sharedInstance().scheduleThread(shared_from_this());
+	}
 	if (canRelease) {
 		_scheduleRelease();
 	}
@@ -597,6 +609,14 @@ void DarlingServer::Thread::suspend(std::function<void()> continuationCallback,
 	}
 
 	_rwlock.lock();
+	// Consume a wake that arrived before suspend() marked us suspended.
+	if (microthreadConsumePendingResume(_resumePermit)) {
+		_rwlock.unlock();
+		if (unlockMe) {
+			libsimple_lock_unlock(unlockMe);
+		}
+		return;
+	}
 	_suspended = true;
 	_rwlock.unlock();
 
@@ -605,6 +625,15 @@ void DarlingServer::Thread::suspend(std::function<void()> continuationCallback,
 	getcontext(&_resumeContext);
 
 	_rwlock.lock();
+	// Consume a wake that arrived while the resume context was being captured.
+	if (microthreadConsumeResumeDuringSuspend(_suspended, _resumePermit)) {
+		_rwlock.unlock();
+		if (unlockMeWhenSuspending) {
+			libsimple_lock_unlock(unlockMeWhenSuspending);
+			unlockMeWhenSuspending = nullptr;
+		}
+		return;
+	}
 	if (_suspended) {
 		if (continuationCallback) {
 			// when suspendeding with a continuation, the current continuation and call are discarded (since they can no longer be safely returned to)
@@ -639,15 +668,18 @@ void DarlingServer::Thread::suspend(std::function<void()> continuationCallback,
 };
 
 void DarlingServer::Thread::resume() {
+	bool schedule = false;
 	{
-		std::shared_lock lock(_rwlock);
-		if (!_suspended) {
-			// maybe we should throw an error here?
-			return;
-		}
+		std::unique_lock lock(_rwlock);
+		// Coalesce repeated wakes into one permit. If the microthread is still
+		// running, it will either consume the permit in suspend() or reschedule
+		// itself from doWork() after physically stopping.
+		schedule = microthreadRecordResume(_running, _suspended, _resumePermit);
 	}
 
-	Server::sharedInstance().scheduleThread(shared_from_this());
+	if (schedule) {
+		Server::sharedInstance().scheduleThread(shared_from_this());
+	}
 };
 
 void DarlingServer::Thread::terminate() {
