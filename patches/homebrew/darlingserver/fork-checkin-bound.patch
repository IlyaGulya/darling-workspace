 .../include/darlingserver/duct-tape/types.h   |  1 +
 duct-tape/src/semaphore.c                     | 18 +++++++++++
 .../darlingserver/fork-checkin.hpp            | 30 +++++++++++++++++++
 internal-include/darlingserver/process.hpp    |  2 +-
 src/call.cpp                                  |  5 +++-
 src/process.cpp                               | 30 +++++++++++++++++--
 7 files changed, 82 insertions(+), 5 deletions(-)
 create mode 100644 internal-include/darlingserver/fork-checkin.hpp

