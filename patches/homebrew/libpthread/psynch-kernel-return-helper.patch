diff --git a/src/inline_internal.h b/src/inline_internal.h
index bc6d65add6ca74028ca70bb461d92099fb315609..6f179f05856eb0ba6c02c2c6d69787a1eb60a184 100644
--- a/src/inline_internal.h
+++ b/src/inline_internal.h
@@ -160,6 +160,29 @@ _pthread_lock_unlock(os_unfair_lock_t lock, mach_port_t mts)
 #undef  errno
 #define errno          (*_pthread_errno_address_direct())
 
+OS_ALWAYS_INLINE
+static inline int
+_pthread_psynch_kernel_return_error(uint32_t updateval, uint32_t *status)
+{
+	if (updateval == (uint32_t)-1) {
+		return errno;
+	}
+	if ((int32_t)updateval < 0) {
+		return -(int32_t)updateval;
+	}
+	if (status) {
+		*status = updateval;
+	}
+	return 0;
+}
+
+OS_ALWAYS_INLINE
+static inline int
+_pthread_psynch_kernel_error_code(int err)
+{
+	return err & 0xff;
+}
+
 #define _pthread_tsd_slot(th, name) \
 		(*(_PTHREAD_TSD_SLOT_##name##_TYPE *)(uintptr_t *)&(th)->tsd[_PTHREAD_TSD_SLOT_##name])
 
diff --git a/src/pthread_cond.c b/src/pthread_cond.c
index 91621a35cfb0faeca4026a5a16acb0dcfd618690..c018fc65193db905f33d79422af45b402acb7626 100644
--- a/src/pthread_cond.c
+++ b/src/pthread_cond.c
@@ -633,17 +633,10 @@ _pthread_psynch_cond_wait(pthread_cond_t *cond,
 		updateval = __psynch_cvwait(cond, cvlsgen, ucntval, (pthread_mutex_t *)npmtx, mugen, flags, (int64_t)(then->tv_sec), (int32_t)(then->tv_nsec));
 	}
 
-	// Darling: the emulated BSD psynch_cvwait syscall returns its BSD error
-	// (EINTR/ETIMEDOUT, possibly OR'd with the cvar ECVCLEARED/ECVPREPOST
-	// status bits) as a *negative* value directly in the return register, not
-	// as the -1 + errno that upstream macOS uses. Accept both: -1 means read
-	// errno; any other negative value carries the (augmented) error itself.
-	// Without this decode libpthread mistakes the error for a successful
-	// updateval, skips the EINTR/prepost recovery, and orphan preposts strand
-	// a later condvar wakeup.
-	if ((int32_t)updateval < 0) {
-		int err = updateval == (uint32_t)-1 ? errno : -(int32_t)updateval;
-		switch (err & 0xff) {
+	uint32_t psynch_status = 0;
+	int psynch_err = _pthread_psynch_kernel_return_error(updateval, &psynch_status);
+	if (psynch_err) {
+		switch (_pthread_psynch_kernel_error_code(psynch_err)) {
 		case ETIMEDOUT:
 			res = ETIMEDOUT;
 			break;
@@ -657,12 +650,12 @@ _pthread_psynch_cond_wait(pthread_cond_t *cond,
 		}
 
 		// add unlock ref to show one less waiter
-		_pthread_cond_updateval(cond, mutex, err, 0);
-	} else if (updateval != 0) {
+		_pthread_cond_updateval(cond, mutex, psynch_err, 0);
+	} else if (psynch_status != 0) {
 		// Successful wait
 		// The return due to prepost and might have bit states
 		// update S and return for prepo if needed
-		_pthread_cond_updateval(cond, mutex, 0, updateval);
+		_pthread_cond_updateval(cond, mutex, 0, psynch_status);
 	}
 
 	pthread_mutex_lock(mutex);
diff --git a/src/pthread_mutex.c b/src/pthread_mutex.c
index e0358fe89464839a7cbde975548e1c6ebf54a138..e1ee4a18b6327db18221b1391e9e101dafc35c23 100644
--- a/src/pthread_mutex.c
+++ b/src/pthread_mutex.c
@@ -766,18 +766,16 @@ _pthread_mutex_fairshare_lock_wait(pthread_mutex_t *mutex, mutex_seq newseq,
 	PLOCKSTAT_MUTEX_BLOCK((pthread_mutex_t *)mutex);
 	do {
 		uint32_t updateval;
+		int psynch_err;
 		do {
 			updateval = __psynch_mutexwait(mutex, newseq.lgenval,
 					newseq.ugenval, oldtid, mutex->mtxopts.value);
 			oldtid = os_atomic_load_wide(tidaddr, relaxed);
-		// Darling: the emulated BSD syscall returns an interrupted/errored
-		// wait (e.g. EINTR) as a *negative* value directly in the return
-		// register, not as -1 + errno. Retry the kernel wait on any such
-		// negative return so the kw_intr interrupted-wakeup redirection is
