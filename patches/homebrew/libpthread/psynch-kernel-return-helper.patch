@@ -1418,10 +1410,11 @@ _pthread_mutex_firstfit_lock_wait(pthread_mutex_t *mutex, mutex_seq newseq,
 			PTHREAD_TRACE(psynch_ffmutex_wait | DBG_FUNC_END, mutex,
