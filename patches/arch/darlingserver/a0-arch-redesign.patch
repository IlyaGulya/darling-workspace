From 78ac2d8f05aab3979a04a85c6ed88974f1039b3d Mon Sep 17 00:00:00 2001
From: Ilya Gulya <ilya@gulya.me>
Date: Sat, 4 Jul 2026 07:10:15 +0000
Subject: [PATCH] A0-ARCH stage 3 fix 1: don't consume a pending wake for a
 dispatch that cannot resume

A nested interrupt_enter dispatching onto the Parked restored context took the
interrupt-stacking branch but had already consumed the cancellation wake as its
resume permit -- the nested sigexc_enter finds the wait already finalized and
fires no replacement, so the restored context parks forever (nestwait storm
wedge: jobs frozen, storm_hits growing, zero violations). Consume only when no
pending call is in the way; the wake survives in its pending slot and dispatches
the restored context after the nested enter completes.
---
 src/thread.cpp | 11 ++++++++++-
 1 file changed, 10 insertions(+), 1 deletion(-)

diff --git a/src/thread.cpp b/src/thread.cpp
index 99dd1a7bcae038d8e1709db843707120d54d1ee3..540717da3ece4bcbbe087b8896345391d217585a 100644
--- a/src/thread.cpp
+++ b/src/thread.cpp
@@ -591,7 +591,16 @@ void DarlingServer::Thread::doWork() {
 	// pre-dispatch view (the state field is authoritative now; there is no lingering
 	// _suspended residue to read). Parking is impossible here (the running guard above).
 	preDispatchParked = _isSuspendedLocked();
-	if (preDispatchParked && _consumePendingWakeLocked()) {
+	// A0-ARCH stage 3: only consume a pending wake when this dispatch can actually RESUME
+	// the parked context (no pending call in the way). With interrupt-as-cancellation the
+	// thread is genuinely Parked while an interrupt window is open, so a storm's nested
+	// interrupt_enter can dispatch ONTO the parked context -- that dispatch takes the
+	// interrupt-stacking branch, and consuming the wake here would EAT the cancellation
+	// resume permit (sigexc_enter of the nested enter finds the wait already finalized and
+	// fires no replacement -- captured live as the nestwait storm wedge, jobs frozen while
+	// storm_hits grow). The unconsumed wake survives in its pending slot and dispatches the
+	// restored context after the nested enter completes.
+	if (preDispatchParked && !_pendingCall && _consumePendingWakeLocked()) {
 		// This execution was scheduled by a matching typed wake; consume it.
 		hadResumePermit = true;
 	}

From 91b0dd24677c3660b1779dd6ea48c2252fc84bbf Mon Sep 17 00:00:00 2001
From: Ilya Gulya <ilya@gulya.me>
Date: Sat, 4 Jul 2026 07:25:14 +0000
Subject: [PATCH] A0-ARCH stage 3 fix 2: psynch mtx/rw continuations honor a
 grant that raced the abort

psynch_cvcontinue already had the 'woken up as we were granting' carve-out; the
mutex and rwlock continuations did NOT -- on THREAD_INTERRUPTED with the kwe
already dequeued and kwe_psynchretval committed they returned EINTR and
DISCARDED the grant. XNU never hits this (mutex waits are uninterruptible), but
Darling's sigexc_enter deliberately clears TH_UNINT so signals can abort any
wait, and stage 3's cancellation window (clear_wait -> normal-dispatch unwind)
is wide enough to hit the race constantly under a signal storm: the lost mutex
handoff wedges every later waiter (cvstorm2-throttled HANG, jobs frozen,
walker showing all threads cleanly parked in fresh waits with empty frames).
Honor the committed grant exactly like the cv path (reset error, return the
grant bits).
---
 duct-tape/pthread/kern_synch.c | 16 ++++++++++++++++
 1 file changed, 16 insertions(+)

diff --git a/duct-tape/pthread/kern_synch.c b/duct-tape/pthread/kern_synch.c
index 961f9a7434d58f2d52ec94445b89f91d8c50a310..0e38f89692c9e1f33e61f9ef7a2437840780d104 100644
--- a/duct-tape/pthread/kern_synch.c
+++ b/duct-tape/pthread/kern_synch.c
@@ -811,6 +811,17 @@ psynch_mtxcontinue(void *parameter, wait_result_t result)
 	if (error != 0) {
 		if (kwe->kwe_kwqqueue) {
 			ksyn_queue_remove_item(kwq, &kwq->kw_ksynqueues[KSYN_QUEUE_WRITE], kwe);
+		} else if (kwe->kwe_psynchretval != 0) {
+			// Darling (A0-ARCH stage 3): the wait was aborted (sigexc cancellation clears
+			// TH_UNINT, so even mutex waits abort on signals here, unlike XNU) but a grant
+			// was ALREADY committed to us -- dequeued from the kwq with kwe_psynchretval
+			// written -- before the abort could win. Honor the grant exactly like
+			// psynch_cvcontinue's "woken up as we were granting" path; discarding it loses
+			// the mutex handoff forever (every later waiter parks against a queue whose
+			// grant went nowhere -- the cvstorm2-throttled wedge, jobs frozen).
+			uint32_t updatebits = kwe->kwe_psynchretval & ~PTH_RWL_MTX_WAIT;
+			pthread_kern->uthread_set_returnval(uth, updatebits);
+			error = 0;
 		}
 	} else {
 		uint32_t updatebits = kwe->kwe_psynchretval & ~PTH_RWL_MTX_WAIT;
@@ -843,6 +854,11 @@ _psynch_rw_continue(ksyn_wait_queue_t kwq, kwq_queue_type_t kqi,
 	if (error != 0) {
 		if (kwe->kwe_kwqqueue) {
 			ksyn_queue_remove_item(kwq, &kwq->kw_ksynqueues[kqi], kwe);
+		} else if (kwe->kwe_psynchretval != 0) {
+			// Darling (A0-ARCH stage 3): abort raced an already-committed grant -- honor
+			// it (see psynch_mtxcontinue)
+			pthread_kern->uthread_set_returnval(uth, kwe->kwe_psynchretval);
+			error = 0;
 		}
 	} else {
 		pthread_kern->uthread_set_returnval(uth, kwe->kwe_psynchretval);

From ab03f8aac53e378e8cd5403e3d4ac1c053244a09 Mon Sep 17 00:00:00 2001
From: Ilya Gulya <ilya@gulya.me>
Date: Sat, 4 Jul 2026 07:58:20 +0000
Subject: [PATCH] A0-ARCH stage 3 fix 3: reset _currentTimerDeadline when the
 timerfd fires (+ timer trace)

The timerfd read handler left the just-fired (now past) deadline in
_currentTimerDeadline; until dtape_timer_fired's re-arm ran on a kernel runner,
every non-override timer_arm compared against the past and was silently
SKIPPED. A fresh short deadline (usleep's 1ms wait timer) armed in that window
was never programmed into the timerfd and only fired when some unrelated event
re-armed it -- captured live as the cvstorm2-throttled stormer's 1ms sleeps
latching to the 5s ring-duplex fail-closed metronome (storm at ~2/s instead of
~750/s), starving the storm and wedging the workload. Pre-existing hole; stage
3's wider windows made it a deterministic hit. Also adds TIMER-ARM/-SKIP/-FIRED
rpctrace lines (env-gated, zero cost when AUXLOG is off).
---
 src/server.cpp | 17 +++++++++++++++++
 1 file changed, 17 insertions(+)

diff --git a/src/server.cpp b/src/server.cpp
index cd12736ddc35d74053ea944d073b089fb788f478..9093871232ae05fa04e6ec6a133c1062e0b3a8f1 100644
--- a/src/server.cpp
+++ b/src/server.cpp
@@ -145,9 +145,14 @@ struct DTapeHooks {
 		std::unique_lock lock(server._timerLock);
 
 		if (!override && server._currentTimerDeadline != 0 && deadline_ns >= server._currentTimerDeadline) {
+			DarlingServer::__rpctrace("TIMER-ARM-SKIP dl=%llu cur=%llu",
+				(unsigned long long)deadline_ns, (unsigned long long)server._currentTimerDeadline);
 			return;
 		}
 
+		DarlingServer::__rpctrace("TIMER-ARM dl=%llu ovr=%d (cur was %llu)",
+			(unsigned long long)deadline_ns, override ? 1 : 0,
+			(unsigned long long)server._currentTimerDeadline);
 		server._currentTimerDeadline = deadline_ns;
 
 		if (timerfd_settime(server._timerFD, TFD_TIMER_ABSTIME, &newSpec, NULL) < 0) {
@@ -999,6 +1004,18 @@ void DarlingServer::Server::start() {
 					continue;
 				}
 
+				// A0-ARCH stage 3 (pre-existing hole, amplified by the wider cancellation
+				// windows): the deadline we were armed for has FIRED -- there is no armed
+				// deadline anymore. Leaving the stale (now past) value in
+				// _currentTimerDeadline makes every non-override timer_arm until
+				// dtape_timer_fired's re-arm compare against the past and get SKIPPED --
+				// a fresh short deadline (usleep's 1ms wait timer) is then never armed and
+				// only fires when some unrelated event re-arms the timerfd (captured live:
+				// the cvstorm2-throttled stormer's 1ms sleeps latching to the 5s duplex
+				// metronome, starving the whole workload into the wedge).
+				_currentTimerDeadline = 0;
+				DarlingServer::__rpctrace("TIMER-FIRED exp=%llu", (unsigned long long)expirations);
+
 				// we're done handling the timerfd;
 				// we don't need to lock anymore (and the following call might need to arm the timer again)
 				lock.unlock();

