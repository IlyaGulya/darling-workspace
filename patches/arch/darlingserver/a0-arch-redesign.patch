+			// Terminated = died with nothing left to run
+			return to == MS::Running || to == MS::Parked || to == MS::Terminated;
+		case MS::Running:
+			return to == MS::Parking || to == MS::Idle || to == MS::Terminated;
+		case MS::Parking:
