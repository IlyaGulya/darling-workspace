#!/usr/bin/env bash
set -euo pipefail

DW_ROOT="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)"
if [[ -f "$DW_ROOT/workspace.env" ]]; then
  # shellcheck disable=SC1091
  source "$DW_ROOT/workspace.env"
fi
DW_DARLING_SRC="${DW_DARLING_SRC:-$(cd "$DW_ROOT/.." && pwd)/darling}"
BEADS_DIR="$DW_ROOT/.beads"
export BEADS_DIR
REPO_ROOT="$(cd "$DW_DARLING_SRC/.." 2>/dev/null && pwd || true)"

die() {
  printf 'dw: %s\n' "$*" >&2
  exit 1
}

require_source() {
  git -C "$DW_DARLING_SRC" rev-parse --show-toplevel >/dev/null 2>&1 ||
    die "Darling checkout not found at $DW_DARLING_SRC"
}

require_repo() {
  command -v repo >/dev/null || die "repo is not installed"
  [[ -n "$REPO_ROOT" && -d "$REPO_ROOT/.repo" ]] ||
    die "$DW_DARLING_SRC is not inside a repo-managed client"
}

status() {
  require_source
  printf 'control: %s\nsource:  %s\n\n' "$DW_ROOT" "$DW_DARLING_SRC"
  if [[ -d "$REPO_ROOT/.repo" ]]; then
    (cd "$REPO_ROOT" && repo status)
  else
    git -C "$DW_DARLING_SRC" status --short --branch
    git -C "$DW_DARLING_SRC" submodule foreach --recursive '
      changes=$(git status --porcelain)
      branch=$(git symbolic-ref --quiet --short HEAD || printf "DETACHED")
      if test -n "$changes" || test "$branch" != "DETACHED"; then
        printf "\n[%s] %s\n" "$displaypath" "$branch"
        git status --short
      fi
    '
  fi
}

snapshot() {
  require_source
  local output tmp
  output="$DW_ROOT/state/repos.tsv"
  tmp="$output.tmp"
  printf 'path\thead\tbranch\torigin\tworktree\n' >"$tmp"

  local head branch origin worktree
  head=$(git -C "$DW_DARLING_SRC" rev-parse HEAD)
  branch=$(git -C "$DW_DARLING_SRC" symbolic-ref --quiet --short HEAD || printf 'DETACHED')
  origin=$(git -C "$DW_DARLING_SRC" remote get-url origin 2>/dev/null || printf '-')
  worktree=clean
  [[ -z "$(git -C "$DW_DARLING_SRC" status --porcelain)" ]] || worktree=dirty
  printf '.\t%s\t%s\t%s\t%s\n' "$head" "$branch" "$origin" "$worktree" >>"$tmp"

  export DW_SNAPSHOT="$tmp"
  git -C "$DW_DARLING_SRC" submodule foreach --quiet --recursive '
    head=$(git rev-parse HEAD)
    branch=$(git symbolic-ref --quiet --short HEAD || printf "DETACHED")
    origin=$(git remote get-url origin 2>/dev/null || printf "-")
    worktree=clean
    test -z "$(git status --porcelain)" || worktree=dirty
    printf "%s\t%s\t%s\t%s\t%s\n" \
      "$displaypath" "$head" "$branch" "$origin" "$worktree" >>"$DW_SNAPSHOT"
  '
  mv "$tmp" "$output"
  "$DW_ROOT/scripts/generate_manifest.py" \
    --source "$DW_DARLING_SRC" \
    --output "$DW_ROOT/locked.xml"
  "$DW_ROOT/scripts/generate_manifest.py" \
    --source "$DW_DARLING_SRC" \
    --output "$DW_ROOT/base.xml" \
    --base
  "$DW_ROOT/scripts/handoff.py" pack \
    --source "$DW_DARLING_SRC" \
    --bundles "$DW_ROOT/handoff"
  printf 'wrote %s\n' "$output"
  printf 'wrote %s\n' "$DW_ROOT/locked.xml"
  printf 'wrote %s\n' "$DW_ROOT/base.xml"
}

doctor() {
  require_source
  command -v br >/dev/null || die "br is not installed"
  printf 'control: %s\nsource:  %s\nbeads:   %s\n' \
    "$DW_ROOT" "$DW_DARLING_SRC" "$(br where)"
  br sync --status
  if [[ -d "$REPO_ROOT/.repo" ]]; then
    printf 'repo:    %s\n' "$REPO_ROOT"
    (cd "$REPO_ROOT" && repo manifest -r -o /tmp/darling-workspace-manifest.xml)
  else
    printf 'repo:    legacy checkout (run dw bootstrap <directory>)\n'
  fi
}

bootstrap() {
  command -v repo >/dev/null || die "repo is not installed"
  local destination manifest_url
  destination="${1:-}"
  manifest_url="${2:-$(git -C "$DW_ROOT" remote get-url origin 2>/dev/null || true)}"
  [[ -n "$destination" ]] || die "usage: dw bootstrap <directory> [manifest-url]"
  [[ -n "$manifest_url" ]] ||
    die "manifest URL is required until this control repository has origin"
  mkdir -p "$destination"
  (
    cd "$destination"
    repo init -u "$manifest_url" -m base.xml
    repo sync -c --no-tags -j"${DW_SYNC_JOBS:-16}"
  )
  "$DW_ROOT/scripts/handoff.py" restore \
    --source "$destination/darling" \
    --bundles "$DW_ROOT/handoff"
  printf 'workspace ready at %s\n' "$destination"
}

dirty() {
  require_source
  if [[ -d "$REPO_ROOT/.repo" ]]; then
    (
      cd "$REPO_ROOT"
      repo forall -p -c '
        test -z "$(git status --porcelain)" || git status --short --branch
      '
    )
  else
    status
  fi
}

topic() {
  require_repo
  local name
  name="${1:-}"
  [[ -n "$name" ]] || die "usage: dw topic <name> [project ...]"
  shift
  (cd "$REPO_ROOT" && repo start "$name" "$@")
}

source_sync() {
  require_repo
  (cd "$REPO_ROOT" && repo sync --no-tags -j"${DW_SYNC_JOBS:-16}" "$@")
}

forall() {
  require_repo
  [[ $# -gt 0 ]] || die "usage: dw forall <shell command>"
  local command
  command="$*"
  (cd "$REPO_ROOT" && repo forall -p -c "$command")
}

setup_local() {
  require_source
  local exclude source_agents target_agents pattern
  exclude="$DW_DARLING_SRC/.git/info/exclude"
  source_agents="$DW_ROOT/source/AGENTS.md"
  target_agents="$DW_DARLING_SRC/AGENTS.md"

  mkdir -p "$(dirname "$exclude")"
  for pattern in '.beads/' 'AGENTS.md' 'pr-drafts/' '.bv/'; do
    grep -Fqx "$pattern" "$exclude" 2>/dev/null ||
      printf '%s\n' "$pattern" >>"$exclude"
  done

  if [[ ! -e "$target_agents" ]]; then
    cp "$source_agents" "$target_agents"
    printf 'installed %s\n' "$target_agents"
  elif ! cmp -s "$source_agents" "$target_agents"; then
    printf 'kept existing %s (differs from control copy)\n' "$target_agents"
  fi
  printf 'updated %s\n' "$exclude"
}

usage() {
  cat <<'EOF'
Usage: dw <command> [args]

Commands:
  status            Show source and active submodule state
  dirty             Show only repositories with worktree changes
  bootstrap DIR [URL]
                    Create a repo-managed client from locked.xml
  source-sync [...] Run repo sync across source repositories
  topic NAME [PROJECT...]
                    Start the same topic branch in selected projects
  forall COMMAND    Run a shell command in every project
  snapshot          Write state/repos.tsv
  beads [args...]   Run br against the control repository
  handoff           Export Beads and refresh locked manifest/state
  doctor            Validate paths and Beads state
  setup-local       Install local agent instructions and Git excludes
  env               Print resolved workspace paths
EOF
}

case "${1:-}" in
  status)
    status
    ;;
  dirty)
    dirty
    ;;
  bootstrap)
    shift
    bootstrap "$@"
    ;;
  source-sync)
    shift
    source_sync "$@"
    ;;
  topic)
    shift
    topic "$@"
    ;;
  forall)
    shift
    forall "$@"
    ;;
  snapshot)
    snapshot
    ;;
  beads)
    shift
    exec br "$@"
    ;;
  handoff|sync)
    br sync --flush-only
    snapshot
    git -C "$DW_ROOT" status --short
    ;;
  doctor)
    doctor
    ;;
  setup-local)
    setup_local
    ;;
  env)
    printf 'DW_ROOT=%s\nDW_DARLING_SRC=%s\nBEADS_DIR=%s\n' \
      "$DW_ROOT" "$DW_DARLING_SRC" "$BEADS_DIR"
    ;;
  help|-h|--help|'')
    usage
    ;;
  *)
    usage >&2
    exit 2
    ;;
esac
