+static int set_receive_timeout(int fd, int seconds) {
+	struct timeval timeout = {
+		.tv_sec = seconds,
+		.tv_usec = 0,
+	};
+
+	if (setsockopt(fd, SOL_SOCKET, SO_RCVTIMEO, &timeout, sizeof(timeout)) < 0) {
+		return errno;
+	}
+
+	return 0;
+}
+
+static dserver_rpc_architecture_t current_architecture(void) {
+#if __x86_64__
+	return dserver_rpc_architecture_x86_64;
+#elif __i386__
+	return dserver_rpc_architecture_i386;
+#elif __aarch64__
+	return dserver_rpc_architecture_arm64;
+#elif __arm__
+	return dserver_rpc_architecture_arm32;
+#else
+	return dserver_rpc_architecture_invalid;
+#endif
+}
