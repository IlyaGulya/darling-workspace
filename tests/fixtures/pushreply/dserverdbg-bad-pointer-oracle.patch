+static int run_pushreply_bad_pointer_oracle(void) {
+	int status = 0;
+	int pipe_ends[2] = {-1, -1};
+	dserver_rpc_call_push_reply_t call = {
+		.header = {
+			.number = dserver_callnum_push_reply,
+			.pid = getpid(),
+			.tid = (pid_t)syscall(SYS_gettid),
+			.architecture = current_architecture(),
+		},
+		.reply = 1,
+		.reply_size = sizeof(dserver_rpc_replyhdr_t),
+	};
+	struct iovec iov = {
+		.iov_base = &call,
+		.iov_len = sizeof(call),
+	};
+	char control[CMSG_SPACE(sizeof(int))] = {};
+	struct msghdr message = {
+		.msg_name = &__dserver_socket_address_data,
+		.msg_namelen = sizeof(__dserver_socket_address_data),
+		.msg_iov = &iov,
+		.msg_iovlen = 1,
+		.msg_control = control,
+		.msg_controllen = sizeof(control),
+	};
+	struct cmsghdr* cmsg = CMSG_FIRSTHDR(&message);
+
+	status = set_receive_timeout(__dserver_main_thread_socket_fd, 3);
+	if (status != 0) {
+		fprintf(stderr, "DSERVERDBG_RECV_TIMEOUT_SETUP_RC=%d (%s)\n", status, strerror(status));
+		return 1;
+	}
+
+	status = dserver_rpc_checkin(false, NULL, -1);
+	printf("DSERVERDBG_CHECKIN_RC=%d\n", status);
+	if (status != 0) {
+		return 1;
+	}
+
+	if (pipe(pipe_ends) != 0) {
+		status = errno;
+		fprintf(stderr, "DSERVERDBG_PUSHREPLY_PIPE_RC=%d (%s)\n", status, strerror(status));
+		return 1;
+	}
+
+	cmsg->cmsg_len = CMSG_LEN(sizeof(int));
+	cmsg->cmsg_level = SOL_SOCKET;
+	cmsg->cmsg_type = SCM_RIGHTS;
+	memcpy(CMSG_DATA(cmsg), &pipe_ends[1], sizeof(pipe_ends[1]));
+
+	ssize_t sent = sendmsg(__dserver_main_thread_socket_fd, &message, 0);
+	close(pipe_ends[1]);
+	pipe_ends[1] = -1;
+	printf("DSERVERDBG_PUSHREPLY_SEND_RC=%zd\n", sent);
+	if (sent != (ssize_t)sizeof(call)) {
+		status = errno;
+		fprintf(stderr, "DSERVERDBG_PUSHREPLY_SEND_ERR=%d (%s)\n", status, strerror(status));
+		close(pipe_ends[0]);
+		return 1;
+	}
+
+	struct pollfd poll_fd = {
+		.fd = pipe_ends[0],
+		.events = POLLIN | POLLHUP,
+	};
+	int poll_rc = poll(&poll_fd, 1, 3000);
+	if (poll_rc < 0) {
+		status = errno;
+		fprintf(stderr, "DSERVERDBG_PUSHREPLY_POLL_RC=%d (%s)\n", status, strerror(status));
+		close(pipe_ends[0]);
+		return 1;
+	}
+	printf("DSERVERDBG_PUSHREPLY_POLL_RC=%d\n", poll_rc);
+
+	if (poll_rc == 0) {
+		printf("DSERVERDBG_PUSHREPLY_PIPE_TIMEOUT=1\n");
+		fprintf(stderr, "push_reply pipe did not close after bad pointer\n");
+		close(pipe_ends[0]);
+		return 1;
+	}
+
+	char byte = 0;
+	ssize_t read_rc = read(pipe_ends[0], &byte, sizeof(byte));
+	printf("DSERVERDBG_PUSHREPLY_PIPE_READ_RC=%zd\n", read_rc);
+	if (read_rc == 1) {
+		printf("DSERVERDBG_PUSHREPLY_PIPE_ACK=%d\n", (int)byte);
+	} else if (read_rc == 0) {
+		printf("DSERVERDBG_PUSHREPLY_PIPE_EOF=1\n");
+	}
+	close(pipe_ends[0]);
+	return 0;
+}
