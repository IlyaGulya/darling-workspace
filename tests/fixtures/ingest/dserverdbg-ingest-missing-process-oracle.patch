+static int write_ingest_missing_process_fault(void) {
+	const char* path = getenv("DSERVER_TEST_FAULT_FILE");
+	if (!path || path[0] == '\0') {
+		fprintf(stderr, "DSERVERDBG_INGEST_FAULT_FILE=missing\n");
+		return 1;
+	}
+
+	FILE* file = fopen(path, "w");
+	if (!file) {
+		int status = errno;
+		fprintf(stderr, "DSERVERDBG_INGEST_FAULT_WRITE_RC=%d (%s)\n", status, strerror(status));
+		return status;
+	}
+
+	if (fputs("ingest.force_missing_process\n", file) < 0) {
+		int status = errno;
+		fclose(file);
+		fprintf(stderr, "DSERVERDBG_INGEST_FAULT_WRITE_RC=%d (%s)\n", status, strerror(status));
+		return status;
+	}
+	if (fclose(file) != 0) {
+		int status = errno;
+		fprintf(stderr, "DSERVERDBG_INGEST_FAULT_CLOSE_RC=%d (%s)\n", status, strerror(status));
+		return status;
+	}
+
+	printf("DSERVERDBG_INGEST_FAULT_WRITTEN=1\n");
+	return 0;
+}
+
+static int run_ingest_missing_process_oracle(void) {
+	int old_uid = -1;
+	int old_gid = -1;
+	int status = 0;
+
+	status = set_receive_timeout(__dserver_main_thread_socket_fd, 3);
+	if (status != 0) {
+		fprintf(stderr, "DSERVERDBG_RECV_TIMEOUT_SETUP_RC=%d (%s)\n", status, strerror(status));
+		return 1;
+	}
+
+	status = dserver_rpc_checkin(false, NULL, -1);
+	printf("DSERVERDBG_CHECKIN_RC=%d\n", status);
+	if (status != 0) {
+		return 1;
+	}
+
+	status = write_ingest_missing_process_fault();
+	if (status != 0) {
+		return 1;
+	}
+
+	status = dserver_rpc_uidgid(-1, -1, &old_uid, &old_gid);
+	printf("DSERVERDBG_INGEST_UIDGID_RC=%d\n", status);
+	printf("DSERVERDBG_INGEST_OLD_UID=%d\n", old_uid);
+	printf("DSERVERDBG_INGEST_OLD_GID=%d\n", old_gid);
+
+	if (status == -ESRCH) {
+		printf("DSERVERDBG_INGEST_MISSING_PROCESS_OK\n");
+		return 0;
+	}
+
+	return 1;
+}
