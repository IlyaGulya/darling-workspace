 typedef uint32_t mach_port_type_t;
 typedef uint32_t mach_port_right_t;
@@ -47,6 +48,7 @@ typedef enum dserverdbg_command {
 	dserverdbg_command_lsport,
 	dserverdbg_command_lspset,
 	dserverdbg_command_lsmsg,
