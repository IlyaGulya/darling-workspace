+
+static int set_receive_timeout(int fd, int seconds) {
+	struct timeval timeout = {
+		.tv_sec = seconds,
+		.tv_usec = 0,
+	};
+
+	if (setsockopt(fd, SOL_SOCKET, SO_RCVTIMEO, &timeout, sizeof(timeout)) < 0) {
+		return errno;
+	}
+
+	return 0;
+}
+
+static int run_microthread_resume_before_suspend_oracle(void) {
+	uint64_t thread_state[128] = {};
+	uint64_t float_state[128] = {};
+	int status = 0;
+
+	status = set_receive_timeout(__dserver_main_thread_socket_fd, 3);
+	if (status != 0) {
+		fprintf(stderr, "DSERVERDBG_RECV_TIMEOUT_SETUP_RC=%d (%s)\n", status, strerror(status));
+		return 1;
+	}
+
+	status = dserver_rpc_checkin(false, NULL, -1);
+	printf("DSERVERDBG_CHECKIN_RC=%d\n", status);
+	if (status != 0) {
+		return 1;
+	}
+
+	status = dserver_rpc_thread_suspended((uint64_t)thread_state, (uint64_t)float_state);
+	printf("DSERVERDBG_THREAD_SUSPENDED_RC=%d\n", status);
+
+	if (status == 0) {
+		printf("DSERVERDBG_MICROTHREAD_RESUME_BEFORE_SUSPEND_OK\n");
+		return 0;
+	}
+	if (status == -EAGAIN) {
+		return 1;
+	}
+
+	return 1;
+}
