+static int set_receive_timeout(int fd, int seconds) {
+	struct timeval timeout = {
+		.tv_sec = seconds,
+		.tv_usec = 0,
+	};
+
+	if (setsockopt(fd, SOL_SOCKET, SO_RCVTIMEO, &timeout, sizeof(timeout)) < 0) {
+		return errno;
+	}
+
+	return 0;
+}
+
+static int run_pthread_cancel_state_oracle(void) {
+	int status = 0;
+	uint32_t thread_port = 0;
+
+	status = set_receive_timeout(__dserver_main_thread_socket_fd, 3);
+	if (status != 0) {
+		fprintf(stderr, "DSERVERDBG_RECV_TIMEOUT_SETUP_RC=%d (%s)\n", status, strerror(status));
+		return 1;
+	}
+
+	status = dserver_rpc_checkin(false, NULL, -1);
+	printf("DSERVERDBG_CHECKIN_RC=%d\n", status);
+	if (status != 0) {
+		return 1;
+	}
+
+	status = dserver_rpc_pthread_canceled(1);
+	printf("DSERVERDBG_PTHREAD_CANCELED_ACTION1_RC=%d\n", status);
+	if (status == -ENOSYS) {
+		printf("DSERVERDBG_PTHREAD_CANCEL_STUB_OK\n");
+		return 1;
+	}
+	if (status != 0) {
+		return 1;
+	}
+
+	status = dserver_rpc_pthread_canceled(2);
+	printf("DSERVERDBG_PTHREAD_CANCELED_ACTION2_RC=%d\n", status);
+	if (status != 0) {
+		return 1;
+	}
+
+	status = dserver_rpc_pthread_canceled(0);
+	printf("DSERVERDBG_PTHREAD_CANCELED_DISABLED_ACTION0_RC=%d\n", status);
+	if (status != -EINVAL) {
+		return 1;
+	}
+
+	status = dserver_rpc_thread_self_trap(&thread_port);
+	printf("DSERVERDBG_THREAD_SELF_RC=%d\n", status);
+	printf("DSERVERDBG_THREAD_SELF_PORT=%u\n", thread_port);
+	if (status != 0 || thread_port == 0) {
+		return 1;
+	}
+
+	status = dserver_rpc_pthread_markcancel(thread_port);
+	printf("DSERVERDBG_PTHREAD_MARKCANCEL_RC=%d\n", status);
+	if (status != 0) {
+		return 1;
+	}
+
+	status = dserver_rpc_pthread_canceled(1);
+	printf("DSERVERDBG_PTHREAD_CANCELED_ENABLE_RC=%d\n", status);
+	if (status != 0) {
+		return 1;
+	}
+
+	status = dserver_rpc_pthread_canceled(0);
+	printf("DSERVERDBG_PTHREAD_CANCELED_PENDING_ACTION0_RC=%d\n", status);
+	if (status != 0) {
+		return 1;
+	}
+
+	printf("DSERVERDBG_PTHREAD_CANCEL_STATE_OK\n");
+	return 0;
+}
